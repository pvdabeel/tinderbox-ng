#!/bin/bash
#
# tinderbox-ng - Gentoo build-testing rig with overlayfs sessions
#
# Builds an immutable baseline (latest stage3 + SWI-Prolog + portage-ng + kb.qlf)
# and exposes it as the lower layer of an overlayfs-backed chroot. Each
# experiment runs in its own session whose writes land in an upper layer that
# can be discarded with one command.
#
# The host OS root is never touched: the chroot lives entirely under
# $TINDERBOX_ROOT (default /srv/tinderbox-ng), the Portage tree binds in
# read-only, and host-side caches like /var/db/pkg are not mounted in.
#
# See README.md in this repository for deployment notes.

set -euo pipefail

# =============================================================================
# Configuration (env overridable)
# =============================================================================

TINDERBOX_ROOT="${TINDERBOX_ROOT:-/srv/tinderbox-ng}"
BASELINE_DIR="$TINDERBOX_ROOT/baseline"
SHARED_DIR="$TINDERBOX_ROOT/shared"
SESSIONS_DIR="$TINDERBOX_ROOT/sessions"
SCRIPTS_DIR="$TINDERBOX_ROOT/scripts"
LOG_DIR="$TINDERBOX_ROOT/logs"

TREE_DIR="$SHARED_DIR/portage-tree"
DISTFILES_DIR="$SHARED_DIR/distfiles"
CCACHE_DIR="$SHARED_DIR/ccache"
BINPKGS_DIR="$SHARED_DIR/binpkgs"
STAGE3_CACHE="$SHARED_DIR/stage3"

# Stage3 settings
#
# IMPORTANT: the default `amd64-openrc` stage3 is **merged-usr** since 23.0.
# Source/config.pl:96 pins `default/linux/amd64/23.0/split-usr/no-multilib`.
# A merged-usr stage3 + split-usr profile fails every ebuild setup phase with
# "ERROR: 23.0 split-usr profile, but disk is merged-usr". So the default here
# is the split-usr variant; flip to amd64-openrc if you also flip
# config:gentoo_profile/1 to a merged-usr profile.
STAGE3_VARIANT="${STAGE3_VARIANT:-amd64-openrc-splitusr}"
STAGE3_ARCH="${STAGE3_ARCH:-amd64}"
STAGE3_BASE_URL="${STAGE3_BASE_URL:-https://distfiles.gentoo.org/releases/${STAGE3_ARCH}/autobuilds}"
GENTOO_RELENG_KEY="${GENTOO_RELENG_KEY:-0xBB572E0E2D182910}"

# Portage tree (gentoo-mirror gives a stable git history; rsync would also work)
PORTAGE_TREE_URL="${PORTAGE_TREE_URL:-https://github.com/gentoo-mirror/gentoo.git}"
PORTAGE_TREE_PIN="${PORTAGE_TREE_PIN:-}"

# portage-ng repo. PORTAGE_NG_URL (git clone) takes precedence; otherwise
# the script rsyncs from PORTAGE_NG_LOCAL into the baseline. Since
# tinderbox-ng now lives in its own repository, there is no in-tree
# auto-detection: PORTAGE_NG_URL or PORTAGE_NG_LOCAL must be set
# explicitly, or one of the conventional deploy paths
# (/root/prolog, /opt/portage-ng, /opt/prolog) must already exist on the
# host. doctor surfaces a missing setting as an error before bootstrap
# touches anything.
SCRIPT_PATH="$(readlink -f -- "$0" 2>/dev/null || printf '%s' "$0")"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"

_pn_is_repo() {
  # portage-ng.pl is the project entry point at the repo root.
  # Source/loader.pl is the module loader. Either marker is sufficient.
  [[ -f "$1/portage-ng.pl" ]] || [[ -f "$1/Source/loader.pl" ]]
}

_pn_autodetect() {
  local cand
  for cand in /root/prolog /opt/portage-ng /opt/prolog; do
    if _pn_is_repo "$cand"; then printf '%s' "$cand"; return; fi
  done
  printf ''
}

PORTAGE_NG_URL="${PORTAGE_NG_URL:-}"
PORTAGE_NG_LOCAL="${PORTAGE_NG_LOCAL:-$(_pn_autodetect)}"
PORTAGE_NG_REF="${PORTAGE_NG_REF:-HEAD}"

# Library + share directories. The canonical layout is "the repo, copied
# verbatim under one prefix":
#
#   <prefix>/bin/tinderbox-ng              ← entry point (this script)
#   <prefix>/libexec/tinderbox-ng/         ← executable helpers tinderbox-ng invokes
#   <prefix>/share/tinderbox-ng/           ← read-only data: templates + manifests
#   <prefix>/share/man/man8/tinderbox-ng.8 ← manpage
#
# Both dev checkouts and deploy-host.sh produce that structure, so the
# default resolution is just "../{libexec,share}/tinderbox-ng" relative
# to bin/. Override per-bucket with TINDERBOX_LIBEXEC_DIR or
# TINDERBOX_SHARE_DIR. The legacy single-bucket TINDERBOX_LIB_DIR is
# honoured for backward compatibility - it maps to both new variables,
# which works for pre-reorg installs that flattened everything into one
# directory.
_default_libexec_dir="$SCRIPT_DIR/../libexec/tinderbox-ng"
_default_share_dir="$SCRIPT_DIR/../share/tinderbox-ng"
LIBEXEC_DIR="${TINDERBOX_LIBEXEC_DIR:-${TINDERBOX_LIB_DIR:-$_default_libexec_dir}}"
SHARE_DIR="${TINDERBOX_SHARE_DIR:-${TINDERBOX_LIB_DIR:-$_default_share_dir}}"

# Profile + locale (must match Source/config.pl:96 and what the baseline runs)
GENTOO_PROFILE="${GENTOO_PROFILE:-default/linux/amd64/23.0/split-usr/no-multilib}"
GENTOO_LOCALE="${GENTOO_LOCALE:-en_US.UTF-8 UTF-8}"
GENTOO_LOCALE_NAME="${GENTOO_LOCALE_NAME:-en_US.utf8}"

# In-chroot paths used by the existing Source/Config/vm-linux.local.pl
CHROOT_TREE_PATH="/usr/portage"
CHROOT_DISTFILES_PATH="/var/cache/distfiles"
CHROOT_CCACHE_PATH="/var/cache/ccache"
CHROOT_BINPKGS_PATH="/var/cache/binpkgs"
CHROOT_PORTAGE_NG="/opt/portage-ng"
CHROOT_GRAPH_DIR="/root/Graph"

# Hosts that must be resolvable inside the chroot but are only known to
# the host via mDNS / Avahi (e.g. *.local). The chroot's nsswitch.conf
# only has 'files dns', so without nss-mdns these names fail to resolve.
# We resolve them once on the host (which has nss-mdns) at session-mount
# time and inject the IPs into the session's /etc/hosts. Space-separated.
TINDERBOX_MDNS_HOSTS="${TINDERBOX_MDNS_HOSTS:-mac-pro.local imac-pro.local}"

# tmpfs mount over the whole sessions directory. Backs every session's
# OverlayFS upper layer with RAM instead of disk, which means *every*
# write that happens in a chroot (src_unpack, src_compile, src_install,
# image staging, VDB merge) lands in RAM. Eliminates the ext4 journal
# (jbd2) serialisation that bottlenecks 16+ concurrent builds and the
# NVMe submission-queue saturation that follows from sustained burst
# writes (timeouts of the form "nvme0: I/O tag X QID Y timeout,
# completion polled" in dmesg).
#
# One shared tmpfs (rather than per-session) gives natural workload
# balancing - a single big build can use up to the whole cap if every
# other session is small. Set to empty to disable (sessions then live
# on the regular host filesystem). Tmpfs is sparse: actual RAM use only
# grows with bytes written.
#
# Default `auto` sizes from host RAM and expected compare-matrix
# concurrency (see _compute_sessions_tmpfs_size). When $TINDERBOX_ROOT
# is already a tmpfs (AWS ami-tinder), auto disables a nested mount.
# Override with an explicit cap (e.g. 100G) or 0 to disable.
TINDERBOX_SESSIONS_TMPFS_SIZE="${TINDERBOX_SESSIONS_TMPFS_SIZE:-auto}"

# ccache shared cache size (host-side, bind-mounted into every session at
# /var/cache/ccache). Sized for the 1000-package comparison matrix which
# includes heavy hitters (LLVM, Qt, GCC, etc.). 100G gives meaningful hit
# rates on the second matrix pass without churning the cache. Bumping
# this only consumes disk; ccache compresses and only fills lazily.
TINDERBOX_CCACHE_MAX_SIZE="${TINDERBOX_CCACHE_MAX_SIZE:-100G}"

# =============================================================================
# Logging helpers
# =============================================================================

_RED=$'\033[31m' _YEL=$'\033[33m' _GRN=$'\033[32m' _BLU=$'\033[34m' _RST=$'\033[0m'
[[ -t 2 ]] || { _RED= _YEL= _GRN= _BLU= _RST=; }

log_info()  { printf '%s[tinderbox-ng]%s %s\n' "$_BLU" "$_RST" "$*" >&2; }
log_warn()  { printf '%s[tinderbox-ng warn]%s %s\n' "$_YEL" "$_RST" "$*" >&2; }
log_error() { printf '%s[tinderbox-ng error]%s %s\n' "$_RED" "$_RST" "$*" >&2; }
log_ok()    { printf '%s[tinderbox-ng ok]%s %s\n' "$_GRN" "$_RST" "$*" >&2; }

die() { log_error "$*"; exit 1; }

# =============================================================================
# Pre-flight
# =============================================================================

require_root() {
  [[ $EUID -eq 0 ]] || die "must be run as root (try: sudo $0 $*)"
}

require_kernel_overlay() {
  if ! grep -qw overlay /proc/filesystems; then
    if ! modprobe overlay 2>/dev/null; then
      die "overlay filesystem not available in kernel; load CONFIG_OVERLAY_FS"
    fi
  fi
}

require_unshare() {
  command -v unshare >/dev/null 2>&1 \
    || die "unshare(1) not found; install sys-apps/util-linux"
  # Sanity-check the kernel supports private mount + IPC namespaces - this
  # should always succeed on a modern Linux but is worth confirming so we
  # bail out before mounting anything.
  if ! unshare --mount --ipc --propagation=private true 2>/dev/null; then
    die "kernel refused 'unshare --mount --ipc --propagation=private'; check CONFIG_NAMESPACES"
  fi
}

require_dirs() {
  [[ -d "$TINDERBOX_ROOT" ]] || die "$TINDERBOX_ROOT does not exist; run 'tinderbox-ng bootstrap' first"
  [[ -d "$BASELINE_DIR/usr" ]] || die "$BASELINE_DIR is not a populated baseline; run 'tinderbox-ng bootstrap' first"
}

# -----------------------------------------------------------------------------
# Preflight aggregation
# -----------------------------------------------------------------------------
#
# Every prerequisite the bootstrap, session-mount, and compare paths depend on.
# Centralised here so `cmd_doctor` can report all problems at once instead of
# the historical "die mid-bootstrap" mode where a missing tool would only
# surface after stage3 was already on disk.

# Required host-side binaries. Bash 5 syntax; tested at startup of cmd_doctor.
TINDERBOX_REQUIRED_BINS=(
  bash mount umount findmnt flock unshare modprobe
  curl git rsync tar gpg gpgconf sha512sum sed awk grep
  install ln chmod chown stat install rmdir
)

# Optional bins that we use when present but degrade gracefully without.
TINDERBOX_OPTIONAL_BINS=(
  ts          # moreutils; timestamps in cmd_exec output
  pgrep       # used by sweep_session_orphans belt-and-suspenders pass
  chattr      # defensive on refresh-kb / install-ccache / refresh-portage-ng
  getent      # used to resolve mDNS hosts; falls back silently
)

# Required data files under $SHARE_DIR (templates copied into the baseline
# at bootstrap time, plus the manifests the matrix harness consumes).
# Missing any of these will silently break a downstream command.
TINDERBOX_REQUIRED_TEMPLATES=(
  baseline.make.conf
  baseline.package.use
  baseline.repos.conf
  portage-ng-dev.in
  manifest-100.txt
  manifest-1000.txt
)

# Required executable helpers under $LIBEXEC_DIR (scripts tinderbox-ng
# invokes itself, or installs into the baseline). Missing any of these
# will silently break a downstream command.
TINDERBOX_REQUIRED_HELPERS=(
  run-matrix.sh
  compare-matrix.sh
  compare-merge-emerge.py
  consolidate-phase-stats.py
  extract-timing.py
)

# Minimum disk-space hints (in MiB) for $TINDERBOX_ROOT before bootstrap.
# Stage3 + swi-prolog + tree + kb.qlf already need ~10G. Add headroom for
# distfiles + first runs.
TINDERBOX_MIN_FREE_MIB="${TINDERBOX_MIN_FREE_MIB:-30000}"

# Is the sessions directory currently a tmpfs mount?
sessions_tmpfs_active() {
  [[ -d "$SESSIONS_DIR" ]] || return 1
  local fstype
  fstype="$(findmnt -no FSTYPE --target "$SESSIONS_DIR" 2>/dev/null)"
  [[ "$fstype" == "tmpfs" ]] && [[ "$(stat -c %m "$SESSIONS_DIR" 2>/dev/null)" == "$SESSIONS_DIR" ]]
}

_host_mem_gib() {
  local mem_kib
  mem_kib="$(awk '/^MemTotal:/ {print $2}' /proc/meminfo 2>/dev/null || echo 0)"
  echo $(( (mem_kib + 1048575) / 1024 / 1024 ))
}

_tinderbox_root_on_tmpfs() {
  [[ -d "$TINDERBOX_ROOT" ]] || return 1
  [[ "$(findmnt -no FSTYPE --target "$TINDERBOX_ROOT" 2>/dev/null)" == "tmpfs" ]]
}

# Estimate a sessions-tmpfs cap from RAM and compare concurrency. Each
# active compare holds two overlay sessions (portage-ng + emerge); budget
# ~4 GiB per session for --build workdirs (portage_tmpdir + upper).
_compute_sessions_tmpfs_size() {
  local mem_gib nproc_logical jobs_hint need_gib cap_gib

  if _tinderbox_root_on_tmpfs; then
    echo 0
    return 0
  fi

  mem_gib="$(_host_mem_gib)"
  (( mem_gib < 1 )) && { echo 100G; return 0; }

  if [[ -n "${TINDERBOX_MATRIX_JOBS:-}" && "${TINDERBOX_MATRIX_JOBS}" =~ ^[0-9]+$ ]]; then
    jobs_hint="$TINDERBOX_MATRIX_JOBS"
  else
    nproc_logical="$(nproc 2>/dev/null || echo 4)"
    jobs_hint=$(( nproc_logical / 2 ))
    (( jobs_hint < 1 )) && jobs_hint=1
    local mem_jobs=$(( mem_gib / 8 ))
    (( jobs_hint > mem_jobs )) && jobs_hint=$mem_jobs
  fi

  need_gib=$(( jobs_hint * 2 * 4 ))
  cap_gib=$(( mem_gib * 70 / 100 ))
  (( need_gib > cap_gib )) && need_gib=$cap_gib
  (( need_gib < 32 )) && need_gib=32
  echo "${need_gib}G"
}

_resolve_sessions_tmpfs_size() {
  local configured="${1:-${TINDERBOX_SESSIONS_TMPFS_SIZE:-auto}}"
  case "$configured" in
    ''|0) echo 0 ;;
    auto|AUTO) _compute_sessions_tmpfs_size ;;
    *) echo "$configured" ;;
  esac
}

# Mount tmpfs over $SESSIONS_DIR if requested by config and not already
# mounted. Idempotent and flock-protected so concurrent callers (e.g. 16
# parallel `tinderbox-ng compare` workers driven by compare-matrix.sh)
# don't race to mount the same target. No-op when
# TINDERBOX_SESSIONS_TMPFS_SIZE is empty or '0'.
_ensure_sessions_tmpfs() {
  local size
  size="$(_resolve_sessions_tmpfs_size)"
  [[ -n "$size" && "$size" != "0" ]] || return 0
  install -d "$SESSIONS_DIR"
  local lock="$TINDERBOX_ROOT/.sessions-tmpfs.lock"
  (
    flock 9
    if sessions_tmpfs_active; then
      return 0
    fi
    if [[ -n "$(ls -A "$SESSIONS_DIR" 2>/dev/null)" ]]; then
      log_warn "$SESSIONS_DIR not empty; tmpfs mount will hide existing sessions"
      log_warn "  destroy them first or unset TINDERBOX_SESSIONS_TMPFS_SIZE to keep them"
    fi
    if [[ "${TINDERBOX_SESSIONS_TMPFS_SIZE:-auto}" == auto ]]; then
      log_info "mounting sessions tmpfs (auto size=$size; host RAM $(_host_mem_gib)GiB)"
    else
      log_info "mounting tmpfs (size=$size) over $SESSIONS_DIR"
    fi
    if ! mount -t tmpfs -o "size=$size,mode=0755,nosuid,nodev" \
                tinderbox-sessions "$SESSIONS_DIR"; then
      die "tmpfs mount on $SESSIONS_DIR failed (size=$size)"
    fi
  ) 9>"$lock"
}

# =============================================================================
# Session helpers
# =============================================================================

session_dir()    { printf '%s/%s' "$SESSIONS_DIR" "$1"; }
session_upper()  { printf '%s/%s/upper' "$SESSIONS_DIR" "$1"; }
session_work()   { printf '%s/%s/work' "$SESSIONS_DIR" "$1"; }
# session_portage_tmpdir is the per-session scratch directory bind-mounted
# at /var/tmp/portage inside the chroot. Lives ALONGSIDE upper/work, NOT
# under upper/, so it bypasses the overlay layer entirely — gtar's
# verify-after-create lstat() sees stable inodes from the underlying tmpfs
# instead of the overlay's inode-cache-reclaim flicker that produces
# "Directory renamed before its status could be extracted" on tarballs
# with many entries (mesa, librsvg, glib). Salvage helpers read from
# here directly; cmd_destroy wipes the whole session_dir so no extra
# cleanup is needed.
session_portage_tmpdir() { printf '%s/%s/portage_tmpdir' "$SESSIONS_DIR" "$1"; }
session_merged() { printf '%s/%s/merged' "$SESSIONS_DIR" "$1"; }
session_logs()   { printf '%s/%s/logs' "$SESSIONS_DIR" "$1"; }
session_lock()   { printf '%s/%s/.lock' "$SESSIONS_DIR" "$1"; }

require_session() {
  local name="$1"
  [[ -n "$name" ]] || die "session name required"
  [[ -d "$(session_dir "$name")" ]] || die "session '$name' does not exist (try 'tinderbox-ng new $name')"
}

session_is_mounted() {
  local merged
  merged="$(session_merged "$1")"
  mountpoint -q "$merged"
}

acquire_lock() {
  local name="$1" lock
  lock="$(session_lock "$name")"
  exec 9>"$lock"
  if ! flock -n 9; then
    die "session '$name' is locked by another process"
  fi
  printf '%d\n' $$ >&9
}

# =============================================================================
# Mount stack (per-session) - mount-namespace isolated
# =============================================================================
#
# All chrooting happens inside `unshare --mount --ipc --propagation=private`.
# Mounts made in that namespace are 100% invisible to the host; on namespace
# exit the kernel discards them automatically. --ipc keeps abstract AF_UNIX
# sockets (notably syslog's @/dev/log) out of the host journal. We never call
# umount in the host namespace, never call `umount -l`, and never `--rbind`
# /dev (we mount a fresh devtmpfs per session). This is the bulletproof safety
# design after the May 2026 host-/dev incident.

_mount_quiet() {
  if ! mount "$@" 2>/tmp/tinderbox-ng-mount.err; then
    log_error "mount failed: $*"
    cat /tmp/tinderbox-ng-mount.err >&2 || true
    return 1
  fi
}

# Session/baseline chroot entry: private mount + IPC namespaces.
_unshare_ns() {
  unshare --mount --ipc --propagation=private -- "$@"
}

# Drop syslog(3) from shadow account tools (groupadd/useradd during acct-*
# merges) inside the session. With --ipc abstract sockets already cannot reach
# host journald; this catches the filesystem /dev/log path too.
_ns_blackhole_dev_log() {
  local devdir="$1/dev"
  [[ -d "$devdir" ]] || return 0
  ln -sf /dev/null "$devdir/log"
}

# Resolve every mDNS hostname listed in $TINDERBOX_MDNS_HOSTS via the
# host's nsswitch (Avahi / nss-mdns) and append the result to the
# session's /etc/hosts file. Idempotent: skips entries already present.
# Silently skips names that cannot be resolved (mDNS responder offline,
# host removed from network, etc.) so the session can still proceed.
_inject_mdns_hosts() {
  local merged="$1"
  local hosts_file="$merged/etc/hosts"
  local h entry ip name

  [[ -n "${TINDERBOX_MDNS_HOSTS:-}" ]] || return 0
  [[ -f "$hosts_file" ]] || install -m 0644 /dev/null "$hosts_file" 2>/dev/null || return 0

  for h in $TINDERBOX_MDNS_HOSTS; do
    entry="$(getent hosts "$h" 2>/dev/null | head -n1)" || continue
    [[ -n "$entry" ]] || continue
    read -r ip name _ <<<"$entry"
    [[ -n "$ip" && -n "$name" ]] || continue
    if grep -qE "^[[:space:]]*[0-9a-fA-F:.]+[[:space:]]+(.*[[:space:]])?${name//./\\.}([[:space:]]|$)" "$hosts_file" 2>/dev/null; then
      continue
    fi
    printf '%s\t%s\t# tinderbox-ng mDNS injection\n' "$ip" "$name" >>"$hosts_file" 2>/dev/null || true
  done
}

# Mount the session's overlay + binds onto $merged. Must run inside an
# unshared mount namespace (called via __ns-helper).
_ns_session_mount() {
  local name="$1"
  local upper work merged
  upper="$(session_upper "$name")"
  work="$(session_work "$name")"
  merged="$(session_merged "$name")"

  mkdir -p "$upper" "$work" "$merged"

  # Defensive: even though unshare --propagation=private already set this,
  # explicitly re-mark / as rprivate inside our namespace.
  mount --make-rprivate / 2>/dev/null || true

  log_info "mounting overlay for session '$name' (in mount-ns)"
  _mount_quiet -t overlay "tinderbox-$name" \
    -o "lowerdir=$BASELINE_DIR,upperdir=$upper,workdir=$work,index=off,redirect_dir=off" \
    "$merged"

  # Fresh /dev — completely independent of host /dev
  _mount_quiet -t devtmpfs -o mode=0755,size=10M devtmpfs "$merged/dev"
  install -d "$merged/dev/pts" "$merged/dev/shm"
  _mount_quiet -t devpts  -o newinstance,ptmxmode=0620,gid=5 devpts "$merged/dev/pts"
  _mount_quiet -t tmpfs   -o mode=1777 tmpfs "$merged/dev/shm"
  _ns_blackhole_dev_log "$merged"

  _mount_quiet -t proc  proc  "$merged/proc"
  _mount_quiet -t sysfs sysfs "$merged/sys"
  _mount_quiet -t tmpfs -o nosuid,nodev,mode=755,size=128M tmpfs "$merged/run"

  # Portage tree (read-only bind; two-step is required by the kernel)
  mkdir -p "$merged$CHROOT_TREE_PATH"
  _mount_quiet --bind "$TREE_DIR" "$merged$CHROOT_TREE_PATH"
  mount -o remount,bind,ro "$merged$CHROOT_TREE_PATH"

  # Distfiles (rw, persistent across sessions)
  mkdir -p "$merged$CHROOT_DISTFILES_PATH" "$DISTFILES_DIR"
  _mount_quiet --bind "$DISTFILES_DIR" "$merged$CHROOT_DISTFILES_PATH"

  if [[ -d "$CCACHE_DIR" ]]; then
    mkdir -p "$merged$CHROOT_CCACHE_PATH"
    _mount_quiet --bind "$CCACHE_DIR" "$merged$CHROOT_CCACHE_PATH"
  fi

  if [[ -d "$BINPKGS_DIR" ]]; then
    mkdir -p "$merged$CHROOT_BINPKGS_PATH"
    _mount_quiet --bind "$BINPKGS_DIR" "$merged$CHROOT_BINPKGS_PATH"
  fi

  # /var/tmp/portage as a fresh per-session bind-mount of a host-side
  # scratch dir. Bypassing overlayfs here is the surgical fix for the
  # gtar "Directory renamed before its status could be extracted" class
  # of unpack failures: under inode-cache reclaim pressure (large-tarball
  # extractions racing with sibling sessions' workdirs) overlay assigns
  # fresh inode numbers to directories tar already recorded, and tar's
  # post-create lstat() bails. The bind goes onto a separate vfsmount
  # whose lookups never traverse the overlay layer, so inode numbers stay
  # stable. See _compare_summarize's INFRA(overlay-inode-flicker)
  # reclassifier for the matching telemetry.
  #
  # The scratch dir is created in cmd_new (chmod 2775, chown 250:250)
  # so PORTAGE_BUILDDIR=/var/tmp/portage/<cat>/<pf> is writable by the
  # FEATURES=userpriv user inside the chroot. Salvage helpers
  # (_compare_salvage_*) read from session_portage_tmpdir() directly
  # since the host-side path persists after the namespace exits.
  local portage_tmpdir
  portage_tmpdir="$(session_portage_tmpdir "$name")"
  if [[ -d "$portage_tmpdir" ]]; then
    mkdir -p "$merged/var/tmp/portage"
    _mount_quiet --bind "$portage_tmpdir" "$merged/var/tmp/portage"
  fi

  # DNS - bind so DHCP changes propagate. Target must exist. Stage3 ships
  # it; if missing (rare), create once. We never truncate via `>` because
  # of frozen-baseline / overlay copy-up edge cases.
  if [[ ! -e "$merged/etc/resolv.conf" ]]; then
    install -m 0644 /dev/null "$merged/etc/resolv.conf" 2>/dev/null || true
  fi
  if [[ -e "$merged/etc/resolv.conf" ]]; then
    _mount_quiet --bind /etc/resolv.conf "$merged/etc/resolv.conf"
  fi

  # Inject host-resolved mDNS entries into the session's /etc/hosts. The
  # baseline doesn't ship nss-mdns, so '.local' names cannot resolve from
  # inside the chroot; without this the local distfiles mirror at
  # http://mac-pro.local/distfiles is unreachable and downloads fall back
  # to the (slower, often pruned) public Gentoo mirror. Runs in the
  # namespace BEFORE chroot, so getent uses the host's nsswitch (which
  # has mdns4_minimal).
  _inject_mdns_hosts "$merged"

  # Verify ro on tree (defensive)
  if findmnt -no OPTIONS "$merged$CHROOT_TREE_PATH" | grep -qw rw; then
    die "tree bind ended up rw; refusing to chroot"
  fi
}

# unmount_session and session_is_mounted are now no-ops because all mounts
# live inside per-invocation mount namespaces and disappear when those exit.
# Kept as stubs so external callers / future subcommands don't break.
unmount_session()    { :; }
session_is_mounted() { return 1; }

# -----------------------------------------------------------------------------
# Orphan reaper
# -----------------------------------------------------------------------------
#
# Even with `unshare --mount --ipc --propagation=private`, a session's processes can
# survive past unshare's exit if they detach (PPID gets reparented to init).
# The most common offender is portage's die_hooks chain:
#
#   sandbox /usr/lib/portage/python3.13/misc-functions.sh die_hooks
#   bash    /usr/lib/portage/python3.13/misc-functions.sh die_hooks
#   python  /usr/lib/portage/python3.13/ebuild-ipc.py exit 0
#
# When the parent emerge gets killed mid-build (timeout, --keep-going abort,
# panic in our matrix harness), the die_hooks helpers spin trying to write to
# a FIFO whose reader is gone. ebuild-ipc.py in particular pegs a CPU at
# ~90% indefinitely.
#
# We identify session-owned processes via /proc/<pid>/root, which (when read
# from the host mount namespace as root) gives the absolute host-side path
# of the process's chroot directory. Any process whose root resolves under
# `$SESSIONS_DIR/$name/` is a leftover from this session and gets SIGKILL'd.
#
# We also sweep by name as belt-and-suspenders for processes whose /root
# symlink can't be resolved (e.g. defunct entries during the read race).

sweep_session_orphans() {
  local name="$1"
  local sess_path
  sess_path="$(readlink -f "$(session_dir "$name")" 2>/dev/null \
                || session_dir "$name")"
  [[ -d "$sess_path" ]] || return 0

  local self_pid=$$
  local killed=0 p pid root cmd
  for p in /proc/[0-9]*; do
    pid="${p##/proc/}"
    [[ "$pid" == "$self_pid" ]] && continue
    root="$(readlink "$p/root" 2>/dev/null)" || continue
    [[ -n "$root" ]] || continue
    case "$root" in
      "$sess_path"|"$sess_path"/*)
        cmd="$(tr '\0' ' ' <"$p/cmdline" 2>/dev/null | head -c 120)"
        log_warn "session '$name': reaping orphan PID $pid: ${cmd:-<unknown>}"
        kill -9 "$pid" 2>/dev/null && killed=$((killed + 1))
        ;;
    esac
  done

  for pat in 'ebuild-ipc.py' 'misc-functions.sh die_hooks'; do
    while read -r pid; do
      [[ -n "$pid" ]] || continue
      [[ "$pid" == "$self_pid" ]] && continue
      root="$(readlink "/proc/$pid/root" 2>/dev/null)" || continue
      case "$root" in
        "$sess_path"|"$sess_path"/*)
          cmd="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null | head -c 120)"
          log_warn "session '$name': reaping orphan PID $pid: ${cmd:-<unknown>}"
          kill -9 "$pid" 2>/dev/null && killed=$((killed + 1))
          ;;
      esac
    done < <(pgrep -f "$pat" 2>/dev/null)
  done

  if (( killed > 0 )); then
    log_info "session '$name': reaped $killed orphan process(es)"
  fi
  return 0
}

# =============================================================================
# Subcommand: doctor (preflight)
# =============================================================================
#
# Aggregate every prerequisite the rest of the script (especially bootstrap)
# depends on and report all problems in one pass. Without this, a missing
# tool or kernel feature surfaces only after stage3 has already been downloaded
# and unpacked - typically 5-15 minutes into bootstrap on a fresh VM.

cmd_doctor() {
  local fail=0
  local warn=0

  log_info "host preflight check (bootstrap prerequisites)"

  # Bash version
  local bash_major="${BASH_VERSINFO[0]:-0}"
  if (( bash_major < 5 )); then
    log_error "bash $BASH_VERSION (need >= 5.0; required for ${BASH_REMATCH[*]:+associative arrays} etc.)"
    fail=$((fail+1))
  else
    log_ok "bash $BASH_VERSION"
  fi

  # Required binaries
  local missing_req=()
  local b
  for b in "${TINDERBOX_REQUIRED_BINS[@]}"; do
    command -v "$b" >/dev/null 2>&1 || missing_req+=("$b")
  done
  if (( ${#missing_req[@]} > 0 )); then
    log_error "missing required commands: ${missing_req[*]}"
    log_error "  install via: emerge sys-apps/util-linux app-crypt/gnupg net-misc/curl dev-vcs/git net-misc/rsync app-arch/tar"
    fail=$((fail+1))
  else
    log_ok "all required commands present"
  fi

  local missing_opt=()
  for b in "${TINDERBOX_OPTIONAL_BINS[@]}"; do
    command -v "$b" >/dev/null 2>&1 || missing_opt+=("$b")
  done
  if (( ${#missing_opt[@]} > 0 )); then
    log_warn "optional commands missing (graceful degradation): ${missing_opt[*]}"
    log_warn "  ts: app-admin/moreutils (matrix log timestamps)"
    log_warn "  pgrep: sys-process/procps; chattr: sys-apps/e2fsprogs; getent: glibc"
    warn=$((warn+1))
  fi

  # Kernel overlay module
  if grep -qw overlay /proc/filesystems 2>/dev/null; then
    log_ok "overlay filesystem available in kernel"
  elif modprobe -n overlay 2>/dev/null; then
    log_warn "overlay not loaded but modprobe-able; bootstrap will load it"
    warn=$((warn+1))
  else
    log_error "overlay filesystem not available and not modprobe-able"
    log_error "  rebuild kernel with CONFIG_OVERLAY_FS=m or =y"
    fail=$((fail+1))
  fi

  # Mount-namespace support
  if unshare --mount --ipc --propagation=private true >/dev/null 2>&1; then
    log_ok "kernel supports unshare --mount --ipc --propagation=private"
  else
    log_error "kernel refused 'unshare --mount --ipc --propagation=private'"
    log_error "  enable CONFIG_NAMESPACES, CONFIG_USER_NS, CONFIG_PID_NS, CONFIG_MOUNT_NS"
    fail=$((fail+1))
  fi

  # devtmpfs (used by _ns_session_mount for fresh /dev)
  if grep -qw devtmpfs /proc/filesystems 2>/dev/null; then
    log_ok "devtmpfs available"
  else
    log_error "devtmpfs not available; sessions need a fresh /dev"
    fail=$((fail+1))
  fi

  # Data templates present (SHARE_DIR resolution)
  local missing_tpl=()
  local t
  for t in "${TINDERBOX_REQUIRED_TEMPLATES[@]}"; do
    [[ -f "$SHARE_DIR/$t" ]] || missing_tpl+=("$t")
  done
  if (( ${#missing_tpl[@]} > 0 )); then
    log_error "missing templates under $SHARE_DIR: ${missing_tpl[*]}"
    log_error "  re-run host install (contrib/deploy-host.sh)"
    fail=$((fail+1))
  else
    log_ok "all templates present in $SHARE_DIR"
  fi

  # Executable helpers present (LIBEXEC_DIR resolution)
  local missing_helpers=()
  for t in "${TINDERBOX_REQUIRED_HELPERS[@]}"; do
    [[ -f "$LIBEXEC_DIR/$t" ]] || missing_helpers+=("$t")
  done
  if (( ${#missing_helpers[@]} > 0 )); then
    log_error "missing helpers under $LIBEXEC_DIR: ${missing_helpers[*]}"
    log_error "  re-run host install (contrib/deploy-host.sh)"
    fail=$((fail+1))
  else
    log_ok "all helpers present in $LIBEXEC_DIR"
  fi

  # PORTAGE_NG_LOCAL or PORTAGE_NG_URL must point somewhere
  if [[ -n "$PORTAGE_NG_URL" ]]; then
    log_ok "portage-ng source: git $PORTAGE_NG_URL @ $PORTAGE_NG_REF"
  elif [[ -n "$PORTAGE_NG_LOCAL" ]] && _pn_is_repo "$PORTAGE_NG_LOCAL"; then
    log_ok "portage-ng source: rsync from $PORTAGE_NG_LOCAL"
  else
    log_error "no portage-ng source found"
    log_error "  tried: \$PORTAGE_NG_LOCAL=${PORTAGE_NG_LOCAL:-(unset)}, plus auto-detect of"
    log_error "  /root/prolog, /opt/portage-ng, /opt/prolog and the script's parent tree."
    log_error "  Set PORTAGE_NG_LOCAL=/path/to/portage-ng (must contain portage-ng.pl"
    log_error "  at the root or Source/loader.pl) or PORTAGE_NG_URL=https://... PORTAGE_NG_REF=<ref>."
    fail=$((fail+1))
  fi

  # Disk space (only meaningful pre-bootstrap; warn if tight)
  if [[ -d "$(dirname "$TINDERBOX_ROOT")" ]]; then
    local free_mib
    free_mib="$(df -BM --output=avail "$(dirname "$TINDERBOX_ROOT")" 2>/dev/null | tail -n1 | tr -dc '0-9')"
    if [[ -n "$free_mib" ]]; then
      if (( free_mib < TINDERBOX_MIN_FREE_MIB )); then
        log_warn "$(dirname "$TINDERBOX_ROOT") has ${free_mib} MiB free; recommended >= ${TINDERBOX_MIN_FREE_MIB} MiB"
        warn=$((warn+1))
      else
        log_ok "$(dirname "$TINDERBOX_ROOT") has ${free_mib} MiB free"
      fi
    fi
  fi

  # tmpfs sizing - if RAM < requested tmpfs cap warn the operator. Skipped
  # silently on non-Linux (no /proc/meminfo); doctor is meant for Linux hosts
  # but we want the dev-box dry-run to stay clean.
  local sessions_tmpfs_resolved
  sessions_tmpfs_resolved="$(_resolve_sessions_tmpfs_size)"
  if [[ -n "$sessions_tmpfs_resolved" && "$sessions_tmpfs_resolved" != "0" ]] && [[ -r /proc/meminfo ]]; then
    local mem_gib cap_gib
    mem_gib="$(_host_mem_gib)"
    cap_gib="${sessions_tmpfs_resolved%[Gg]}"
    if [[ "$cap_gib" =~ ^[0-9]+$ ]] && (( cap_gib > 0 )); then
      if (( mem_gib > 0 && cap_gib > mem_gib )); then
        log_warn "sessions tmpfs cap ${sessions_tmpfs_resolved} > host RAM ${mem_gib}G (sparse, but may swap)"
        warn=$((warn+1))
      else
        if [[ "${TINDERBOX_SESSIONS_TMPFS_SIZE:-auto}" == auto ]]; then
          log_ok "sessions tmpfs auto=${sessions_tmpfs_resolved} (host RAM: ${mem_gib}G)"
        else
          log_ok "sessions tmpfs cap ${sessions_tmpfs_resolved} (host RAM: ${mem_gib}G)"
        fi
      fi
    fi
  elif [[ "$sessions_tmpfs_resolved" == "0" ]] && _tinderbox_root_on_tmpfs; then
    log_ok "sessions tmpfs disabled (auto: \$TINDERBOX_ROOT is tmpfs)"
  fi

  # mDNS resolution (optional but commonly needed for *.local)
  if [[ -n "${TINDERBOX_MDNS_HOSTS:-}" ]] && command -v getent >/dev/null 2>&1; then
    local h
    for h in $TINDERBOX_MDNS_HOSTS; do
      if getent hosts "$h" >/dev/null 2>&1; then
        log_ok "mDNS resolves: $h"
      else
        log_warn "mDNS does not resolve: $h (host may need nss-mdns; sessions still work for non-mDNS targets)"
        warn=$((warn+1))
      fi
    done
  fi

  # vm.vfs_cache_pressure: drives how aggressively the kernel reclaims
  # dentry/inode cache. Default on most distros is 100 (treat dcache equal
  # to pagecache); under heavy matrix concurrency that triggers an
  # OverlayFS bug where directory inodes flicker to fresh values mid-tar
  # extraction, and gtar bails with "Directory renamed before its status
  # could be extracted" (most often on large tarballs like
  # mesa-26.0.5.tar.xz, librsvg-2.60.0.tar.xz, glib-2.88.1.tar.xz).
  # 27 sessions in compare-matrix-20260515T222721 hit this; 26 of them on
  # the pn side, where the layer-batched executor maximises inode-cache
  # pressure on /var/tmp/portage. tinderbox-ng now bind-mounts a fresh
  # tmpfs over /var/tmp/portage in every session (see _ns_session_mount),
  # so this is a belt-and-braces signal — keep dentry/inode cache around
  # so the residual rate stays at zero.
  if [[ -r /proc/sys/vm/vfs_cache_pressure ]]; then
    local vcp
    vcp="$(cat /proc/sys/vm/vfs_cache_pressure 2>/dev/null)"
    if [[ "$vcp" =~ ^[0-9]+$ ]] && (( vcp > 50 )); then
      log_warn "vm.vfs_cache_pressure=$vcp (default 100); recommended <= 50 to reduce"
      log_warn "  OverlayFS inode-cache reclaim during tar -x of large tarballs"
      log_warn "  (mesa, librsvg, glib). Apply with:"
      log_warn "    sysctl -w vm.vfs_cache_pressure=50"
      log_warn "    echo 'vm.vfs_cache_pressure = 50' >> /etc/sysctl.d/50-tinderbox-ng.conf"
      warn=$((warn+1))
    else
      log_ok "vm.vfs_cache_pressure=$vcp (<= 50; OverlayFS-friendly)"
    fi
  fi

  # Baseline freeze-damage check (only meaningful when a baseline exists).
  #
  # Older tinderbox-ng versions called `bootstrap_freeze` at the end of
  # bootstrap (and again after every refresh-kb / refresh-portage-ng /
  # install-ccache). It stripped owner-write across the baseline -
  # initially on files+dirs, later on dirs only. Both variants have been
  # removed: the file variant broke autotools/libtoolize chains for ~100s
  # of packages (freetype, colm, libcap-ng, libev, alsa-lib, mtx-style),
  # and the dir variant was a no-op because root inside the chroot
  # bypasses dir mode checks via CAP_DAC_OVERRIDE. Overlay's lower-layer
  # contract is the actual session-isolation mechanism.
  #
  # Existing baselines bootstrapped under the old freeze policy still
  # carry the damage; we count it cheaply and steer the operator to
  # `tinderbox-ng baseline-thaw` (chmod u+w on files+dirs, no rebootstrap).
  if [[ -d "$BASELINE_DIR" ]]; then
    local thawed_files thawed_dirs
    thawed_files="$(find "$BASELINE_DIR" -xdev -type f ! -perm -u=w 2>/dev/null | wc -l)"
    thawed_dirs="$(find  "$BASELINE_DIR" -xdev -type d ! -perm -u=w 2>/dev/null | wc -l)"
    if (( thawed_files > 0 || thawed_dirs > 0 )); then
      log_warn "baseline has legacy freeze damage:"
      log_warn "  $thawed_files file(s) and $thawed_dirs dir(s) lack owner-write"
      log_warn "  This is the residue of an older bootstrap_freeze; it has been"
      log_warn "  removed from tinderbox-ng. Some packages (autotools/libtool"
      log_warn "  consumers, eautoreconf chains) will fail at install with bare"
      log_warn "  cp / install permission errors against baseline files."
      log_warn "  Repair in ~1s with:"
      log_warn "    tinderbox-ng baseline-thaw"
      warn=$((warn+1))
    else
      log_ok "baseline perms healthy (no legacy freeze damage; $thawed_files files / $thawed_dirs dirs lack u=w)"
    fi
  fi

  # baseline.make.conf must pin LDFLAGS explicitly. Without it the profile
  # default injects -Wl,-z,pack-relative-relocs, which breaks autoconf's
  # conftest on a large slice of ebuilds (false "C compiler cannot create
  # executables" failures in compare rows).
  if [[ -f "$BASELINE_DIR/etc/portage/make.conf" ]]; then
    local _mc="$BASELINE_DIR/etc/portage/make.conf"
    local _ldflags_line
    _ldflags_line="$(grep -E '^LDFLAGS=' "$_mc" 2>/dev/null | head -n1 || true)"
    if [[ -z "$_ldflags_line" ]]; then
      log_warn "baseline make.conf has no LDFLAGS= pin; profile may add -Wl,-z,pack-relative-relocs"
      log_warn "  causing spurious autoconf failures in compare/matrix runs. Fix with:"
      log_warn "    tinderbox-ng refresh-baseline-config"
      warn=$((warn+1))
    elif [[ "$_ldflags_line" == *pack-relative-relocs* ]]; then
      log_warn "baseline make.conf LDFLAGS includes pack-relative-relocs (discouraged on this rig)"
      log_warn "  redeploy templates with: tinderbox-ng refresh-baseline-config"
      warn=$((warn+1))
    else
      log_ok "baseline LDFLAGS pinned (no pack-relative-relocs)"
    fi
  fi

  if (( fail > 0 )); then
    die "preflight: $fail error(s), $warn warning(s); fix errors before bootstrap"
  fi
  log_ok "preflight: 0 errors, $warn warning(s)"
  return 0
}


# =============================================================================
# Subcommand: selftest
# =============================================================================
#
# Post-bootstrap smoke test. Runs `compare --pretend` on a tiny well-known
# package in a throwaway session to confirm the baseline is wired correctly:
# both engines plan it, the overlay mounts, and the chroot can resolve hosts.
#
# This catches "bootstrap finished cleanly but kb.qlf is broken" or "the
# baseline missed a config flag" regressions in seconds, before they bite a
# multi-hour matrix run.

cmd_selftest() {
  require_root
  require_dirs

  local target="${TINDERBOX_SELFTEST_TARGET:-sys-apps/portage}"
  local label="selftest-$$"

  log_info "selftest: compare --pretend $target (label=$label)"

  # cmd_compare itself runs sessions through unshare and tears them down.
  if cmd_compare --pretend --label "$label" "$target"; then
    log_ok "selftest passed: both engines planned $target cleanly"
    return 0
  else
    local rc=$?
    log_error "selftest failed (compare exit $rc); inspect $LOG_DIR/compare-${label}-*"
    return "$rc"
  fi
}


# =============================================================================
# Subcommand: bootstrap
# =============================================================================

cmd_bootstrap() {
  require_root
  require_kernel_overlay
  require_unshare

  # Centralised preflight: catches missing tools / kernel features before
  # we download stage3. Skip with TINDERBOX_SKIP_DOCTOR=1 only for re-bootstraps
  # on machines you've already qualified.
  if [[ -z "${TINDERBOX_SKIP_DOCTOR:-}" ]]; then
    cmd_doctor
  fi

  log_info "bootstrap: building baseline at $BASELINE_DIR"
  log_info "this takes a long time (stage3 download + emerge swi-prolog + portage-ng sync)"

  if [[ -d "$BASELINE_DIR/usr" ]] && [[ -z "${TINDERBOX_REBOOTSTRAP:-}" ]]; then
    die "baseline already populated at $BASELINE_DIR; set TINDERBOX_REBOOTSTRAP=1 to overwrite"
  fi

  mkdir -p "$BASELINE_DIR" "$SHARED_DIR" "$SESSIONS_DIR" "$SCRIPTS_DIR" "$LOG_DIR" \
           "$STAGE3_CACHE" "$DISTFILES_DIR" "$CCACHE_DIR" "$BINPKGS_DIR"

  bootstrap_fetch_stage3
  bootstrap_unpack_stage3
  bootstrap_pin_tree
  bootstrap_post_stage3
  bootstrap_install_swipl
  bootstrap_install_ccache
  bootstrap_install_kernel_sources
  bootstrap_install_portage_ng
  bootstrap_install_kb_qlf

  log_ok "bootstrap complete; baseline ready at $BASELINE_DIR"
  if [[ -n "${TINDERBOX_BOOTSTRAP_SELFTEST:-}" ]]; then
    log_info "running post-bootstrap selftest (TINDERBOX_BOOTSTRAP_SELFTEST set)"
    cmd_selftest || log_warn "selftest reported issues; inspect logs above"
  else
    log_info "next: tinderbox-ng selftest    # smoke-test compare on sys-apps/portage"
    log_info "      tinderbox-ng new <name> && tinderbox-ng enter <name>"
  fi
}

# Import Gentoo release signing keys (master + rotating weekly keys in
# gentoo-release.asc). AWS often cannot reach hkps://keys.gentoo.org.
_bootstrap_import_releng_key() {
  local homedir="${1:-$STAGE3_CACHE/.gnupg}"

  mkdir -p "$homedir" && chmod 700 "$homedir"

  if gpg --homedir "$homedir" --list-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1; then
    return 0
  fi

  log_info "importing Gentoo Release Engineering key ($GENTOO_RELENG_KEY)"

  if [[ -f "$SHARE_DIR/gentoo-release.asc" ]]; then
    if gpg --homedir "$homedir" --import "$SHARE_DIR/gentoo-release.asc" >/dev/null 2>&1 \
        && gpg --homedir "$homedir" --list-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1; then
      log_info "  from bundled $SHARE_DIR/gentoo-release.asc"
      return 0
    fi
    log_warn "  bundled gentoo-release.asc did not provide $GENTOO_RELENG_KEY"
  fi

  local url="${TINDERBOX_STAGE3_RELENG_ASC_URL:-https://dev.gentoo.org/~mgorny/dist/openpgp-keys/gentoo-release.asc.20250806.gz}"
  if curl -fsSL "$url" | gzip -dc 2>/dev/null \
      | gpg --homedir "$homedir" --import - >/dev/null 2>&1 \
      && gpg --homedir "$homedir" --list-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1; then
    log_info "  from $url"
    return 0
  fi

  if curl -fsSL 'https://qa-reports.gentoo.org/output/service-keys.gpg' \
      | gpg --homedir "$homedir" --import - >/dev/null 2>&1 \
      && gpg --homedir "$homedir" --list-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1; then
    log_info "  from qa-reports service-keys.gpg"
    return 0
  fi

  local ks
  for ks in hkps://keyserver.ubuntu.com hkps://keys.openpgp.org hkps://keys.gentoo.org; do
    if gpg --homedir "$homedir" --keyserver "$ks" --recv-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1 \
        && gpg --homedir "$homedir" --list-keys "$GENTOO_RELENG_KEY" >/dev/null 2>&1; then
      log_info "  from keyserver $ks"
      return 0
    fi
    log_warn "  keyserver $ks failed for $GENTOO_RELENG_KEY"
  done

  die "could not import Gentoo Release Engineering key $GENTOO_RELENG_KEY"
}

bootstrap_fetch_stage3() {
  local pointer_url="$STAGE3_BASE_URL/latest-stage3-${STAGE3_VARIANT}.txt"
  log_info "resolving latest stage3 ($STAGE3_VARIANT) from $pointer_url"

  local pointer
  pointer="$(curl -fsSL "$pointer_url")"
  local rel
  rel="$(printf '%s' "$pointer" | grep -E '^[0-9]+T[0-9]+Z/stage3-' | awk '{print $1}' | head -n1)"
  [[ -n "$rel" ]] || die "could not parse latest-stage3 pointer file"

  local tarball="${rel##*/}"
  local url_tar="$STAGE3_BASE_URL/$rel"
  local url_dig="$STAGE3_BASE_URL/$rel.DIGESTS"
  local url_asc="$STAGE3_BASE_URL/$rel.asc"

  ( cd "$STAGE3_CACHE"
    log_info "fetching $tarball"
    curl -fL --remote-name-all -C - "$url_tar" "$url_dig" "$url_asc" || \
      curl -fL --remote-name-all "$url_tar" "$url_dig" "$url_asc"

    log_info "verifying GPG signature on $tarball"
    _bootstrap_import_releng_key "$STAGE3_CACHE/.gnupg"
    # .tar.xz.asc is a detached signature over the tarball (not .DIGESTS).
    gpg --homedir "$STAGE3_CACHE/.gnupg" --verify "$tarball.asc" "$tarball"

    log_info "verifying GPG signature on $tarball.DIGESTS"
    # .DIGESTS is clearsigned inline; checksum lines are verified below.
    gpg --homedir "$STAGE3_CACHE/.gnupg" --verify "$tarball.DIGESTS"

    # Modern GnuPG auto-spawns long-lived per-homedir daemons (keyboxd,
    # gpg-agent) on first use and keeps them resident for ~10min idle.
    # Bootstrap is a one-shot; ask gpgconf to shut them down cleanly so
    # we don't leak a few MB of RSS holding fds on the keybox indefinitely.
    gpgconf --homedir "$STAGE3_CACHE/.gnupg" --kill all 2>/dev/null || true

    log_info "verifying SHA512 from .DIGESTS"
    local expected actual
    expected="$(awk -v f="$tarball" '
      /^# SHA512 HASH$/ { in_sha=1; next }
      /^# / && in_sha   { in_sha=0 }
      in_sha && $2==f   { print $1; exit }
    ' "$tarball.DIGESTS")"
    [[ -n "$expected" ]] || die "no SHA512 entry for $tarball in .DIGESTS"
    actual="$(sha512sum "$tarball" | awk '{print $1}')"
    [[ "$expected" == "$actual" ]] || die "SHA512 mismatch on $tarball"
  )

  printf '%s\n' "$rel" >"$STAGE3_CACHE/.current"
  log_ok "stage3 verified: $rel"
}

bootstrap_unpack_stage3() {
  local rel
  rel="$(<"$STAGE3_CACHE/.current")"
  local tarball="$STAGE3_CACHE/${rel##*/}"

  log_info "unpacking stage3 into $BASELINE_DIR"

  # Refuse to touch baseline if anything is mounted inside it (host-namespace).
  # With the mount-ns design no stale mounts should ever exist here, but if
  # they do, we ABORT rather than risk umount propagation. The user must
  # reboot or manually clean up before retrying.
  if command -v findmnt >/dev/null; then
    local stale
    stale="$(findmnt -R "$BASELINE_DIR" -no TARGET 2>/dev/null | head -5 || true)"
    if [[ -n "$stale" ]]; then
      log_error "stale mounts under $BASELINE_DIR (refusing to unpack):"
      printf '  %s\n' "$stale" >&2
      die "reboot the host or manually umount these and retry"
    fi
  fi

  if [[ -d "$BASELINE_DIR/usr" ]]; then
    log_warn "overwriting existing baseline (TINDERBOX_REBOOTSTRAP set)"

    # Drop +i bits in case a previous bootstrap got far enough to freeze
    if command -v chattr >/dev/null; then
      chattr -R -i "$BASELINE_DIR" 2>/dev/null || true
    fi
    chmod -R u+w "$BASELINE_DIR" 2>/dev/null || true

    rm -rf --one-file-system "${BASELINE_DIR:?}/"*
    rm -rf --one-file-system "${BASELINE_DIR:?}"/.[!.]* 2>/dev/null || true
  fi
  tar -xpf "$tarball" -C "$BASELINE_DIR" --xattrs-include='*.*' --numeric-owner
  log_ok "stage3 unpacked"
}

# Resolve $TREE_DIR's HEAD to the requested pin. Used by both bootstrap_pin_tree
# (initial clone / first pin) and cmd_refresh_tree (re-pin an existing checkout).
#
# Pin resolution rules:
#   1. If $1 is non-empty, use it. Otherwise default to whatever origin's HEAD
#      symref points at (e.g. `stable` for current gentoo-mirror, `master` for
#      legacy mirrors). This avoids hard-coding a branch name that upstream
#      may rename -- which is exactly what tripped up the previous code path
#      after gentoo-mirror flipped its default branch from `master` to `stable`
#      around 2026Q1: `git fetch origin master` succeeded against the new
#      "master is now an alias of stable" mirror but `git checkout master`
#      then failed because the local shallow clone never created a `master`
#      branch tracker -- only `origin/stable` existed.
#
#   2. Resolve the pin to a concrete commit by trying, in order:
#        a. refs/remotes/origin/<pin>   -- a remote branch
#        b. <pin>                       -- a local commit / tag / branch
#      and reset HARD to that commit. Hard-reset (vs. checkout) is the right
#      primitive for a read-only Portage snapshot: gentoo-mirror periodically
#      force-pushes when its CVS->git mirror rewrites history, which leaves
#      local branches diverged ([ahead 1, behind 1]) and refuses --ff-only
#      pulls. We don't preserve local commits in this checkout.
#
# Persists the resolved commit to $SHARED_DIR/portage-tree.commit.
_set_tree_pin() {
  local requested="${1:-}"
  local pin

  if [[ -n "$requested" ]]; then
    pin="$requested"
  else
    pin="$(git -C "$TREE_DIR" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
            | sed 's|^origin/||')"
    if [[ -z "$pin" ]]; then
      # Fallback if origin/HEAD is missing (e.g. ancient git or shallow clone
      # without remote.origin.HEAD). Try `stable` then `master` -- in that
      # order because stable is the post-2026 gentoo-mirror default.
      for cand in stable master; do
        if git -C "$TREE_DIR" rev-parse --verify "refs/remotes/origin/$cand" >/dev/null 2>&1; then
          pin="$cand"; break
        fi
      done
    fi
    [[ -n "$pin" ]] || die "could not resolve a default branch for $TREE_DIR"
    log_info "no pin given; using origin's default branch: $pin"
  fi

  # Update remote-tracking refs first. The first attempt is the cheapest
  # (depth-1 update of just the requested ref); we fall back to a full
  # fetch and finally to --unshallow for repos that need deeper history
  # to resolve $pin.
  git -C "$TREE_DIR" fetch --no-show-forced-updates origin "$pin" 2>/dev/null \
    || git -C "$TREE_DIR" fetch --no-show-forced-updates origin 2>/dev/null \
    || git -C "$TREE_DIR" fetch --unshallow origin

  local target=""
  if git -C "$TREE_DIR" rev-parse --verify "refs/remotes/origin/$pin" >/dev/null 2>&1; then
    target="refs/remotes/origin/$pin"
  elif git -C "$TREE_DIR" rev-parse --verify "$pin" >/dev/null 2>&1; then
    target="$pin"
  else
    die "cannot resolve pin '$pin' as either origin/<branch> or commit/tag in $TREE_DIR"
  fi

  log_info "resetting $TREE_DIR to $target"
  git -C "$TREE_DIR" reset --hard "$target" >/dev/null

  local pin_commit
  pin_commit="$(git -C "$TREE_DIR" rev-parse HEAD)"
  printf '%s\n' "$pin_commit" >"$SHARED_DIR/portage-tree.commit"
  log_ok "tree pinned at $pin_commit"
}

bootstrap_pin_tree() {
  if [[ -d "$TREE_DIR/.git" ]]; then
    log_info "tree already cloned at $TREE_DIR; fetching"
  else
    log_info "cloning Portage tree from $PORTAGE_TREE_URL"
    # Always shallow-clone the default branch initially; _set_tree_pin will
    # unshallow on demand if PORTAGE_TREE_PIN points at older history.
    git clone --depth=1 "$PORTAGE_TREE_URL" "$TREE_DIR"
  fi

  _set_tree_pin "$PORTAGE_TREE_PIN"
}

_bootstrap_apply_portage_templates() {
  install -d "$BASELINE_DIR/etc/portage/repos.conf"
  install -d "$BASELINE_DIR/etc/portage/package.use"
  cp_template baseline.repos.conf "$BASELINE_DIR/etc/portage/repos.conf/gentoo.conf"
  cp_template baseline.make.conf  "$BASELINE_DIR/etc/portage/make.conf"
  cp_template baseline.package.use "$BASELINE_DIR/etc/portage/package.use/00-tinderbox-ng-defaults"
  _baseline_sync_ccache_feature
}

# Toggle FEATURES=ccache in the baseline make.conf to match whether
# dev-util/ccache is actually installed. Portage warns on every compile
# when ccache is requested but /usr/lib*/ccache/bin is missing; keeping
# the bit out of the shipped template avoids that during bootstrap steps
# that run before bootstrap_install_ccache.
_baseline_ccache_installed() {
  local d
  for d in "$BASELINE_DIR"/usr/lib/ccache/bin \
           "$BASELINE_DIR"/usr/lib64/ccache/bin \
           "$BASELINE_DIR"/usr/lib*/ccache/bin; do
    [[ -d "$d" ]] && return 0
  done
  return 1
}

_baseline_sync_ccache_feature() {
  local makeconf="$BASELINE_DIR/etc/portage/make.conf"
  [[ -f "$makeconf" ]] || return 0

  if _baseline_ccache_installed; then
    grep -qE '^FEATURES=.*\bccache\b' "$makeconf" && return 0
    sed -i 's/\(^FEATURES="[^"]*buildpkg\)/\1 ccache/' "$makeconf"
  else
    grep -qE '^FEATURES=.*\bccache\b' "$makeconf" || return 0
    sed -i '/^FEATURES=/s/ ccache//g' "$makeconf"
  fi
}

bootstrap_post_stage3() {
  log_info "post-stage3 setup (profile, locale, env, mtab, /etc/portage)"

  _bootstrap_apply_portage_templates

  install -d "$BASELINE_DIR/var/cache/distfiles" \
             "$BASELINE_DIR/var/cache/binpkgs" \
             "$BASELINE_DIR/var/cache/ccache" \
             "$BASELINE_DIR$CHROOT_TREE_PATH" \
             "$BASELINE_DIR$CHROOT_PORTAGE_NG" \
             "$BASELINE_DIR/root/Graph"

  ln -sf /proc/self/mounts "$BASELINE_DIR/etc/mtab"

  printf '%s\n' "$GENTOO_LOCALE" >>"$BASELINE_DIR/etc/locale.gen"

  in_baseline_chroot bash -e <<EOF
eselect profile set "$GENTOO_PROFILE"
locale-gen
eselect locale set "$GENTOO_LOCALE_NAME"
env-update
. /etc/profile
gcc-config -l
binutils-config -l
emerge --info | head -n 5
EOF

  bootstrap_claim_app_alternatives

  log_ok "post-stage3 setup done"
}

# Stage3 tarballs ship common tool paths (/usr/bin/bc, /bin/cpio, …) without
# an owning package. Gentoo's app-alternatives/* ebuilds claim those orphans
# during @system migration; until they do, every transitive pull prints a
# multi-paragraph file-collision elog even though protect-owned allows the
# merge. Install the full alternatives set once, right after profile setup,
# with collision protection disabled for this step only.
bootstrap_claim_app_alternatives() {
  log_info "claim stage3 orphan tool paths (app-alternatives)"
  in_baseline_chroot bash -e <<'EOF'
. /etc/profile
alts=(
  app-alternatives/awk
  app-alternatives/bc
  app-alternatives/bzip2
  app-alternatives/cpio
  app-alternatives/gpg
  app-alternatives/gzip
  app-alternatives/lex
  app-alternatives/lzip
  app-alternatives/ninja
  app-alternatives/sh
  app-alternatives/tar
  app-alternatives/yacc
)
FEATURES="-protect-owned -collision-protect ${FEATURES}" \
  emerge --quiet-build=y --jobs="$(nproc)" --load-average="$(nproc)" \
         --keep-going=y --oneshot "${alts[@]}"
EOF
  log_ok "app-alternatives installed"
}

bootstrap_install_swipl() {
  log_info "emerge dev-lang/swi-prolog (long; cached in baseline)"
  in_baseline_chroot bash -e <<'EOF'
. /etc/profile
emerge --quiet-build=y --jobs="$(nproc)" --load-average="$(nproc)" \
       --keep-going=y dev-lang/swi-prolog dev-vcs/git net-misc/curl
EOF
  log_ok "swi-prolog installed in baseline"
}

# Install dev-util/ccache into the baseline and configure a host-shared
# cache. CCACHE_DIR in baseline.make.conf points at /var/cache/ccache
# (_ns_session_mount bind-mounts from $CCACHE_DIR on the host). After
# emerge, _baseline_sync_ccache_feature adds FEATURES=ccache so Portage
# only requests the masquerade shims once they exist.
#
# /etc/ccache.conf:
#   - max_size: caps the on-disk cache at $TINDERBOX_CCACHE_MAX_SIZE.
#   - compression / level 6: standard since ccache 4.0; explicit so the
#     setting is auditable from outside the chroot.
#   - inode_cache off: shared cache across sessions whose chroots are
#     all mounted at /var/cache/ccache via different overlay merged-dirs
#     would otherwise see inconsistent st_dev values and constantly
#     invalidate each other.
#
# Permissions: portage's userfetch/usersandbox runs the build phases as
# uid 250 (portage). The cache directory must be writable by that user
# from inside every session. chown portage:portage + 2775 (setgid) keeps
# new ccache entries owned by portage even if root drops a file in.
bootstrap_install_ccache() {
  log_info "emerge dev-util/ccache (shared host cache: $CCACHE_DIR, max=$TINDERBOX_CCACHE_MAX_SIZE)"
  install -d "$CCACHE_DIR"
  # Bind-mount target ownership: the in-chroot chown below sets the in-baseline
  # path, but the *bind source* lives on the host filesystem and overlays the
  # chroot path at session-mount time. Without this host-side chown, ccache
  # writes from inside sessions (running as portage uid 250 under userfetch /
  # usersandbox) hit EPERM on a root-owned host directory and silently produce
  # zero cache hits across the entire matrix. uid 250 is the canonical portage
  # uid in stage3; chown numerically so this works on hosts that don't have a
  # portage user defined.
  chown 250:250 "$CCACHE_DIR"
  chmod 2775    "$CCACHE_DIR"
  # ccache resolves config from $CCACHE_DIR/ccache.conf BEFORE /etc/ccache.conf
  # (per-cache config wins over system-wide). A stale per-cache file from an
  # earlier hand-rolled setup will silently cap max_size below what we just
  # wrote into /etc/ccache.conf. Remove it so /etc/ccache.conf is authoritative.
  rm -f "$CCACHE_DIR/ccache.conf"
  in_baseline_chroot bash -e <<EOF
. /etc/profile
emerge --quiet-build=y --jobs="\$(nproc)" --load-average="\$(nproc)" \
       --keep-going=y --oneshot dev-util/ccache
install -d -m 2775 -o portage -g portage /var/cache/ccache
cat >/etc/ccache.conf <<'CFG'
# Generated by tinderbox-ng bootstrap_install_ccache.
# Tune via TINDERBOX_CCACHE_MAX_SIZE on the next bootstrap, or edit in
# place and bump again with: tinderbox-ng install-ccache.
max_size           = $TINDERBOX_CCACHE_MAX_SIZE
compression        = true
compression_level  = 6
inode_cache        = false
CFG
ccache --version | head -n1
ccache --show-config 2>/dev/null | grep -E '^(max_size|cache_dir|compression)' || true
EOF
  _baseline_sync_ccache_feature
  log_ok "ccache installed; max_size=$TINDERBOX_CCACHE_MAX_SIZE; shared dir: $CCACHE_DIR"
}

# Install kernel sources into the baseline so ebuilds whose configure /
# build phases probe `/usr/src/linux` (kernel headers, vmlinux symbols,
# Module.symvers, etc.) succeed inside compare sessions. Without this,
# packages like `app-emulation/virtualbox-modules`, `sys-power/cpupower`,
# `sys-fs/zfs-kmod`, and a long tail of out-of-tree modules + tools that
# scrape the kernel tree fail at src_configure with "no /usr/src/linux"
# or "include/linux not found".
#
# The matrix never boots the chroot, but linux-mod-r1 ebuilds still
# require a *built* tree marker: `/usr/src/linux/Module.symvers`.
# defconfig + modules_prepare alone satisfy header lookups
# (autoconf.h) yet still fail `_modules_sanity_kernelbuilt()` with
# "built kernel sources are required to build kernel modules".
# `make modules` after defconfig is the minimum baseline cost that
# produces Module.symvers without installing a bootable kernel image.
#
# Kernel sources are baseline-shared via the overlay lower layer: every
# session sees the same /usr/src/linux* without paying for a copy-up
# until something writes there (which the matrix workload does not).
# Distfiles + tarball land in $DISTFILES_DIR (bind-mounted), so the
# ~150 MB tarball is fetched once across the host, not per-bootstrap.
#
# Idempotent: re-emerging an installed gentoo-sources is a no-op for
# Portage; eselect-set on an already-correct symlink is a no-op too.
# Kernel prep skips work when Module.symvers is present and newer than
# .config; re-runs after a kernel-source bump rebuild modules only.
#
# Override the package via TINDERBOX_KERNEL_PACKAGE if you need a
# specific kernel flavour (e.g. `sys-kernel/vanilla-sources`,
# `sys-kernel/gentoo-kernel`); the eselect step is unconditional.
# Linux-mod regression targets live in share/tinderbox-ng/manifest-kernel-modules.txt
# (split from manifest-failures.txt so stale baselines do not spam fail/fail).
bootstrap_install_kernel_sources() {
  local kernel_pkg="${TINDERBOX_KERNEL_PACKAGE:-sys-kernel/gentoo-sources}"
  log_info "emerge $kernel_pkg into baseline (provides /usr/src/linux for ebuilds that probe kernel headers)"
  in_baseline_chroot bash -e <<EOF
. /etc/profile
emerge --quiet-build=y --jobs="\$(nproc)" --load-average="\$(nproc)" \
       --keep-going=y --oneshot $kernel_pkg
# eselect kernel ships in stage3 (sys-apps/eselect provides the 'kernel'
# module). Idempotent: re-running points the symlink at the highest
# installed version, which is what we want after a kernel-source bump.
if eselect kernel list 2>/dev/null | grep -qE '^[[:space:]]*\['; then
  eselect kernel set 1
  ls -ld /usr/src/linux 2>/dev/null || true
else
  echo "warn: eselect kernel found no installed kernel sources" >&2
fi
# Prep the tree for linux-mod-r1 (vhba, lkrg, ryzen_smu, nvidia-drivers,
# virtualbox-guest-modules, zfs-kmod, ...). pkg_setup() reads .config,
# autoconf.h, and Module.symvers.
if [[ -e /usr/src/linux ]]; then
  kdir="\$(readlink -f /usr/src/linux)"
  if [[ -d "\$kdir" ]]; then
    echo "preparing kernel sources for linux-mod ebuilds under \$kdir"
    pushd "\$kdir" >/dev/null
    if [[ ! -f .config ]]; then
      echo "  make defconfig"
      make -s defconfig
    fi
    if [[ ! -f include/generated/autoconf.h ]]; then
      echo "  make modules_prepare"
      make -s -j"\$(nproc)" modules_prepare
    fi
    if [[ ! -f Module.symvers ]] || [[ .config -nt Module.symvers ]]; then
      echo "  make modules (Module.symvers for linux-mod-r1; one-time baseline cost)"
      make -s -j"\$(nproc)" modules
    fi
    popd >/dev/null
  fi
fi
EOF
  log_ok "kernel sources installed; /usr/src/linux ready (Module.symvers for linux-mod ebuilds)"
}

# portage-ng's config.pl consults Source/Config/Private/{passwords,api_key}.pl.
# Those files are gitignored (only template_*.pl ships in the repo). Fresh
# git clones / rsyncs therefore fail kb load until the stubs exist. Copy from
# the shipped templates with empty credentials — fine for tinderbox-ng compare
# runs that do not use digest auth or LLM keys.
_ensure_portage_ng_private_config() {
  local png_root="$1"
  local priv="$png_root/Source/Config/Private"
  local pair dst tpl

  [[ -d "$png_root" ]] || return 0
  install -d "$priv"

  for pair in api_key passwords; do
    dst="$priv/${pair}.pl"
    tpl="$priv/template_${pair}.pl"
    [[ -f "$dst" ]] && continue
    if [[ -f "$tpl" ]]; then
      cp "$tpl" "$dst"
      log_info "  stub $dst (from template)"
    else
      : >"$dst"
      log_warn "  stub $dst (empty; template_${pair}.pl missing)"
    fi
  done
}

bootstrap_install_portage_ng() {
  log_info "installing portage-ng into baseline at $CHROOT_PORTAGE_NG"

  [[ -z "$PORTAGE_NG_URL" && -n "$PORTAGE_NG_LOCAL" ]] \
    && _ensure_portage_ng_private_config "$PORTAGE_NG_LOCAL"

  if [[ -n "$PORTAGE_NG_URL" ]]; then
    in_baseline_chroot bash -e <<EOF
. /etc/profile
git clone "$PORTAGE_NG_URL" "$CHROOT_PORTAGE_NG"
git -C "$CHROOT_PORTAGE_NG" checkout "$PORTAGE_NG_REF"
EOF
  else
    [[ -d "$PORTAGE_NG_LOCAL" ]] || die "PORTAGE_NG_LOCAL=$PORTAGE_NG_LOCAL is not a directory"
    log_info "rsync from $PORTAGE_NG_LOCAL"
    rsync -a --delete \
          --exclude='.git/objects/pack/*.idx.lock' \
          --exclude='Source/Snapshots/' \
          "$PORTAGE_NG_LOCAL/" "$BASELINE_DIR$CHROOT_PORTAGE_NG/"
  fi

  _ensure_portage_ng_private_config "$BASELINE_DIR$CHROOT_PORTAGE_NG"

  install -m 0755 "$SHARE_DIR/portage-ng-dev.in" "$BASELINE_DIR/usr/local/bin/portage-ng-dev"
  sed -i "s|@PORTAGE_NG_ROOT@|$CHROOT_PORTAGE_NG|g" \
      "$BASELINE_DIR/usr/local/bin/portage-ng-dev"

  install -d "$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Knowledge/Sets/world"
  : >"$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Knowledge/Sets/world/vm-linux.local"

  install -m 0755 "$LIBEXEC_DIR/run-matrix.sh" "$BASELINE_DIR/usr/local/bin/tinderbox-matrix"

  _patch_portage_ng_host_config

  log_ok "portage-ng installed at $CHROOT_PORTAGE_NG"
}

# Tinderbox-ng-owned override of portage-ng's host-specific config to
# flip policies that matter for matrix-style concurrent buildpkg
# producers but not for solo portage-ng use.
#
# Currently sets:
#   config:binpkg_refresh(mtime)
#
# Background: portage-ng's repo-level Source/config.pl ships
# `config:binpkg_refresh(manual).` (cheapest, fully predictable). With
# FEATURES=buildpkg in baseline.make.conf and the shared binpkgs dir
# bind-mounted into every session, sibling compare-matrix workers
# regenerate the on-disk `Packages` index continuously. Long-running
# `--build` workers under `manual` keep the in-memory index they loaded
# at process start and never see binpkgs their siblings produced after
# launch -- forcing redundant source builds in the matrix tail.
# `mtime` is documented in portage-ng's config.pl pldoc as the policy
# that re-syncs the in-memory index from `Packages` when its mtime
# advances, which is the "live tinderbox/matrix" case.
#
# We patch the deployed host-specific config (Source/Config/<host>.pl)
# instead of the repo-level config.pl, so:
#   - upstream portage-ng users keep the conservative `manual` default
#   - tinderbox-ng owns the policy bump on the boxes it deploys
#   - re-running refresh-portage-ng (which rsyncs all of Source/) just
#     overwrites the file with the upstream copy and we re-apply here
#
# Predicate semantics: `config:binpkg_refresh/1` is loaded as a single
# fact in upstream config.pl (no `:- multifile` / `:- dynamic`), and the
# host config in Source/Config/<host>.pl is consulted AFTER config.pl
# during init_knowledgebase (portage-ng.pl:115). So just appending a
# second fact would leave the older `manual` clause in place and lose
# under any consumer that uses `once/1` or matches the head literally.
# We therefore declare the predicate dynamic, retract any existing
# clauses, then assert `mtime` -- which works under all three plausible
# upstream consumer regimes (first-asserted, last-asserted, only-one).
#
# Wired upstream as of portage-ng commit 76730972 ("binpkg: honor
# config:binpkg_refresh/1 in available_for/4"). Each dispatch probe in
# `binpkg_exec:available_for/4` now reads `config:binpkg_refresh/1`:
# under `mtime` it stats $PKGDIR/Packages and re-runs `binpkg:sync(kb)`
# whenever an external producer (sibling matrix worker) has bumped the
# index, so a long-running `--build` worker picks up newly-minted
# binpkgs between probes instead of being frozen on the snapshot it
# loaded at process start. Concurrent probes serialize on a dedicated
# `binpkg_exec_refresh` mutex upstream-side, so we don't have to
# coordinate here. Verified end-to-end on 2026-05-15 with a
# `compare --build app-containers/dive` smoke: planner emits 7 source
# actions but the executor short-circuits each install through qmerge,
# completing in ~2 minutes vs the multi-hour source-build path.
#
# Idempotent: if the host config already declares config:binpkg_refresh/1
# (any policy, e.g. an operator deliberately wants `manual`), leave it
# alone -- so an operator-side override always wins. The chroot inherits
# the host's UTS namespace, so we look up <host>.pl by `hostname`, with a
# `vm-linux.local.pl` fallback to match the rest of the bootstrap which
# hardcodes that label (e.g. the empty world file).
_patch_portage_ng_host_config() {
  local host_short host_cfg="" cand
  host_short="$(hostname)"
  for cand in "$host_short" "vm-linux.local"; do
    if [[ -f "$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Config/${cand}.pl" ]]; then
      host_cfg="$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Config/${cand}.pl"
      break
    fi
  done
  if [[ -z "$host_cfg" ]]; then
    log_warn "no Source/Config/<host>.pl found in baseline; skipping deploy patches"
    return 0
  fi

  # Patch 1: rewrite binpkg repo paths to the in-chroot canonical path.
  #
  # Upstream vm-linux.local.pl ships `binpkg:init('/srv/tinderbox-ng/shared/
  # binpkgs', ...)` -- a HOST path. portage-ng running inside the baseline
  # chroot (refresh-kb) or inside a session (compare runs) sees no such
  # path: tinderbox-ng binds the shared binpkgs dir to `/var/cache/binpkgs`
  # in both contexts (matching Portage's PKGDIR + the FHS expectation).
  # With the upstream paths, refresh-kb logs
  #   No Packages index at /srv/tinderbox-ng/shared/binpkgs/Packages
  # and the resulting kb.qlf has zero binpkg variants. Sessions hit the
  # same blind spot: the planner cannot use the binpkg cache to short-
  # circuit source builds because portage-ng's binpkg repository is empty.
  #
  # The deploy fix is to swap the host-form paths for the in-chroot form
  # in the host config. We patch the deployed copy (post-rsync) rather
  # than upstream so portage-ng-core stays generic; the contract that
  # tinderbox-ng owns the in-chroot mount layout is already documented.
  #
  # Idempotent: if the file already uses the in-chroot path (i.e. an
  # operator manually fixed it, or a future portage-ng release adopts
  # the change), the sed substitution is a no-op.
  if grep -q "'/srv/tinderbox-ng/shared/binpkgs" "$host_cfg"; then
    sed -i \
      -e "s|'/srv/tinderbox-ng/shared/binpkgs/Packages'|'/var/cache/binpkgs/Packages'|g" \
      -e "s|'/srv/tinderbox-ng/shared/binpkgs'|'/var/cache/binpkgs'|g" \
      "$host_cfg"
    log_info "  $host_cfg: rewrote binpkg paths to in-chroot /var/cache/binpkgs"
  fi

  # Patch 2: append config:binpkg_refresh(mtime) override (idempotent).
  if grep -qE '^[[:space:]]*config:binpkg_refresh\b' "$host_cfg"; then
    log_info "  $host_cfg: config:binpkg_refresh already set; leaving alone"
    return 0
  fi
  cat >>"$host_cfg" <<'EOF'

% --- tinderbox-ng deploy override ---------------------------------------------
% Override portage-ng's default config:binpkg_refresh(manual) for the
% tinderbox/matrix scenario: sibling compare sessions regenerate the
% shared Packages index mid-run via FEATURES=buildpkg. `mtime` re-syncs
% the in-memory index when the on-disk file changes, so long-running
% workers pick up binpkgs produced by their siblings instead of
% redundantly source-building them.
%
% This file is consulted AFTER Source/config.pl, so we must explicitly
% retract the upstream `manual` fact before asserting `mtime` -- otherwise
% any once/1 consumer would still see the older clause. Declaring the
% predicate dynamic first lets retractall succeed even though config.pl
% loaded it as a static fact.
%
% Re-applied by tinderbox-ng on every refresh-portage-ng; see
% bin/tinderbox-ng:_patch_portage_ng_host_config for rationale.
:- dynamic(config:binpkg_refresh/1).
:- retractall(config:binpkg_refresh(_)).
config:binpkg_refresh(mtime).
EOF
  log_info "  $host_cfg: appended config:binpkg_refresh(mtime) override"
}

bootstrap_install_kb_qlf() {
  log_info "generating kb.qlf via portage-ng-dev --sync"
  log_info "(temporarily mounting tree rw so prolog-side git pull can run)"

  in_baseline_chroot \
    --tree-rw \
    bash -e <<'EOF'
. /etc/profile
cd /opt/portage-ng
/usr/local/bin/portage-ng-dev --mode standalone --sync
EOF

  if [[ -f "$BASELINE_DIR$CHROOT_PORTAGE_NG/Knowledge/kb.qlf" ]]; then
    log_ok "kb.qlf generated ($(stat -c%s "$BASELINE_DIR$CHROOT_PORTAGE_NG/Knowledge/kb.qlf" 2>/dev/null) bytes)"
  else
    log_warn "kb.qlf not found after --sync; check the bootstrap log"
  fi

  bootstrap_pin_tree
}

# bootstrap_freeze used to chmod a-w the baseline (first all files+dirs,
# later dirs-only). Both variants were removed:
#
#   * The all-files variant silently stripped owner-write from every system
#     file. autotools.eclass then failed any package whose libtoolize chain
#     `cp /usr/share/gnuconfig/config.{guess,sub} .` with no -f over a
#     0555 destination just laid down by libtoolize --copy --force. We saw
#     this as a long tail of "both engines fail" in compare-matrix runs
#     (freetype, colm, libcap-ng, libev, alsa-lib, ...).
#
#   * The dirs-only variant was harmless but also useless: root inside
#     the chroot bypasses directory mode checks via CAP_DAC_OVERRIDE, so
#     `chmod a-w` on a baseline dir did not stop any actual write from
#     either the host (root) or the chroot (also root). Overlay's
#     copy-on-write + the host being a single-tenant tinderbox box mean
#     session-side writes never reach the lower layer regardless of mode.
#
# We rely on overlayfs lower-layer semantics for session isolation
# (sessions copy-up; lower is never touched by the kernel's overlay
# driver). The baseline is owned by root, and host-side admin mistakes
# are a separate operational concern handled by backups + git history of
# the bootstrap config, not by mode bits.

# =============================================================================
# Subcommand: refresh-tree
# =============================================================================

cmd_refresh_tree() {
  require_root
  # Default to origin/HEAD (currently `stable` on gentoo-mirror, was `master`
  # pre-2026) by passing an empty pin to _set_tree_pin. Operators can still
  # pass an explicit branch / tag / commit positional arg.
  local pin="${1:-}"

  [[ -d "$TREE_DIR/.git" ]] || die "$TREE_DIR is not a git checkout"

  _set_tree_pin "$pin"

  log_warn "tree changed; existing sessions still see the OLD bind until reset"
  log_warn "kb.qlf is now stale; run 'tinderbox-ng refresh-kb' to regenerate"
}

# =============================================================================
# Subcommand: refresh-kb
# =============================================================================

cmd_refresh_kb() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs

  log_info "regenerating kb.qlf inside baseline against pinned tree"

  in_baseline_chroot \
    --tree-rw \
    bash -e <<'EOF'
. /etc/profile
cd /opt/portage-ng
/usr/local/bin/portage-ng-dev --mode standalone --sync
EOF

  bootstrap_pin_tree
  log_ok "kb.qlf refreshed"
}

# =============================================================================
# Subcommand: refresh-portage-ng
# =============================================================================
#
# Re-deploy the portage-ng source tree into the baseline. Mirrors what
# bootstrap_install_portage_ng does: rsync from $PORTAGE_NG_LOCAL (or
# git clone $PORTAGE_NG_URL) into $BASELINE_DIR$CHROOT_PORTAGE_NG, then
# refresh the in-baseline /usr/local/bin/portage-ng-dev shim and the
# tinderbox-matrix helper.
#
# Use this whenever the host-side checkout has commits the baseline
# doesn't yet ship: every fresh session bind-mounts the baseline copy,
# so without this step new sessions keep running yesterday's resolver.
#
# kb.qlf is NOT regenerated here -- only Source/ is replaced. Run
# `tinderbox-ng refresh-kb` separately if you also want to re-parse
# the tree (only needed when the parser or grammar changed, not for
# pipeline / planner / scheduler edits).

cmd_refresh_portage_ng() {
  require_root
  require_dirs

  [[ -d "$BASELINE_DIR$CHROOT_PORTAGE_NG" ]] \
    || die "no portage-ng in baseline at $BASELINE_DIR$CHROOT_PORTAGE_NG; run bootstrap first"

  if [[ -n "$PORTAGE_NG_URL" ]]; then
    log_info "git pull from $PORTAGE_NG_URL inside baseline"
    in_baseline_chroot bash -e <<EOF
. /etc/profile
cd "$CHROOT_PORTAGE_NG"
git fetch origin
git checkout "$PORTAGE_NG_REF"
git reset --hard "origin/$PORTAGE_NG_REF" || git reset --hard "$PORTAGE_NG_REF"
EOF
  else
    [[ -d "$PORTAGE_NG_LOCAL" ]] || die "PORTAGE_NG_LOCAL=$PORTAGE_NG_LOCAL is not a directory"
    log_info "rsync from $PORTAGE_NG_LOCAL"
    # --delete on the source tree must NOT wipe in-baseline build artefacts
    # that the host checkout never has (Knowledge/kb.qlf etc. are gitignored;
    # vm-linux.local world file is created by bootstrap; Certificates/ and
    # Private/ are VM-specific). Without these excludes, refresh-portage-ng
    # silently destroys kb.qlf and the next session takes 10+ minutes to
    # re-parse the whole tree from md5-cache. The exclude paths mirror the
    # repository's .gitignore exactly: Knowledge/ and Source/Certificates/ +
    # Source/Private/ live at repository roots, NOT under Source/Knowledge/.
    [[ -n "$PORTAGE_NG_LOCAL" ]] && _ensure_portage_ng_private_config "$PORTAGE_NG_LOCAL"
    rsync -a --delete \
          --exclude='.git/objects/pack/*.idx.lock' \
          --exclude='Source/Snapshots/' \
          --exclude='Source/Certificates/' \
          --exclude='Source/Private/' \
          --exclude='Source/Config/Private/passwords.pl' \
          --exclude='Source/Config/Private/api_key.pl' \
          --exclude='Knowledge/kb.qlf' \
          --exclude='Knowledge/kb.raw' \
          --exclude='Knowledge/profile.qlf' \
          --exclude='Knowledge/profile.raw' \
          --exclude='Knowledge/embeddings.pl' \
          --exclude='Knowledge/phase_stats.pl' \
          --exclude='Knowledge/resume.pl' \
          --exclude='Source/Knowledge/Sets/**/*.local' \
          "$PORTAGE_NG_LOCAL/" "$BASELINE_DIR$CHROOT_PORTAGE_NG/"
    _ensure_portage_ng_private_config "$BASELINE_DIR$CHROOT_PORTAGE_NG"
  fi

  log_info "refreshing in-baseline portage-ng-dev shim and tinderbox-matrix helper"
  install -m 0755 "$SHARE_DIR/portage-ng-dev.in" "$BASELINE_DIR/usr/local/bin/portage-ng-dev"
  sed -i "s|@PORTAGE_NG_ROOT@|$CHROOT_PORTAGE_NG|g" \
      "$BASELINE_DIR/usr/local/bin/portage-ng-dev"
  install -m 0755 "$LIBEXEC_DIR/run-matrix.sh" "$BASELINE_DIR/usr/local/bin/tinderbox-matrix"

  # Re-touch the empty per-host world file so first --pretend doesn't crash
  # on missing-file. This mirrors the equivalent step in
  # bootstrap_install_portage_ng. The exclude pattern above keeps any
  # *.local file already populated by previous sessions.
  install -d "$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Knowledge/Sets/world"
  if [[ ! -f "$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Knowledge/Sets/world/vm-linux.local" ]]; then
    : >"$BASELINE_DIR$CHROOT_PORTAGE_NG/Source/Knowledge/Sets/world/vm-linux.local"
  fi

  # The rsync above re-overwrites Source/Config/<host>.pl with whatever
  # is in the upstream checkout, dropping any tinderbox-ng-owned policy
  # overrides (notably config:binpkg_refresh(mtime), required for the
  # matrix runner). Re-apply.
  _patch_portage_ng_host_config

  log_ok "portage-ng refreshed in baseline; new sessions will pick it up"
  log_warn "existing sessions still see the OLD portage-ng until reset"
  if [[ ! -f "$BASELINE_DIR$CHROOT_PORTAGE_NG/Knowledge/kb.qlf" ]]; then
    log_warn "kb.qlf MISSING from baseline; run 'tinderbox-ng refresh-kb' to (re)generate it"
  else
    log_info "kb.qlf preserved (was not in source rsync); run 'refresh-kb' if parser/grammar changed"
  fi
}


# =============================================================================
# Subcommand: install-ccache
# =============================================================================
#
# Retrofit ccache into an already-bootstrapped baseline, or bump max_size
# / re-write /etc/ccache.conf in place. Equivalent to running
# `bootstrap_install_ccache` standalone with the baseline temporarily
# unfrozen. Idempotent: re-emerging ccache is a no-op if already present
# and the .conf file is overwritten with current TINDERBOX_CCACHE_MAX_SIZE.
#
# Use this when:
#   - You bootstrapped on an older revision of tinderbox-ng and want
#     ccache without throwing the baseline away.
#   - You need to change max_size mid-stream (set TINDERBOX_CCACHE_MAX_SIZE
#     in the env, then re-run).

cmd_install_ccache() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs

  bootstrap_install_ccache

  log_ok "install-ccache complete; subsequent sessions will hit the shared cache"
}

# =============================================================================
# Subcommand: install-kernel-sources
# =============================================================================
#
# Retrofit kernel sources into an already-bootstrapped baseline.
# Equivalent to running `bootstrap_install_kernel_sources` standalone.
# Idempotent: safe to re-run after a kernel-source version bump in the
# tree -- emerge re-installs (or no-ops), eselect re-points the
# /usr/src/linux symlink at the highest installed version, and the
# defconfig/modules_prepare/modules prep re-runs when Module.symvers is
# stale or missing.
#
# Use this when:
#   - You bootstrapped on a tinderbox-ng revision before kernel sources
#     were part of the bootstrap pipeline (this is the migration case).
#   - You bootstrapped before `make modules` was added and linux-mod
#     compares fail with "built kernel sources are required".
#   - You want to flip TINDERBOX_KERNEL_PACKAGE (e.g. swap gentoo-sources
#     for vanilla-sources) without throwing the baseline away.
#   - The pinned tree picked up a kernel-source revbump and you want
#     the baseline to track it without a full re-bootstrap.

cmd_install_kernel_sources() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs

  bootstrap_install_kernel_sources

  log_ok "install-kernel-sources complete; subsequent sessions see /usr/src/linux"
}

# =============================================================================
# Subcommand: baseline-thaw
# =============================================================================
#
# One-shot migration shim for legacy baselines bootstrapped by older
# tinderbox-ng versions that called bootstrap_freeze (chmod a-w on files
# and/or dirs). Restores owner-write on every file and directory so the
# baseline matches what a current `tinderbox-ng bootstrap` would produce.
#
# Idempotent: a baseline that already has full owner-write is unaffected
# (chmod u+w is a no-op when the bit is already set). Cheap: ~1s for a
# 70k-file stage3.
#
# Use this when:
#   * `tinderbox-ng doctor` warns about >0 files lacking owner-write.
#   * You upgrade tinderbox-ng to a no-freeze version and want to keep
#     the existing baseline instead of rebootstrapping (~hours saved).
#
# After thaw, every package in the baseline carries the perms it was
# installed with (which is what stage3 + Portage produce by default).

cmd_baseline_thaw() {
  require_root
  require_dirs

  [[ -d "$BASELINE_DIR" ]] || die "no baseline at $BASELINE_DIR"

  local files_before dirs_before
  files_before="$(find "$BASELINE_DIR" -xdev -type f ! -perm -u=w 2>/dev/null | wc -l)"
  dirs_before="$(find "$BASELINE_DIR" -xdev -type d ! -perm -u=w 2>/dev/null | wc -l)"
  log_info "baseline-thaw: $files_before file(s), $dirs_before dir(s) lack owner-write"

  if (( files_before == 0 && dirs_before == 0 )); then
    log_ok "baseline already fully owner-writable; nothing to do"
    return 0
  fi

  if command -v chattr >/dev/null 2>&1; then
    chattr -R -i "$BASELINE_DIR" 2>/dev/null || true
  fi
  log_info "restoring owner-write on all files and directories"
  find "$BASELINE_DIR" -xdev \( -type f -o -type d \) \
       -exec chmod u+w {} + 2>/dev/null || true

  local files_after dirs_after
  files_after="$(find "$BASELINE_DIR" -xdev -type f ! -perm -u=w 2>/dev/null | wc -l)"
  dirs_after="$(find "$BASELINE_DIR" -xdev -type d ! -perm -u=w 2>/dev/null | wc -l)"
  if (( files_after > 0 || dirs_after > 0 )); then
    die "baseline-thaw: residual damage ($files_after files, $dirs_after dirs); investigate"
  fi
  log_ok "baseline thawed; setuid bits and xattrs untouched"
}

# =============================================================================
# Subcommand: refresh-baseline-config
# =============================================================================
#
# Re-apply the shipped /etc/portage templates (make.conf, repos.conf,
# package.use defaults) from share/tinderbox-ng/ into the existing baseline.
# Idempotent and cheap (~instant). Does not touch emerged packages, kb.qlf,
# or portage-ng — only the three template files bootstrap copies at
# bootstrap_post_stage3 time.
#
# Use when share/tinderbox-ng/baseline.make.conf gains a new pin (e.g.
# LDFLAGS without pack-relative-relocs) and you want existing baselines to
# pick it up without a full TINDERBOX_REBOOTSTRAP=1 rebuild.

cmd_refresh_baseline_config() {
  require_root
  require_dirs

  [[ -d "$BASELINE_DIR" ]] || die "no baseline at $BASELINE_DIR"

  local mc="$BASELINE_DIR/etc/portage/make.conf"
  if [[ -f "$mc" ]] && [[ ! -w "$mc" ]]; then
    die "$mc is not owner-writable; run: tinderbox-ng baseline-thaw"
  fi

  log_info "refresh-baseline-config: re-applying portage templates from $SHARE_DIR"
  _bootstrap_apply_portage_templates
  log_ok "baseline portage templates refreshed:"
  log_info "  $BASELINE_DIR/etc/portage/make.conf"
  log_info "  $BASELINE_DIR/etc/portage/repos.conf/gentoo.conf"
  log_info "  $BASELINE_DIR/etc/portage/package.use/00-tinderbox-ng-defaults"
  log_info "new compare sessions inherit the update via the baseline lower layer"
}

# =============================================================================
# Subcommand: new
# =============================================================================

cmd_new() {
  require_root
  require_dirs
  _ensure_sessions_tmpfs
  local name="${1:-}"
  [[ -n "$name" ]] || die "usage: tinderbox-ng new <name>"
  [[ ! -d "$(session_dir "$name")" ]] || die "session '$name' already exists"

  install -d "$(session_upper "$name")" "$(session_work "$name")" \
             "$(session_merged "$name")" "$(session_logs "$name")"
  # /var/tmp/portage scratch space, off-overlay (see session_portage_tmpdir
  # docstring). Mode 2775 + portage:portage (uid 250 in stage3) mirrors
  # the canonical /var/tmp/portage perms emerge expects when running
  # phases under FEATURES=userpriv. Numeric chown so this works on hosts
  # that don't have a `portage` user defined.
  install -d -m 2775 "$(session_portage_tmpdir "$name")"
  chown 250:250 "$(session_portage_tmpdir "$name")" 2>/dev/null || true
  printf '%s\n' "created=$(date -Iseconds)" >"$(session_dir "$name")/info"
  log_ok "session '$name' created"
}

# =============================================================================
# Subcommand: enter
# =============================================================================
#
# Re-execs into a private mount namespace via the internal __ns-helper, which
# performs the overlay+bind mounts and then chroots. When the inner shell
# exits, the namespace dies and every mount with it - no teardown path can
# ever leak into the host.

cmd_enter() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs
  require_session "${1:-}"
  local name="$1"

  acquire_lock "$name"
  log_info "entering session '$name' in private mount namespace"
  exec unshare --mount --ipc --propagation=private -- \
    "$0" __ns-helper session "$name" /bin/bash -l
}

# =============================================================================
# Subcommand: exec
# =============================================================================

cmd_exec() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs
  require_session "${1:-}"
  local name="$1"; shift
  if [[ "${1:-}" == "--" ]]; then shift; fi
  [[ $# -gt 0 ]] || die "usage: tinderbox-ng exec <name> -- <cmd...>"

  acquire_lock "$name"

  local logdir stamp logfile
  logdir="$(session_logs "$name")"
  install -d "$logdir"
  stamp="$(date +%Y%m%dT%H%M%S)"
  logfile="$logdir/exec-$stamp.log"

  log_info "exec in session '$name' (mount-ns): $* (log: $logfile)"
  printf 'exit=PENDING\nstamp=%s\ncmd=%q\n' "$stamp" "$*" \
    >"$logdir/exec-$stamp.meta"

  local rc=0
  if command -v ts >/dev/null 2>&1; then
    _unshare_ns "$0" __ns-helper session "$name" /bin/bash -l -c "$*" 2>&1 \
      | ts '%H:%M:%S' | tee "$logfile" \
      || rc=${PIPESTATUS[0]}
  else
    _unshare_ns "$0" __ns-helper session "$name" /bin/bash -l -c "$*" 2>&1 \
      | tee "$logfile" \
      || rc=${PIPESTATUS[0]}
  fi

  sed -i "s/^exit=PENDING/exit=$rc/" "$logdir/exec-$stamp.meta"
  sweep_session_orphans "$name"
  exit "$rc"
}

# =============================================================================
# Subcommands: portage-ng / emerge (build-engine convenience wrappers)
# =============================================================================
#
# Both run a Gentoo build inside an existing session. They differ only in
# which engine they invoke:
#
#   portage-ng  -> /opt/portage-ng/Source/Application/Wrapper/portage-ng-dev
#                  --mode standalone --ci --build <args>
#   emerge      -> /usr/bin/emerge --color=y --oneshot --verbose <args>
#
# Use --pretend to get the plan without executing. Both wrappers route
# through cmd_exec so logs land in $session/logs/exec-<stamp>.log and
# exit codes propagate. The point of having both is that
# `tinderbox-ng compare` can drive identical apples-to-apples runs.
#
# Default flags reflect the comparison use case:
#   - emerge: -1 (oneshot; do not modify @world), -v (verbose phase header)
#   - portage-ng: --mode standalone --ci --build (matches the rest of
#     the matrix harness)
#
# Pass extra emerge/portage-ng options after the session name and they
# get forwarded verbatim, so e.g.:
#
#   tinderbox-ng emerge sess --pretend www-servers/apache
#   tinderbox-ng portage-ng sess --pretend www-servers/apache
#
# both work and let you A/B the two planners without invoking compare.

cmd_portage_ng() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs
  require_session "${1:-}"
  local name="$1"; shift
  [[ $# -gt 0 ]] || die "usage: tinderbox-ng portage-ng <name> [--pretend|--build] <args...>"

  local mode_flag="--build"
  local positional=()
  for arg in "$@"; do
    case "$arg" in
      --pretend|-p) mode_flag="--pretend" ;;
      --build|-b)   mode_flag="--build"   ;;
      *)            positional+=("$arg")  ;;
    esac
  done
  [[ ${#positional[@]} -gt 0 ]] || die "no portage-ng arguments after flags"

  local cmd="cd /opt/portage-ng && timeout ${TINDERBOX_BUILD_TIMEOUT:-43200} ./Source/Application/Wrapper/portage-ng-dev --mode standalone --ci $mode_flag ${positional[*]}"
  cmd_exec "$name" -- "$cmd"
}

cmd_emerge() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs
  require_session "${1:-}"
  local name="$1"; shift
  [[ $# -gt 0 ]] || die "usage: tinderbox-ng emerge <name> [-p|--pretend] <args...>"

  # Default to --oneshot so we don't pollute @world. Caller can override
  # by passing their own emerge atoms/flags after the session name.
  local emerge_flags="--color=y --oneshot --verbose"
  local cmd="timeout ${TINDERBOX_BUILD_TIMEOUT:-43200} /usr/bin/emerge $emerge_flags $*"
  cmd_exec "$name" -- "$cmd"
}

# -----------------------------------------------------------------------------
# Salvage Portage per-package build.log files from a session before destroy
# -----------------------------------------------------------------------------
#
# Walks `<session_merged>/var/tmp/portage/<cat>/<pf>/temp/` for every
# leftover build.log and copies it (plus the small companion files
# emerge keeps next to it: build.log.gz if compressed, environment is
# intentionally NOT salvaged because it's huge and rarely needed for
# triage) to <dest>/<cat>/<pf>.build.log .
#
# Why "leftover": at default Portage settings (FEATURES=clean,
# !keepwork) a successful merge wipes its workdir, so any surviving
# build.log under /var/tmp/portage marks a package whose build phase
# failed. That makes this a zero-config "salvage just the failures"
# strategy without needing to parse each engine's log first.
#
# Best-effort: never aborts, always returns 0. Logs the count when >0.

# -----------------------------------------------------------------------------
# Salvage the target package's per-ebuild build log + portage-ng phase_stats.pl
# -----------------------------------------------------------------------------
#
# Each engine writes a per-ebuild log file independent of its session-wide
# log:
#   * emerge       /var/log/portage/<cat>:<pf>:<timestamp>.log[.gz]
#                  (only when PORTAGE_LOGDIR is set; the build pass below
#                  exports PORTAGE_LOGDIR=/var/log/portage to make this
#                  happen, otherwise the log lives under /var/tmp/portage
#                  and is wiped by FEATURES=clean on successful builds)
#   * portage-ng   /var/tmp/portage-ng/logs/<entry-with-slashes-as-dashes>.log
#                  (config:build_log_dir, persists regardless of outcome)
#
# We only care about the user's *target* package(s), not their dependency
# closure, so we glob each engine's log dir for files whose basename
# contains <cat>:<pn>-... or <cat>--<pn>-... and copy the newest match
# per target out to <logdir>/<engine>.target.<cat_pn>.build.log .
#
# portage-ng additionally writes ebuild_exec:phase_stats_file at
# <cwd>/Knowledge/phase_stats.pl, where <cwd> is /opt/portage-ng (set by
# the engine command). We salvage that to <logdir>/phase_stats.pl .
#
# Best-effort: never aborts, always returns 0.

_compare_salvage_target_buildlog() {
  local engine="$1" session="$2" dest="$3"; shift 3
  local upper; upper="$(session_upper "$session")"

  # Engine-specific persistent log dir (only populated by source-build
  # codepaths; binpkg merges leave nothing here).
  local primary_root
  case "$engine" in
    emerge)     primary_root="$upper/var/log/portage"            ;;
    portage-ng) primary_root="$upper/var/tmp/portage-ng/logs"    ;;
    *) return 0 ;;
  esac

  local n=0 t
  for t in "$@"; do
    # Reduce a target atom (=cat/pn-1.0::repo, >=cat/pn-1.0:slot, etc.)
    # to bare cat/pn so we can match either Portage's `:` filename
    # convention or portage-ng's `--` slash-replacement.
    local cp
    cp="$(printf '%s' "$t" | sed -E 's/^[!~<>=]+//; s/::.*$//; s/:[^/]*$//; s/-[0-9].*$//')"
    local cat_part="${cp%%/*}"
    local pn_part="${cp#*/}"
    [[ -n "$cat_part" && -n "$pn_part" && "$cat_part" != "$pn_part" ]] || continue
    local safe="${cp//\//_}"

    local found=()

    # 1. Engine-specific persistent log dir (source builds).
    if [[ -d "$primary_root" ]]; then
      while IFS= read -r -d '' f; do found+=("$f"); done \
        < <(find "$primary_root" -maxdepth 1 -type f \( \
              -name "${cat_part}:${pn_part}-*"     \
           -o -name "${cat_part}--${pn_part}-*"    \
           -o -name "${cat_part}--${pn_part}.*"    \
           \) -print0 2>/dev/null)
    fi

    # 2. Fallback: Portage's per-package temp build.log. Works for
    # binpkg merges (which never hit ebuild_exec / PORTAGE_LOGDIR) and
    # is the universal "what happened during the merge" record. With
    # FEATURES=clean a successful source merge wipes this, so for
    # source builds the primary_root file (when present) is the one
    # that survives -- the fallback only fires for binpkg merges or
    # for failed source builds whose workdir survives by virtue of the
    # failure.
    #
    # /var/tmp/portage is a per-session bind-mount of
    # session_portage_tmpdir() (overlay-bypass; see _ns_session_mount),
    # so we read from the host-side scratch dir directly. Falls back to
    # the legacy $upper path for sessions that predate the bind-mount
    # change so cross-version operation stays clean.
    if (( ${#found[@]} == 0 )); then
      local pkgroot="$(session_portage_tmpdir "$session")/$cat_part"
      [[ -d "$pkgroot" ]] || pkgroot="$upper/var/tmp/portage/$cat_part"
      if [[ -d "$pkgroot" ]]; then
        local pf_dir
        while IFS= read -r -d '' pf_dir; do
          local bl="$pf_dir/temp/build.log"
          [[ -f "$bl" ]] && found+=("$bl")
        done < <(find "$pkgroot" -mindepth 1 -maxdepth 1 -type d \
                      -name "${pn_part}-*" -print0 2>/dev/null)
      fi
    fi

    (( ${#found[@]} > 0 )) || continue

    # If multiple match (e.g. portage-ng wrote install/run/register as
    # separate files, or there are slot-rotated copies), keep them all.
    local f outname
    for f in "${found[@]}"; do
      outname="${engine}.target.${safe}.build.log"
      if (( ${#found[@]} > 1 )); then
        outname="${engine}.target.${safe}.${f##*/}"
      fi
      [[ "$f" == *.gz && "$outname" != *.gz ]] && outname+=".gz"
      cp -p "$f" "$dest/$outname" 2>/dev/null && n=$((n+1))
    done
  done

  if (( n > 0 )); then
    log_info "  salvaged $n target build.log(s) [$engine] → $dest"
  fi
  return 0
}

_compare_salvage_phase_stats() {
  local session="$1" dest="$2"
  local src
  src="$(session_upper "$session")/opt/portage-ng/Knowledge/phase_stats.pl"
  [[ -f "$src" ]] || return 0
  cp -p "$src" "$dest/phase_stats.pl" 2>/dev/null || return 0
  local sz
  sz="$(stat -c %s "$src" 2>/dev/null || echo '?')"
  log_info "  salvaged phase_stats.pl ($sz bytes) → $dest"
  return 0
}

_compare_salvage_buildlogs() {
  local session="$1" dest="$2"
  local pkgroot
  # /var/tmp/portage inside the chroot is a per-session bind-mount of
  # session_portage_tmpdir() (set up in _ns_session_mount as an overlay
  # bypass); the host-side directory persists after the namespace exits,
  # so we read from it directly. For sessions that predate this layout
  # we fall back to the original $upper/var/tmp/portage location so
  # cross-version operation stays clean.
  #
  # IMPORTANT historical context: when this code walked the overlay's
  # `upper` layer it had to AVOID `merged`, because from the host's
  # main namespace `merged/` is empty after the session command returns
  # (the overlay+binds only exist inside the per-session mount
  # namespace). The upper layer always contained every file written
  # during the session and persisted outside the namespace until
  # cmd_destroy removed session_dir. Verified empirically: dev-haskell/*
  # (and all other build-phase failures whose chroots include
  # /var/tmp/portage/<cat>/<pf>/temp/build.log) silently failed to
  # salvage before that fix. The portage_tmpdir layout preserves the
  # same persistence guarantee while bypassing the overlay-inode-cache
  # bug; see commit log for details.
  pkgroot="$(session_portage_tmpdir "$session")"
  if [[ ! -d "$pkgroot" ]]; then
    pkgroot="$(session_upper "$session")/var/tmp/portage"
  fi
  [[ -d "$pkgroot" ]] || return 0
  local n=0 log rel cat pf
  while IFS= read -r -d '' log; do
    rel="${log#$pkgroot/}"          # cat/pf/temp/build.log
    cat="${rel%%/*}"
    pf="${rel#*/}"; pf="${pf%%/*}"
    install -d "$dest/$cat" 2>/dev/null || continue
    if cp -p "$log" "$dest/$cat/$pf.build.log" 2>/dev/null; then
      n=$((n+1))
      # Compress on the fly: build.logs from a failed make can be MB
      # of -Wall noise plus the actual error. gzip-9 is fast and shrinks
      # them ~10x; tools (less, zgrep) handle .gz transparently.
      gzip -f -9 "$dest/$cat/$pf.build.log" 2>/dev/null || true
    fi
  done < <(find "$pkgroot" -mindepth 4 -maxdepth 4 -name build.log -type f -print0 2>/dev/null)
  if (( n > 0 )); then
    log_info "  salvaged $n failed build.log(s) → $dest"
  fi
  return 0
}


# =============================================================================
# Subcommand: compare (run portage-ng + emerge side by side)
# =============================================================================
#
# Spins two fresh sessions from the same baseline, runs the same target
# package through portage-ng and through emerge in parallel (each in its
# own mount namespace), captures the logs, and prints a concise
# side-by-side summary plus a delta report.
#
# Use this whenever you suspect "portage-ng can't do X but emerge can"
# (or vice-versa). It's the difference between guessing and knowing.
#
#   tinderbox-ng compare www-servers/apache
#   tinderbox-ng compare --build www-servers/apache
#   tinderbox-ng compare --pretend dev-libs/glib            # default
#   tinderbox-ng compare --keep app-shells/zsh              # don't destroy sessions after
#   tinderbox-ng compare --label apache-mpms www-servers/apache
#
# Sessions are named pkg-cmp-{portage-ng,emerge}-<label>. <label> defaults
# to the sanitized package atom. Both sessions are destroyed at the end
# unless --keep is passed. Per-package portage build.log files are always
# salvaged out of /var/tmp/portage/<cat>/<pf>/temp/ before destroy and
# stored under <logdir>/build-logs/{portage-ng,emerge}/<cat>/<pf>.build.log.gz
# so failures retain their root-cause evidence after cleanup.
#
# Plan vs. build logs: every invocation runs each engine in --pretend
# first, and writes the resolver output to <engine>.plan.log (with a
# .exit sibling). When mode is --build AND the plan pass returned an
# acceptable rc (0/1/2 for portage-ng, 0 for emerge), the engine is
# invoked a second time without --pretend; that pass's output goes to
# <engine>.build.log (with a .exit sibling). The plan pass and build
# pass each get their own mount namespace but share the session's
# overlay upper layer, so the build pass starts from the post-plan
# session state (in practice indistinguishable from a fresh session
# since --pretend writes nothing of consequence). If the plan pass
# fails the build pass is skipped; the absence of <engine>.build.log
# signals "build did not run". This means a --build run produces 4
# session-wide logs (pn.plan, pn.build, em.plan, em.build); a --pretend
# run produces 2 (pn.plan, em.plan).
#
# Per-target artefacts (--build only): the build pass also salvages
# each engine's per-ebuild log for the *target* package(s) into
# <logdir>/{portage-ng,emerge}.target.<cat_pn>.build.log. These come
# from the engine's persistent log dir (portage-ng's
# config:build_log_dir, emerge's PORTAGE_LOGDIR=/var/log/portage which
# we set on the build pass) and survive workdir cleanup, so a
# successful target's compile log is preserved without disabling
# FEATURES=clean. portage-ng's phase_stats.pl is salvaged alongside.
#
# Per-pass timing: each pass also writes <log>.timing alongside <log>
# and <log>.exit, with key=value lines:
#     started=<unix-epoch-seconds>
#     ended=<unix-epoch-seconds>
#     wall_time_ms=<integer milliseconds>
#     rc=<integer>
# These files are the canonical input for `tinderbox-ng extract-timing`,
# which aggregates portage-ng vs. emerge wall-clock timings across one
# or many compare sessions. We capture wall time ourselves rather than
# relying on engine-internal timing markers because emerge does not
# emit any (only the legacy graph-mode .emerge wrappers did) and
# portage-ng's --ci pretend path likewise does not currently emit them.

# _compare_sanitize_label <package-atom>
#
# Filesystem-safe compare label. Must stay in sync with compare-matrix.sh
# (translate '+' -> 'p' before collapsing non-alnum) so ad-hoc compares
# and matrix runs never collide on session names (bonnie vs bonnie++, …).
_compare_sanitize_label() {
  printf '%s' "$1" | tr '+' 'p' | tr -c '[:alnum:]' '_' | sed 's/^_*//;s/_*$//'
}

# _compare_run_pass <log> <session> <command-string>
#
# Runs the command in a fresh mount namespace inside the given session,
# redirecting all output to <log>. Records the command's exit code in
# <log>.exit and per-pass wall-clock timing in <log>.timing.
#
# Returns the underlying command's rc (NOT the unshare rc), preserving
# the existing acceptable-rc gates (portage-ng: 0/1/2; emerge: 0) the
# build pass uses to decide whether to fire.
_compare_run_pass() {
  local log="$1" sess="$2" cmd="$3"
  local t0 t1
  # date +%s.%N gives nanosecond-precision Unix epoch with a literal
  # '.' separator (locale-independent), unlike bash's $EPOCHREALTIME.
  t0="$(date +%s.%N)"
  _unshare_ns "$0" __ns-helper session "$sess" /bin/bash -l -c "$cmd" \
    >"$log" 2>&1
  local rc=$?
  t1="$(date +%s.%N)"
  printf '%d\n' "$rc" >"$log.exit"
  # awk handles the float arithmetic that bash can't (bash integers
  # overflow if we naively multiply nanoseconds by 1000). Output is
  # always integer ms; sub-millisecond passes round to 0.
  awk -v t0="$t0" -v t1="$t1" -v rc="$rc" '
    BEGIN {
      printf "started=%d\n",       t0
      printf "ended=%d\n",         t1
      printf "wall_time_ms=%d\n",  (t1 - t0) * 1000
      printf "rc=%d\n",            rc
    }
  ' >"$log.timing"
  return "$rc"
}

cmd_compare() {
  require_root
  require_kernel_overlay
  require_unshare
  require_dirs

  local mode="--pretend"
  local keep=0
  local label=""
  local positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pretend|-p)   mode="--pretend"; shift ;;
      --build|-b)     mode="--build";   shift ;;
      --keep)         keep=1;           shift ;;
      --label)        label="$2";       shift 2 ;;
      --label=*)      label="${1#--label=}"; shift ;;
      --)             shift; positional+=("$@"); break ;;
      -*)             die "compare: unknown flag $1" ;;
      *)              positional+=("$1"); shift ;;
    esac
  done
  [[ ${#positional[@]} -gt 0 ]] || die "usage: tinderbox-ng compare [--pretend|--build] [--keep] [--label NAME] <pkg>..."

  local target="${positional[*]}"
  if [[ -z "$label" ]]; then
    label="$(_compare_sanitize_label "$target" | head -c 40)"
  fi

  local sess_pn="pkg-cmp-portage-ng-$label"
  local sess_em="pkg-cmp-emerge-$label"

  log_info "compare: target='$target'  mode=$mode  label=$label"
  log_info "  portage-ng session: $sess_pn"
  log_info "  emerge     session: $sess_em"

  # Fresh sessions both ways, sequentially (cheap; mount-only)
  for s in "$sess_pn" "$sess_em"; do
    if [[ -d "$(session_dir "$s")" ]]; then
      log_info "  destroying stale session $s"
      cmd_destroy "$s" >/dev/null 2>&1 || true
    fi
    cmd_new "$s" >/dev/null
  done

  local logdir="$LOG_DIR/compare-$label-$(date +%Y%m%dT%H%M%S)"
  install -d "$logdir"

  local pn_plan_log="$logdir/portage-ng.plan.log"
  local pn_build_log="$logdir/portage-ng.build.log"
  local em_plan_log="$logdir/emerge.plan.log"
  local em_build_log="$logdir/emerge.build.log"

  log_info "  running both engines in parallel (logs: $logdir)"

  # Plan pass always runs --pretend regardless of the requested mode;
  # the build pass (only invoked when mode=--build and the plan pass
  # succeeded) runs without --pretend. Splitting the two passes lets
  # us archive the resolver output and the build output separately,
  # which is exactly what an operator wants when triaging a build
  # failure: was it the plan that diverged, or the execution?
  # Split timeouts: planning is bounded (resolver is CPU only, never waits
  # on the network or compilers), the build pass can chase pathologically
  # large source trees (libreoffice, dev-lang/pypy, dev-lang/spark,
  # everything in dev-ada/*, all sequoia-* crates, …). Running both passes
  # under one fat timeout means a slow planner can starve the build, or a
  # legitimate-but-long build trips the planner-tuned ceiling.
  # TINDERBOX_BUILD_TIMEOUT is the build-pass timeout for both engines; if
  # an operator bumps it, both see the new value. TINDERBOX_PLAN_TIMEOUT
  # defaults to 1800s; if an operator already set TINDERBOX_BUILD_TIMEOUT
  # explicitly we still honour that as the upper bound for the plan pass
  # (`min(plan_default, build)` semantics) so we don't surprise anyone who
  # tightened the knob to a small value to bound a quick smoke matrix.
  local BUILD_TO="${TINDERBOX_BUILD_TIMEOUT:-43200}"
  local PLAN_TO="${TINDERBOX_PLAN_TIMEOUT:-1800}"
  if (( PLAN_TO > BUILD_TO )); then PLAN_TO="$BUILD_TO"; fi
  local pn_plan_cmd="cd /opt/portage-ng && timeout $PLAN_TO ./Source/Application/Wrapper/portage-ng-dev --mode standalone --ci --pretend $target"
  local pn_build_cmd="cd /opt/portage-ng && timeout $BUILD_TO ./Source/Application/Wrapper/portage-ng-dev --mode standalone --ci --build $target"
  local em_plan_cmd="timeout $PLAN_TO /usr/bin/emerge --color=n --oneshot --verbose --pretend $target"
  # PORTAGE_LOGDIR=/var/log/portage makes Portage retain a per-ebuild log
  # at /var/log/portage/<cat>:<pf>:<ts>.log even when FEATURES=clean wipes
  # the build temp dir on successful merge. _compare_salvage_target_buildlog
  # picks the target's log out of there before the session is destroyed.
  local em_build_cmd="PORTAGE_LOGDIR=/var/log/portage timeout $BUILD_TO /usr/bin/emerge --color=n --oneshot --verbose $target"

  # Forks; we don't use cmd_exec here to avoid its `exit` at the end
  # (we want both halves to finish and then summarize).
  #
  # set +e inside each subshell: the surrounding script runs under
  # `set -euo pipefail`, which would otherwise abort the subshell as
  # soon as unshare/the inner command returns non-zero -- *before* the
  # printf that records the exit code into <log>.exit. Without that
  # file, _compare_summarize sees pn_rc="?" and the summary degrades
  # to FAIL(?). portage-ng in particular returns 2 for "plan with
  # domain assumptions" which is a normal outcome, not a crash, so
  # this guard is essential.
  #
  # Each engine's subshell runs the plan pass first, then conditionally
  # the build pass. The build pass uses a fresh mount namespace but
  # the same session, so it sees the overlay upper layer's post-plan
  # state (in practice unchanged: --pretend writes nothing of
  # consequence). The "acceptable rc" gate to proceed differs per
  # engine: portage-ng treats 0/1/2 as "plan succeeded" (per
  # .cursorrules), emerge requires rc=0.
  ( set +e
    _compare_run_pass "$pn_plan_log" "$sess_pn" "$pn_plan_cmd"
    pn_plan_rc=$?
    if [[ "$mode" == "--build" && "$pn_plan_rc" -le 2 ]]; then
      _compare_run_pass "$pn_build_log" "$sess_pn" "$pn_build_cmd"
    fi
  ) &
  local pn_pid=$!

  ( set +e
    _compare_run_pass "$em_plan_log" "$sess_em" "$em_plan_cmd"
    em_plan_rc=$?
    if [[ "$mode" == "--build" && "$em_plan_rc" -eq 0 ]]; then
      _compare_run_pass "$em_build_log" "$sess_em" "$em_build_cmd"
    fi
  ) &
  local em_pid=$!

  wait "$pn_pid" || true
  wait "$em_pid" || true

  sweep_session_orphans "$sess_pn"
  sweep_session_orphans "$sess_em"

  # Effective rc per engine: build pass rc if it ran, else plan pass
  # rc. This collapses the two-pass shape back to a single status for
  # the summary table and the cmd_compare exit code, while keeping the
  # split logs for forensic use.
  local pn_rc em_rc
  if [[ -f "$pn_build_log.exit" ]]; then
    pn_rc="$(cat "$pn_build_log.exit")"
  else
    pn_rc="$(cat "$pn_plan_log.exit" 2>/dev/null || echo "?")"
  fi
  if [[ -f "$em_build_log.exit" ]]; then
    em_rc="$(cat "$em_build_log.exit")"
  else
    em_rc="$(cat "$em_plan_log.exit" 2>/dev/null || echo "?")"
  fi

  _compare_summarize "$target" "$mode" "$sess_pn" "$sess_em" \
                     "$pn_plan_log" "$pn_build_log" \
                     "$em_plan_log" "$em_build_log" \
                     "$pn_rc" "$em_rc" "$logdir"

  # Salvage Portage per-package build.log files for FAILED packages
  # in the dep closure BEFORE destroying the sessions. Successful builds
  # clean their workdir (FEATURES=clean, default), so a leftover
  # `<cat>/<pf>/temp/build.log` always signals a failed package. Without
  # this, the only post-mortem evidence is the per-engine log we already
  # have, which records the step-level FAIL but not the underlying
  # compile/configure/install error. We need the latter to triage shared
  # sub-package failures (e.g. xdg-utils / qt5compat cascading into
  # multiple top-level fail/fail rows in compare-matrix).
  #
  # Always run, even with --keep, since copies are cheap and this gives
  # the same post-mortem path regardless of cleanup mode.
  _compare_salvage_buildlogs "$sess_pn" "$logdir/build-logs/portage-ng"
  _compare_salvage_buildlogs "$sess_em" "$logdir/build-logs/emerge"

  # Salvage the *target* package's per-ebuild build log (regardless of
  # outcome) plus portage-ng's phase_stats.pl. These come from each
  # engine's persistent log directory, not from /var/tmp/portage, so
  # they survive successful merges. Skipped automatically when no build
  # pass ran (e.g. mode=--pretend).
  _compare_salvage_target_buildlog portage-ng "$sess_pn" "$logdir" "${positional[@]}"
  _compare_salvage_target_buildlog emerge     "$sess_em" "$logdir" "${positional[@]}"
  _compare_salvage_phase_stats               "$sess_pn" "$logdir"

  if [[ $keep -eq 0 ]]; then
    log_info "  cleaning up sessions (use --keep to preserve)"
    cmd_destroy "$sess_pn" >/dev/null 2>&1 || true
    cmd_destroy "$sess_em" >/dev/null 2>&1 || true
  else
    log_info "  --keep: sessions preserved at $sess_pn / $sess_em"
  fi

  # Exit code: 0 if both succeeded, 1 if one failed, 2 if both failed.
  if [[ "$pn_rc" == "0" && "$em_rc" == "0" ]]; then
    exit 0
  elif [[ "$pn_rc" != "0" && "$em_rc" != "0" ]]; then
    exit 2
  else
    exit 1
  fi
}

# Internal: render a side-by-side comparison summary.
#
# Pulls a few key signals out of each engine's logs:
#   - exit code (success vs failure)
#   - planner verdict (count of actions / packages from the plan log)
#   - ebuilds actually installed/registered (parsed from VDB after build,
#     and from the build log's completion markers)
#   - first failed phase / first error keyword (build log preferred,
#     plan log fallback)
#
# Logs come in pairs per engine: <engine>.plan.log (always present)
# and <engine>.build.log (only present when mode=--build AND the plan
# pass succeeded). Counters that describe the plan come from the plan
# log; counters that describe execution come from the build log.
#
# Output is plain stdout so it's easy to redirect or pipe to less.
_compare_summarize() {
  # Don't let a failing grep or empty pipeline kill the summary mid-render.
  set +e
  local target="$1" mode="$2"
  local sess_pn="$3" sess_em="$4"
  local pn_plan_log="$5" pn_build_log="$6"
  local em_plan_log="$7" em_build_log="$8"
  local pn_rc="$9" em_rc="${10}"
  local logdir="${11}"

  # portage-ng exit-code semantics (per .cursorrules):
  #   0 = no assumptions
  #   1 = only prover cycle-break assumptions
  #   2 = at least one domain assumption (e.g. masked dep)
  # All three indicate the planner produced a plan; only larger codes
  # (or a missing rc altogether) mean a real crash. emerge follows the
  # standard 0=success/non-zero=failure convention.
  local pn_status em_status
  case "$pn_rc" in
    0)   pn_status="OK" ;;
    1)   pn_status="OK(cycles)" ;;
    2)   pn_status="OK(assumed)" ;;
    124) pn_status="TIMEOUT" ;;
    137) pn_status="KILLED(SIGKILL)" ;;   # almost always OOM in the matrix
    143) pn_status="KILLED(SIGTERM)" ;;
    *)   pn_status="FAIL($pn_rc)" ;;
  esac
  case "$em_rc" in
    0)   em_status="OK" ;;
    124) em_status="TIMEOUT" ;;
    137) em_status="KILLED(SIGKILL)" ;;
    143) em_status="KILLED(SIGTERM)" ;;
    *)   em_status="FAIL($em_rc)" ;;
  esac

  # Reclassify fetch-restricted ebuilds (RESTRICT="fetch" or RESTRICT="mirror"
  # with no upstream binary mirror, e.g. app-arch/stuffit, app-office/moneydance,
  # dev-db/sqldeveloper, app-office/worklog-assistant-bin) as RESTRICT(fetch)
  # rather than FAIL(N). These aren't real failures: the package metadata
  # explicitly requires a manual download. Reading both engines' build logs
  # for the documented marker is cheap and lets results.tsv distinguish
  # "package broken" from "rig can't auto-download".
  #
  # Marker shapes seen in the wild:
  #   portage-ng: "[step N] FAIL (manual fetch required) download portage://..."
  #   emerge:     "Fetch failed for '<cat>/<pf>'" / ">>> Please download files manually"
  if [[ -f "$pn_build_log" ]] && grep -aqE 'FAIL \(manual fetch required\)' "$pn_build_log" 2>/dev/null; then
    pn_status="RESTRICT(fetch)"
  fi
  if [[ -f "$em_build_log" ]] && grep -aqE 'Please download files manually|Fetch failed for ' "$em_build_log" 2>/dev/null; then
    em_status="RESTRICT(fetch)"
  fi

  # Reclassify gtar "Directory renamed before its status could be extracted"
  # as INFRA(overlay-inode-flicker). This is a documented OverlayFS bug:
  # under inode-cache reclaim pressure (mesa-26.0.5.tar.xz unpacks ~30k
  # files, librsvg / glib are similar), the kernel evicts overlay inodes
  # mid-extraction and re-allocates fresh ones; gtar's verify-after-create
  # lstat() returns a different inode than the one it recorded and bails.
  # See https://github.com/spdk/spdk/issues/3521 plus the docker/RHEL
  # threads with the same symptom.
  #
  # The bug strikes pn ~26x more than emerge in our matrix because pn's
  # layer-batched executor keeps many cpvs' workdirs populated under
  # /var/tmp/portage simultaneously, maximising overlay inode-cache
  # pressure. Tagging it explicitly avoids charging pn for an
  # infrastructure issue. The fix path (separate non-overlay tmpfs at
  # /var/tmp/portage) lands in _ns_session_mount; this reclassifier is
  # the cheap accounting fix that's correct even after that lands (any
  # residual occurrence is still genuinely an infra issue).
  local _gtar_re='Directory renamed before its status could be extracted'
  if [[ -f "$pn_build_log" ]] && grep -aqE "$_gtar_re" "$pn_build_log" 2>/dev/null; then
    pn_status="INFRA(overlay-inode-flicker)"
  elif [[ -d "$logdir/build-logs/portage-ng" ]] && \
       find "$logdir/build-logs/portage-ng" -name '*.build.log.gz' -print0 2>/dev/null \
         | xargs -0 -r zgrep -lE "$_gtar_re" 2>/dev/null \
         | grep -q .; then
    pn_status="INFRA(overlay-inode-flicker)"
  fi
  if [[ -f "$em_build_log" ]] && grep -aqE "$_gtar_re" "$em_build_log" 2>/dev/null; then
    em_status="INFRA(overlay-inode-flicker)"
  fi

  # portage-ng renders with ANSI color codes, so we strip them before matching.
  # ESC[...m sequences appear around numbers in lines like "Total: \e[32m16\e[00m completed."
  local _strip='s/\x1b\[[0-9;]*[a-zA-Z]//g'
  local pn_plan_clean em_plan_clean pn_build_clean em_build_clean
  pn_plan_clean="$(sed -E "$_strip" "$pn_plan_log" 2>/dev/null)"
  em_plan_clean="$(sed -E "$_strip" "$em_plan_log" 2>/dev/null)"
  pn_build_clean=""
  em_build_clean=""
  [[ -f "$pn_build_log" ]] && pn_build_clean="$(sed -E "$_strip" "$pn_build_log" 2>/dev/null)"
  [[ -f "$em_build_log" ]] && em_build_clean="$(sed -E "$_strip" "$em_build_log" 2>/dev/null)"

  # Plan-side counters come from the plan log.
  # portage-ng's plan: "Total: N actions" line; emerge: "Total: N packages"
  local pn_plan_actions em_plan_actions
  pn_plan_actions="$(printf '%s\n' "$pn_plan_clean" | grep -oE 'Total:[[:space:]]*[0-9]+ actions?' | tail -n1 | grep -oE '[0-9]+')"
  em_plan_actions="$(printf '%s\n' "$em_plan_clean" | grep -oE 'Total:[[:space:]]*[0-9]+ packages?' | tail -n1 | grep -oE '[0-9]+')"
  [[ -z "$pn_plan_actions" ]] && pn_plan_actions="?"
  [[ -z "$em_plan_actions" ]] && em_plan_actions="?"

  # Execution-side counters come from the build log; absent in --pretend
  # mode (or when plan failed and build was skipped) -> 0.
  local pn_completed em_completed
  pn_completed="$(printf '%s\n' "$pn_build_clean" | grep -oE 'Total:[[:space:]]*[0-9]+ completed' | tail -n1 | grep -oE '[0-9]+')"
  [[ -z "$pn_completed" ]] && pn_completed=0
  em_completed="$(printf '%s\n' "$em_build_clean" | grep -cE '^>>> Completed')"
  [[ -z "$em_completed" ]] && em_completed=0

  # First error / failure marker, trimmed (use stripped-ANSI version).
  # Prefer the build log (where real execution failures live) over the
  # plan log (which usually only errors on unsatisfiable resolves).
  local pn_first_err em_first_err
  pn_first_err="$(printf '%s\n' "$pn_build_clean" | grep -m1 -iE '\b(error|fail|aborting|REQUIRED_USE|unmet|unsatisfied)' | head -c 200)"
  [[ -z "$pn_first_err" ]] && pn_first_err="$(printf '%s\n' "$pn_plan_clean" | grep -m1 -iE '\b(error|fail|aborting|REQUIRED_USE|unmet|unsatisfied)' | head -c 200)"
  em_first_err="$(printf '%s\n' "$em_build_clean" | grep -m1 -iE '\b(error|fail|aborting|REQUIRED_USE|unmet|unsatisfied)' | head -c 200)"
  [[ -z "$em_first_err" ]] && em_first_err="$(printf '%s\n' "$em_plan_clean" | grep -m1 -iE '\b(error|fail|aborting|REQUIRED_USE|unmet|unsatisfied)' | head -c 200)"

  # Final installed CPV list from each session's VDB upper layer
  local pn_vdb em_vdb
  pn_vdb="$(_compare_vdb_list "$sess_pn")"
  em_vdb="$(_compare_vdb_list "$sess_em")"
  local pn_n em_n
  pn_n="$(printf '%s' "$pn_vdb" | awk 'NF{c++} END{print c+0}')"
  em_n="$(printf '%s' "$em_vdb" | awk 'NF{c++} END{print c+0}')"

  local only_pn only_em both pn_sorted em_sorted
  pn_sorted="$(printf '%s\n' "$pn_vdb" | sort -u)"
  em_sorted="$(printf '%s\n' "$em_vdb" | sort -u)"
  only_pn="$(comm -23 <(printf '%s\n' "$pn_sorted") <(printf '%s\n' "$em_sorted") 2>/dev/null)"
  only_em="$(comm -13 <(printf '%s\n' "$pn_sorted") <(printf '%s\n' "$em_sorted") 2>/dev/null)"
  both="$(   comm -12 <(printf '%s\n' "$pn_sorted") <(printf '%s\n' "$em_sorted") 2>/dev/null)"

  printf '\n'
  printf '┌────────────────────────────────────────────────────────────────────────┐\n'
  printf '│ tinderbox-ng compare report                                            │\n'
  printf '├────────────────────────────────────────────────────────────────────────┤\n'
  printf '│ target : %-62s│\n' "$target"
  printf '│ mode   : %-62s│\n' "$mode"
  printf '│ logs   : %-62s│\n' "$logdir"
  printf '├──────────────────┬─────────────────────────┬───────────────────────────┤\n'
  printf '│ %-16s │ %-23s │ %-25s │\n' '(metric)' 'portage-ng' 'emerge'
  printf '├──────────────────┼─────────────────────────┼───────────────────────────┤\n'
  printf '│ %-16s │ %-23s │ %-25s │\n' 'exit'         "$pn_status"        "$em_status"
  printf '│ %-16s │ %-23s │ %-25s │\n' 'plan actions' "$pn_plan_actions"  "$em_plan_actions"
  printf '│ %-16s │ %-23s │ %-25s │\n' 'completed'    "$pn_completed"     "$em_completed"
  printf '│ %-16s │ %-23s │ %-25s │\n' 'merged into VDB' "$pn_n"          "$em_n"
  printf '└──────────────────┴─────────────────────────┴───────────────────────────┘\n'

  if [[ -n "$pn_first_err" || -n "$em_first_err" ]]; then
    printf '\nFirst error/warning per engine:\n'
    [[ -n "$pn_first_err" ]] && printf '  portage-ng: %s\n' "$pn_first_err"
    [[ -n "$em_first_err" ]] && printf '  emerge    : %s\n' "$em_first_err"
  fi

  # Surface any salvaged per-package build.log files so the operator can
  # zgrep / less directly without re-running the failure.
  local bl_pn bl_em
  bl_pn="$(find "$logdir/build-logs/portage-ng" -type f -name '*.build.log.gz' 2>/dev/null | wc -l | tr -d ' ')"
  bl_em="$(find "$logdir/build-logs/emerge"     -type f -name '*.build.log.gz' 2>/dev/null | wc -l | tr -d ' ')"
  if [[ "${bl_pn:-0}" -gt 0 || "${bl_em:-0}" -gt 0 ]]; then
    printf '\nSalvaged failed-package build.logs (gzipped):\n'
    [[ "${bl_pn:-0}" -gt 0 ]] && printf '  portage-ng: %s file(s) under %s/build-logs/portage-ng/\n' "$bl_pn" "$logdir"
    [[ "${bl_em:-0}" -gt 0 ]] && printf '  emerge    : %s file(s) under %s/build-logs/emerge/\n'     "$bl_em" "$logdir"
  fi

  if [[ -n "$only_pn$only_em" ]]; then
    printf '\nVDB delta (after build):\n'
    if [[ -n "$only_pn" ]]; then
      printf '  only in portage-ng:\n'
      printf '%s\n' "$only_pn" | sed 's/^/    + /'
    fi
    if [[ -n "$only_em" ]]; then
      printf '  only in emerge:\n'
      printf '%s\n' "$only_em" | sed 's/^/    + /'
    fi
    if [[ -n "$both" ]]; then
      local nb
      nb="$(printf '%s' "$both" | awk 'NF{c++} END{print c+0}')"
      printf '  in both: %s packages\n' "$nb"
    fi
  fi

  printf '\nFull logs:\n'
  printf '  portage-ng plan : %s\n'  "$pn_plan_log"
  [[ -f "$pn_build_log" ]] && printf '  portage-ng build: %s\n' "$pn_build_log"
  printf '  emerge     plan : %s\n'  "$em_plan_log"
  [[ -f "$em_build_log" ]] && printf '  emerge     build: %s\n' "$em_build_log"

  # Surface target-only artefacts (per-ebuild build logs + phase_stats.pl)
  # when present. Listed separately from the session-wide logs above so
  # the operator can grab them quickly without globbing the dir.
  local tgt_n=0 tgt
  for tgt in "$logdir"/portage-ng.target.*.build.log* "$logdir"/emerge.target.*.build.log*; do
    [[ -f "$tgt" ]] || continue
    if (( tgt_n == 0 )); then printf '\nTarget per-ebuild logs:\n'; fi
    printf '  %s\n' "$tgt"
    tgt_n=$((tgt_n+1))
  done
  if [[ -f "$logdir/phase_stats.pl" ]]; then
    printf '\nportage-ng phase_stats.pl: %s\n' "$logdir/phase_stats.pl"
  fi

  printf '\n'
  set -e
}

# Internal: list installed CPV atoms in a session's upper VDB layer.
# Returns one cat/name-version per line, sorted.
_compare_vdb_list() {
  local name="$1"
  local vdb_root
  vdb_root="$(session_upper "$name")/var/db/pkg"
  [[ -d "$vdb_root" ]] || return 0
  ( cd "$vdb_root" && find . -mindepth 2 -maxdepth 2 -type d 2>/dev/null \
      | sed 's|^\./||' | sort )
}

# =============================================================================
# Subcommand: continue (resume an interrupted compare-matrix run)
# =============================================================================
#
# Auto-detects the most recent compare-matrix-* run, recovers its mode /
# manifest / jobs from meta.txt, computes the set of targets not yet in
# results.tsv, and dispatches compare-matrix on the remaining targets.
#
# Appends to the original run's results.tsv (via compare-matrix.sh
# --resume-dir) so resumed work shows up in the same dashboard counters
# and the same canonical TSV as the original run. meta.txt records every
# resume event as an auditable "# ----- resumed at ... -----" block.
#
# Always re-mounts the sessions tmpfs first if it isn't active. The tmpfs
# is intentionally not auto-mounted by the host (no fstab entry, no init
# unit) — that's tinderbox-ng's job, not the OS's. After a crash + reboot
# this is the first thing that needs to happen, otherwise new sessions
# silently fall back to the underlying disk and saturate I/O.
#
# Foreground by default (so Ctrl-C still works); for unattended runs the
# preferred wrapper is `screen` (lets you reattach to a live driver TTY
# across SSH drops), e.g.
#
#   ssh root@vm-linux.local 'screen -dmS tinderbox-ng tinderbox-ng continue --jobs 16'
#   ssh -t root@vm-linux.local screen -r tinderbox-ng     # reattach
#
# Pass --background as the no-screen fallback: detach via nohup setsid
# nice and write a pidfile + driver log. That survives SSH drops too,
# but daemonises the driver — there is no live TTY to reattach to.

cmd_continue() {
  require_root
  require_dirs

  local pinned_run="" jobs_override="" detach=0 force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run)        pinned_run="$2"; shift 2 ;;
      --run=*)      pinned_run="${1#--run=}"; shift ;;
      --jobs|-j)    jobs_override="$2"; shift 2 ;;
      --jobs=*)     jobs_override="${1#--jobs=}"; shift ;;
      --background|--bg) detach=1; shift ;;
      --force)      force=1; shift ;;
      -h|--help)
        cat <<'CONT_HELP'
tinderbox-ng continue [--run DIR] [--jobs N] [--background] [--force]

Resume a compare-matrix run that was interrupted (host crash, reboot,
SIGINT, etc.).

Behaviour:
  * Auto-mounts the sessions tmpfs if not already mounted.
  * Refuses to launch if a compare-matrix driver is already running
    (use --force to override; not recommended — two parallel matrices
    will oversubscribe the host).
  * Auto-detects the most recent compare-matrix-<stamp>/ run dir.
  * Reads its meta.txt to recover the original --pretend/--build mode,
    manifest path, and --jobs setting.
  * Computes "remaining targets" = original manifest minus every target
    already present in the run's results.tsv.
  * Launches a new compare-matrix run on the remaining manifest, in a
    new compare-matrix-<stamp>/ dir (the previous TSV stays untouched).

Options:
  --run DIR       Pin a specific previous run directory (otherwise auto).
  --jobs N        Override the --jobs setting recovered from meta.txt.
  --background    Detach with nohup setsid nice; write driver pid + log
                  paths and exit immediately. Survives SSH drops, but
                  daemonises the driver -- no live TTY to reattach to.
                  For unattended runs, prefer wrapping the foreground
                  invocation in screen so you keep a live TTY:
                    ssh root@vm-linux.local screen -dmS tinderbox-ng \\
                        tinderbox-ng continue --jobs 16
                    ssh -t root@vm-linux.local screen -r tinderbox-ng
  --force         Bypass the "already running" guard. Only safe if you
                  really want two concurrent matrices on the box.

Resumed work appends to the original run's results.tsv; meta.txt logs
each resume event. No manual TSV merging needed.
CONT_HELP
        return 0 ;;
      --) shift; break ;;
      -*) die "continue: unknown flag $1" ;;
      *)  die "continue: unexpected positional arg '$1'" ;;
    esac
  done

  _ensure_sessions_tmpfs

  local reports_dir="${REPORTS_DIR_DEFAULT:-$TINDERBOX_ROOT/reports}"

  # Safeguard: refuse to launch a second matrix in parallel with one that's
  # already running. pgrep matches both the absolute install path and the
  # in-tree template path. Override via --force.
  local active_drivers
  active_drivers="$(pgrep -af '(/usr/local/sbin/compare-matrix|compare-matrix\.sh)' 2>/dev/null \
                    | grep -v $$ || true)"
  if [[ -n "$active_drivers" ]]; then
    if (( force )); then
      log_warn "a compare-matrix driver is already running (--force given, proceeding):"
      while IFS= read -r line; do
        [[ -n "$line" ]] && log_warn "  $line"
      done <<<"$active_drivers"
    else
      log_error "a compare-matrix driver is already running:"
      while IFS= read -r line; do
        [[ -n "$line" ]] && log_error "  $line"
      done <<<"$active_drivers"
      log_error "abort the in-flight driver first (kill -TERM <pid>),"
      log_error "or pass --force if you really want a second concurrent matrix."
      die "refusing to start a second matrix"
    fi
  fi

  local run="$pinned_run"
  if [[ -z "$run" ]]; then
    # Strict canonical-name match: only `compare-matrix-<14-digit-stamp>`
    # qualifies as a resumable run. Anything with a suffix
    # (`.merged-into-*`, `.aborted`, `.partial-*`, `archive-*`, etc.) is
    # an operator-archived sibling that must NOT be auto-detected, even
    # if its mtime happens to be newer than the canonical original.
    # Use --run DIR to override.
    # Use POSIX-extended regex explicitly. The default emacs/findutils
    # regex syntax in GNU find 4.10 silently fails to honour `\{N\}`
    # repetition (returns no matches), which would make `cmd_continue`
    # always die with "no canonical compare-matrix-<stamp> run found"
    # even when one exists. Verified on findutils 4.10.0.
    run="$(find "$reports_dir" -maxdepth 1 -mindepth 1 -type d \
                -regextype posix-extended \
                -regex ".*/compare-matrix-[0-9]{8}T[0-9]{6}" \
                -printf '%T@\t%p\n' 2>/dev/null \
            | sort -rn | head -n1 | cut -f2-)"
    [[ -n "$run" ]] || die "no canonical compare-matrix-<stamp> run found under $reports_dir"
    log_info "auto-detected previous run: $(basename "$run")"
  fi
  [[ -d "$run" ]] || die "run directory not found: $run"

  local meta="$run/meta.txt"
  local tsv="$run/results.tsv"
  [[ -f "$meta" ]] || die "missing meta.txt in $run"
  [[ -f "$tsv" ]]  || die "missing results.tsv in $run"

  local prev_mode prev_manifest prev_jobs
  prev_mode="$(awk -F'\t' '$1=="mode"     {print $2; exit}' "$meta")"
  prev_manifest="$(awk -F'\t' '$1=="manifest" {print $2; exit}' "$meta")"
  prev_jobs="$(awk -F'\t' '$1=="jobs"     {print $2; exit}' "$meta")"

  [[ -n "$prev_mode" ]]     || die "could not recover mode from $meta"
  [[ -n "$prev_manifest" ]] || die "could not recover manifest path from $meta"
  [[ -f "$prev_manifest" ]] || die "previous manifest not found: $prev_manifest"
  case "$prev_mode" in
    --pretend|--build) ;;
    *) die "unrecognised mode '$prev_mode' in $meta" ;;
  esac

  local jobs="${jobs_override:-${prev_jobs:-1}}"
  [[ "$jobs" =~ ^[0-9]+$ && "$jobs" -ge 1 ]] \
    || die "--jobs must be a positive integer, got: $jobs"

  log_info "previous run summary:"
  log_info "  dir      : $(basename "$run")"
  log_info "  mode     : $prev_mode"
  log_info "  manifest : $prev_manifest"
  log_info "  jobs     : ${prev_jobs:-1} (using: $jobs)"

  local stamp done_file remain_dir remain_file
  stamp="$(date +%Y%m%dT%H%M%S)"
  done_file="$(mktemp)"
  remain_dir="$TINDERBOX_ROOT/manifests"
  remain_file="$remain_dir/resume-$stamp.txt"
  install -d "$remain_dir"

  awk -F'\t' 'NR>1 && $1!="" {print $1}' "$tsv" | sort -u > "$done_file"
  comm -23 <(sort -u "$prev_manifest") "$done_file" > "$remain_file"
  rm -f "$done_file"

  local total done_count remaining
  total="$(wc -l < "$prev_manifest" | tr -d ' ')"
  done_count="$(awk -F'\t' 'NR>1 && $1!=""' "$tsv" | wc -l | tr -d ' ')"
  remaining="$(wc -l < "$remain_file" | tr -d ' ')"

  log_info "progress recovered: $done_count done, $remaining remaining (of $total)"
  log_info "resume manifest   : $remain_file"

  if (( remaining == 0 )); then
    rm -f "$remain_file"
    log_ok "previous run appears complete; nothing to resume"
    return 0
  fi

  local cm="$LIBEXEC_DIR/compare-matrix.sh"
  [[ -x "$cm" ]] || die "compare-matrix script not found at $cm (re-run deploy-host.sh)"

  # We pass --resume-dir so compare-matrix.sh appends to the original
  # run's results.tsv (and meta.txt as a "resumed at" block) instead of
  # creating a sibling stamp dir. The dashboard then naturally aggregates
  # everything under one logical run; no manual TSV unioning needed.
  if (( detach )); then
    install -d "$reports_dir"
    local logfile pidfile
    logfile="$reports_dir/all-packages-driver-resume-$stamp.log"
    pidfile="$reports_dir/all-packages-driver.pid"
    log_info "launching detached resume into $(basename "$run"): nohup setsid nice -n 19 $cm $prev_mode --jobs $jobs --manifest $remain_file"
    nohup setsid nice -n 19 \
      "$cm" "$prev_mode" --jobs "$jobs" \
            --manifest "$remain_file" \
            --resume-dir "$run" \
      </dev/null >"$logfile" 2>&1 &
    echo $! >"$pidfile"
    sleep 2
    if kill -0 "$(cat "$pidfile")" 2>/dev/null; then
      log_ok "background resume launched"
      log_info "  pid : $(cat "$pidfile")"
      log_info "  log : $logfile"
      log_info "  watch: tinderbox-ng progress"
    else
      die "background resume failed to start; see $logfile"
    fi
  else
    log_info "running in foreground (Ctrl-C to abort, or use --background)"
    exec "$cm" "$prev_mode" --jobs "$jobs" \
                            --manifest "$remain_file" \
                            --resume-dir "$run"
  fi
}


# =============================================================================
# Subcommand: exit (legacy no-op)
# =============================================================================
#
# Kept for backwards-compatible muscle memory. With mount-ns isolation, every
# session's mounts vanish automatically on chroot exit, so there is nothing
# to tear down.

cmd_exit() {
  require_root
  require_session "${1:-}"
  log_info "session '$1' is mount-ns isolated; checking for orphan processes"
  sweep_session_orphans "$1"
}

# =============================================================================
# Subcommand: reset
# =============================================================================

cmd_reset() {
  require_root
  require_session "${1:-}"
  local name="$1"
  sweep_session_orphans "$name"
  unmount_session "$name"
  log_info "wiping upper, work and portage_tmpdir for session '$name'"
  rm -rf --one-file-system "$(session_upper "$name")" "$(session_work "$name")" \
                           "$(session_portage_tmpdir "$name")"
  install -d "$(session_upper "$name")" "$(session_work "$name")"
  install -d -m 2775 "$(session_portage_tmpdir "$name")"
  chown 250:250 "$(session_portage_tmpdir "$name")" 2>/dev/null || true
  log_ok "session '$name' reset to baseline"
}

# =============================================================================
# Subcommand: destroy
# =============================================================================

cmd_destroy() {
  require_root
  require_session "${1:-}"
  local name="$1"
  sweep_session_orphans "$name"
  unmount_session "$name"
  log_info "destroying session '$name' ($(session_dir "$name"))"
  rm -rf --one-file-system "$(session_dir "$name")"
  log_ok "session '$name' destroyed"
}

# =============================================================================
# Subcommands: tmpfs-up / tmpfs-down
# =============================================================================
#
# Manual control over the shared sessions tmpfs (see
# TINDERBOX_SESSIONS_TMPFS_SIZE in the configuration block). Auto-mount
# happens lazily on `cmd_new`, so these are only needed when the operator
# wants to mount/unmount explicitly (e.g. before a long batch run, or to
# free RAM after one).

cmd_tmpfs_up() {
  require_root
  require_dirs
  if sessions_tmpfs_active; then
    log_info "sessions tmpfs already mounted at $SESSIONS_DIR"
    findmnt -no SOURCE,FSTYPE,SIZE,OPTIONS --target "$SESSIONS_DIR"
    return 0
  fi
  _ensure_sessions_tmpfs
  log_ok "sessions tmpfs mounted (size=$(_resolve_sessions_tmpfs_size))"
  findmnt -no SOURCE,FSTYPE,SIZE,OPTIONS --target "$SESSIONS_DIR"
}

cmd_tmpfs_down() {
  require_root
  if ! sessions_tmpfs_active; then
    log_info "sessions tmpfs not mounted; nothing to do"
    return 0
  fi
  local active
  active="$(ls "$SESSIONS_DIR" 2>/dev/null | wc -l)"
  if [[ "$active" -gt 0 ]]; then
    die "$active session(s) still under $SESSIONS_DIR; destroy them first"
  fi
  log_info "unmounting sessions tmpfs at $SESSIONS_DIR"
  umount "$SESSIONS_DIR" || die "umount $SESSIONS_DIR failed"
  log_ok "sessions tmpfs unmounted"
}

# =============================================================================
# Subcommand: list
# =============================================================================

cmd_list() {
  require_dirs
  # SCRATCH = /var/tmp/portage scratch dir (off-overlay; see
  # session_portage_tmpdir); accounts for ebuild work/temp/image trees
  # that used to be in UPPER. Operators reading old vs new lists will see
  # UPPER shrink and SCRATCH appear; the sum is roughly comparable to the
  # prior UPPER number.
  printf '%-30s  %-8s  %-10s  %-10s  %s\n' NAME MOUNTED UPPER SCRATCH CREATED
  if [[ ! -d "$SESSIONS_DIR" ]]; then return; fi
  local s name mounted upper_size scratch_size info created
  for s in "$SESSIONS_DIR"/*/; do
    [[ -d "$s" ]] || continue
    name="$(basename "$s")"
    if session_is_mounted "$name"; then mounted=yes; else mounted=no; fi
    upper_size="$(du -sh "$(session_upper "$name")" 2>/dev/null | awk '{print $1}')"
    scratch_size="$(du -sh "$(session_portage_tmpdir "$name")" 2>/dev/null | awk '{print $1}')"
    info="$s/info"
    created="-"
    [[ -f "$info" ]] && created="$(awk -F= '$1=="created"{print $2}' "$info")"
    printf '%-30s  %-8s  %-10s  %-10s  %s\n' "$name" "$mounted" "${upper_size:--}" "${scratch_size:--}" "$created"
  done
}

# =============================================================================
# Subcommand: diff
# =============================================================================

cmd_diff() {
  require_session "${1:-}"
  local name="$1" upper
  upper="$(session_upper "$name")"
  [[ -d "$upper" ]] || die "no upper layer for session '$name'"
  if [[ ! "$(ls -A "$upper" 2>/dev/null)" ]]; then
    log_info "session '$name' has no upper-layer changes"
    return 0
  fi
  log_info "files changed in session '$name' (relative to baseline):"
  ( cd "$upper" && find . -mindepth 1 -printf '%y  %p\n' )
}

# =============================================================================
# Subcommand: status
# =============================================================================

cmd_status() {
  printf 'tinderbox-ng status\n'
  printf '  TINDERBOX_ROOT       %s\n' "$TINDERBOX_ROOT"
  printf '  baseline             %s\n' "$([[ -d $BASELINE_DIR/usr ]] && echo populated || echo MISSING)"
  printf '  tree pin             %s\n' "$([[ -f $SHARED_DIR/portage-tree.commit ]] && cat "$SHARED_DIR/portage-tree.commit" || echo MISSING)"
  printf '  kb.qlf               %s\n' "$([[ -f $BASELINE_DIR$CHROOT_PORTAGE_NG/Knowledge/kb.qlf ]] && echo present || echo MISSING)"
  printf '  distfiles size       %s\n' "$(du -sh "$DISTFILES_DIR" 2>/dev/null | awk '{print $1}')"
  printf '  ccache size          %s\n' "$(du -sh "$CCACHE_DIR" 2>/dev/null | awk '{print $1}')"
  printf '  sessions             %s\n' "$(find "$SESSIONS_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)"
  if sessions_tmpfs_active; then
    local sz used avail
    read -r sz used avail < <(df -BG --output=size,used,avail "$SESSIONS_DIR" 2>/dev/null \
                              | tail -n +2 | tr -d 'G')
    printf '  sessions tmpfs       active: %sG used / %sG avail / %sG cap\n' "${used:-?}" "${avail:-?}" "${sz:-?}"
  else
    local resolved
    resolved="$(_resolve_sessions_tmpfs_size)"
    if [[ "$resolved" == "0" ]]; then
      if _tinderbox_root_on_tmpfs; then
        printf '  sessions tmpfs       inactive (auto: TINDERBOX_ROOT is tmpfs)\n'
      else
        printf '  sessions tmpfs       inactive (TINDERBOX_SESSIONS_TMPFS_SIZE=%s)\n' \
          "${TINDERBOX_SESSIONS_TMPFS_SIZE:-unset}"
      fi
    else
      printf '  sessions tmpfs       inactive (configured=%s; resolved cap=%s)\n' \
        "${TINDERBOX_SESSIONS_TMPFS_SIZE:-auto}" "$resolved"
    fi
  fi
}


# =============================================================================
# Subcommand: progress (live monitor)
# =============================================================================
#
# Continuously-updated dashboard for in-flight matrix runs (compare-matrix.sh
# writes to /srv/tinderbox-ng/reports/compare-matrix-<stamp>/results.tsv as it
# runs). Renders a progress bar with ETA, current rate, host load + RAM,
# tmpfs occupancy, and the live list of active sessions with their engine
# and age. Designed to be the "is it still going / how long left / what is
# it doing right now" command operators reach for first.
#
# Auto-detects the most recent matrix run by ctime under
# $TINDERBOX_ROOT/reports/. Pass --run DIR to pin a specific run. With no
# matrix run available it still shows host stats + session list (useful
# during interactive `enter` work).

REPORTS_DIR_DEFAULT="$TINDERBOX_ROOT/reports"

# Stale-TSV cutoff for the "presumed dead" heuristic. A run with no new
# results.tsv row in this many seconds AND no live compare-matrix process
# is treated as aborted, even when meta.txt has no finished_at line (the
# typical sign of a hard kill: SIGKILL of the driver before its trap can
# write finished_at).
TINDERBOX_PROGRESS_STALE_SECS="${TINDERBOX_PROGRESS_STALE_SECS:-1800}"

# Returns 0 if a run looks aborted/dead, 1 if it looks active.
# Three signals (any one is enough to mark aborted):
#   1. Directory name has an explicit operator marker
#      (-aborted / -partial / -killed / -stopped).
#   2. results.tsv hasn't grown in TINDERBOX_PROGRESS_STALE_SECS AND no
#      compare-matrix process is currently running on the host.
#   3. Driver log file in the parent reports/ has the same basename as
#      the run dir + .driver.log (compare-matrix.sh writes one when run
#      via the matrix harness; presence after the run dir already exists
#      and no process is alive == past run, dead now).
_progress_run_aborted() {
  local d="$1"
  local name; name="$(basename "$d")"
  case "$name" in
    *-aborted-*|*-partial-*|*-killed-*|*-stopped-*) return 0 ;;
  esac
  local tsv="$d/results.tsv"
  if [[ -f "$tsv" ]]; then
    local now mtime age
    now=$(date +%s)
    mtime=$(stat -c %Y "$tsv" 2>/dev/null || stat -f %m "$tsv" 2>/dev/null || echo "$now")
    age=$(( now - mtime ))
    if (( age > TINDERBOX_PROGRESS_STALE_SECS )); then
      # No live driver matching this run path → presumed dead. We grep for
      # the basename so a process working on a SIBLING run dir doesn't
      # falsely keep this one alive.
      if ! pgrep -af "compare-matrix" 2>/dev/null | grep -qF "$name"; then
        return 0
      fi
    fi
  fi
  return 1
}

# Find the matrix run to track. Selection priority:
#   1. Newest run that is BOTH unfinished AND not aborted/dead → "live".
#   2. Newest run with finished_at (the most recent completed run) → useful
#      for showing the just-completed report after a clean exit.
#   3. Newest run regardless of state.
# Returns "" when reports/ is empty.
#
# Implementation note: avoids GNU-only `find -printf` so the dev-box dry-run
# on macOS doesn't silently report "no run found". `ls -dt` is supported by
# both GNU and BSD coreutils and sorts by mtime newest-first.
_progress_pick_run() {
  local reports="${1:-$REPORTS_DIR_DEFAULT}"
  [[ -d "$reports" ]] || return 0
  local newest_live="" newest_finished="" newest_any="" d meta
  # Strict canonical-name match: only `compare-matrix-<14-digit-stamp>`.
  # Anything with a suffix (`.merged-into-*`, `.aborted`, `.partial-*`,
  # operator-archived siblings, etc.) MUST be excluded so the dashboard
  # doesn't follow an inert/dead dir whose mtime got bumped by an admin
  # rename or merge. Use --run DIR to override.
  shopt -s nullglob
  local -a runs=()
  while IFS= read -r d; do
    [[ -d "$d" ]] && runs+=("$d")
  done < <(ls -dt "$reports"/compare-matrix-* 2>/dev/null \
             | grep -E '/compare-matrix-[0-9]{8}T[0-9]{6}$')
  shopt -u nullglob
  for d in "${runs[@]}"; do
    meta="$d/meta.txt"
    [[ -f "$meta" ]] || continue
    [[ -z "$newest_any" ]] && newest_any="$d"
    # A run is "truly finished" only if its LAST `finished_at` marker
    # comes AFTER its LAST `resumed_at` marker. A `resumed_at` written
    # later means the run was reactivated and the prior `finished_at`
    # is stale -- treat the dir as live again. Without this guard,
    # `tinderbox-ng continue` correctly reactivates an existing run dir
    # but the dashboard keeps falling back to an older run that lacks
    # `finished_at` (because the picker still classifies the live one
    # as "finished").
    local lf lr
    lf="$(awk '$1=="finished_at"{print NR}' "$meta" 2>/dev/null | tail -n1)"
    lr="$(awk '$1=="resumed_at" {print NR}' "$meta" 2>/dev/null | tail -n1)"
    local truly_finished=0
    if [[ -n "$lf" && ( -z "$lr" || "$lf" -gt "$lr" ) ]]; then
      truly_finished=1
    fi
    if (( truly_finished )); then
      [[ -z "$newest_finished" ]] && newest_finished="$d"
    elif [[ -z "$newest_live" ]] && ! _progress_run_aborted "$d"; then
      newest_live="$d"
    fi
  done
  printf '%s' "${newest_live:-${newest_finished:-$newest_any}}"
}

# Render a unicode progress bar of width $1 filled to fraction $2 (0..1).
# Falls back to ASCII when LANG is not UTF-8 (or LC_ALL set to C).
_progress_bar() {
  local width="$1" frac="$2"
  awk -v w="$width" -v f="$frac" -v utf="${LANG:-}${LC_ALL:-}" '
    BEGIN {
      if (f < 0) f = 0; if (f > 1) f = 1
      filled = int(w * f + 0.5)
      empty  = w - filled
      if (utf ~ /UTF-?8/) { fc = "\xe2\x96\x88"; ec = "\xe2\x96\x91" }
      else                { fc = "#";            ec = "-" }
      out = "["
      for (i = 0; i < filled; i++) out = out fc
      for (i = 0; i < empty;  i++) out = out ec
      out = out "]"
      printf "%s", out
    }'
}

# Format $1 seconds as "Hh Mm Ss" (skipping zeros from the left).
_progress_hms() {
  local s="${1:-0}"
  if ! [[ "$s" =~ ^-?[0-9]+$ ]]; then printf '?'; return; fi
  if (( s < 0 )); then printf '?'; return; fi
  local h m
  h=$(( s / 3600 ))
  m=$(( (s % 3600) / 60 ))
  s=$(( s % 60 ))
  if   (( h > 0 )); then printf '%dh %dm %ds' "$h" "$m" "$s"
  elif (( m > 0 )); then printf '%dm %ds'         "$m" "$s"
  else                   printf '%ds'                  "$s"
  fi
}

# Stream a single rendered frame to stdout. Designed to be fast: avoids
# `du`, walks the sessions dir once with stat-based age, and reads
# results.tsv with `wc -l` rather than an awk pipeline.
_progress_render_frame() {
  # Render best-effort: a failing subshell (df on a missing dir, findmnt on
  # a non-Linux dev box, etc.) must never abort the dashboard. The function
  # always returns 0 so the caller's `set -e` is not tripped.
  set +e
  local run="$1" cols="$2"
  local now
  now=$(date +%s)

  # ---- Header ----
  printf '\033[1mtinderbox-ng progress\033[0m  -  refresh %ss   (q or ^C to quit)\n' \
    "${TINDERBOX_PROGRESS_INTERVAL:-2}"
  printf -- '─%.0s' $(seq 1 "$cols"); printf '\n'

  # ---- Matrix-run block ----
  if [[ -n "$run" && -d "$run" ]]; then
    local meta="$run/meta.txt"
    local tsv="$run/results.tsv"
    local total mode jobs started host kernel finished
    total="$(awk -F'\t' '$1=="package_count"{print $2}'  "$meta" 2>/dev/null)"
    mode="$(awk  -F'\t' '$1=="mode"{print $2}'           "$meta" 2>/dev/null)"
    jobs="$(awk  -F'\t' '$1=="jobs"{print $2}'           "$meta" 2>/dev/null)"
    started="$(awk -F'\t' '$1=="started_at"{print $2}'   "$meta" 2>/dev/null)"
    finished="$(awk -F'\t' '$1=="finished_at"{print $2}' "$meta" 2>/dev/null)"
    host="$(awk -F'\t' '$1=="host"{print $2}'            "$meta" 2>/dev/null)"
    kernel="$(awk -F'\t' '$1=="kernel"{print $2}'        "$meta" 2>/dev/null)"

    local done=0
    if [[ -f "$tsv" ]]; then
      done=$(( $(wc -l < "$tsv") - 1 ))
      (( done < 0 )) && done=0
    fi
    [[ -z "$total" || "$total" -le 0 ]] && total=0

    local started_epoch=0
    if [[ -n "$started" ]]; then
      # GNU date first; fall back to BSD `date -j -f` (macOS dev box) so the
      # elapsed/ETA block remains accurate during dry-runs.
      started_epoch="$(date -d "$started" +%s 2>/dev/null \
        || date -j -u -f '%Y-%m-%dT%H:%M:%SZ' "$started" +%s 2>/dev/null \
        || echo 0)"
    fi
    local elapsed=0
    if (( started_epoch > 0 )); then
      elapsed=$(( now - started_epoch ))
      (( elapsed < 0 )) && elapsed=0
    fi

    local frac=0 pct="0.0" rate_per_h=0 avg_s=0 eta=0 finishes_at="-"
    if (( total > 0 )); then
      frac=$(awk -v d="$done" -v t="$total" 'BEGIN{ printf "%.4f", (t>0 ? d/t : 0) }')
      pct=$(awk  -v d="$done" -v t="$total" 'BEGIN{ printf "%.1f",  (t>0 ? 100*d/t : 0) }')
    fi
    if (( done > 0 && elapsed > 0 )); then
      rate_per_h=$(awk -v d="$done" -v e="$elapsed" 'BEGIN{ printf "%.1f", 3600*d/e }')
      avg_s=$(awk      -v d="$done" -v e="$elapsed" 'BEGIN{ printf "%.1f", e/d }')
      if (( total > done )); then
        eta=$(awk -v r="$avg_s" -v rem=$(( total - done )) 'BEGIN{ printf "%d", r*rem }')
        finishes_at="$(date -d "@$(( now + eta ))" '+%Y-%m-%d %H:%M %Z' 2>/dev/null \
          || date -r "$(( now + eta ))" '+%Y-%m-%d %H:%M %Z' 2>/dev/null \
          || echo "?")"
      fi
    fi

    local bar_w=$(( cols - 28 ))
    (( bar_w < 10 )) && bar_w=10
    (( bar_w > 60 )) && bar_w=60

    # Banner status: green for finished, yellow for aborted/dead,
    # nothing extra for actively-running. Actively-running is implied by
    # the auto-pick selecting it; we only label the "not live" cases so
    # the operator never confuses a stale dashboard with a real one.
    local status_banner=""
    if [[ -n "$finished" ]]; then
      status_banner=$' \033[1;32m[FINISHED]\033[0m'
    elif _progress_run_aborted "$run"; then
      status_banner=$' \033[1;33m[ABORTED]\033[0m'
    fi
    printf 'Run:        %s%s\n' "$(basename "$run")" "$status_banner"
    printf '            mode=%s  jobs=%s  host=%s  kernel=%s\n' \
      "${mode:-?}" "${jobs:-?}" "${host:-?}" "${kernel:-?}"
    printf 'Started:    %s   (%s ago)\n' "${started:-?}" "$(_progress_hms "$elapsed")"
    if [[ -n "$finished" ]]; then
      printf 'Finished:   \033[32m%s\033[0m\n' "$finished"
    fi
    printf 'Progress:   '
    _progress_bar "$bar_w" "$frac"
    printf '  %d / %d  (%s%%)\n' "$done" "$total" "$pct"
    # Rate / ETA are only meaningful for an actively-running matrix.
    # Suppress them for finished and aborted runs so the dashboard doesn't
    # claim a dead run will "finish in 371h".
    if [[ -z "$finished" ]] && ! _progress_run_aborted "$run"; then
      printf 'Rate:       %s pkg/h   (avg %ss/pkg)\n' "$rate_per_h" "$avg_s"
      if (( eta > 0 )); then
        printf 'ETA:        %s   →   ~%s\n' "$(_progress_hms "$eta")" "$finishes_at"
      else
        printf 'ETA:        (waiting for first completion)\n'
      fi
    fi
  else
    printf 'Run:        \033[33m(no compare-matrix run found under %s)\033[0m\n' \
      "$REPORTS_DIR_DEFAULT"
  fi
  printf '\n'

  # ---- Host stats ----
  # Read /proc/loadavg defensively: on non-Linux dry-runs it doesn't exist
  # and `read` would leave la5/la15 unbound, tripping `set -u`.
  local la1="?" la5="?" la15="?" cores=1
  if [[ -r /proc/loadavg ]]; then
    read -r la1 la5 la15 _ < /proc/loadavg 2>/dev/null || true
  fi
  cores="$(nproc 2>/dev/null || echo 1)"
  local mem_total_kib mem_avail_kib mem_used_g="?" mem_total_g="?"
  if [[ -r /proc/meminfo ]]; then
    mem_total_kib="$(awk '/^MemTotal:/{print $2}'     /proc/meminfo 2>/dev/null || echo 0)"
    mem_avail_kib="$(awk '/^MemAvailable:/{print $2}' /proc/meminfo 2>/dev/null || echo 0)"
    mem_total_g=$(awk -v k="$mem_total_kib" 'BEGIN{ printf "%.1f", k/1024/1024 }')
    mem_used_g=$(awk  -v t="$mem_total_kib" -v a="$mem_avail_kib" \
      'BEGIN{ printf "%.1f", (t-a)/1024/1024 }')
  fi

  local load_color="\033[32m"
  if [[ "$la1" != "?" ]]; then
    awk -v l="$la1" -v c="$cores" 'BEGIN{ exit !(l > c) }'     && load_color="\033[33m"
    awk -v l="$la1" -v c="$cores" 'BEGIN{ exit !(l > c*1.5) }' && load_color="\033[31m"
  fi

  printf 'Load avg:   %b%s %s %s\033[0m   on %s cores\n' \
    "$load_color" "$la1" "$la5" "$la15" "$cores"
  printf 'RAM:        %s GB used / %s GB total\n' "$mem_used_g" "$mem_total_g"

  # tmpfs occupancy
  if sessions_tmpfs_active 2>/dev/null; then
    local tsz tused tavail
    read -r tsz tused tavail < <(df -BG --output=size,used,avail "$SESSIONS_DIR" 2>/dev/null \
                                  | tail -n +2 | tr -d 'G')
    printf 'Tmpfs:      %sG used / %sG avail / %sG cap (sessions)\n' \
      "${tused:-?}" "${tavail:-?}" "${tsz:-?}"
  fi

  # du -sBG (NOT df) so each metric reports the actual directory size
  # rather than the filesystem's total used bytes (which would show the
  # same number for distfiles + ccache when both share /srv). du is
  # warm-cache fast (<50 ms once the dentries are in the kernel cache);
  # cold path is ~0.5 s on a 25 GB distfiles tree which is acceptable for
  # a 2 s refresh loop.
  local distfiles_sz ccache_sz
  distfiles_sz="$(du -sBG "$DISTFILES_DIR" 2>/dev/null | awk '{print $1}' | tr -d 'G')"
  ccache_sz="$(   du -sBG "$CCACHE_DIR"    2>/dev/null | awk '{print $1}' | tr -d 'G')"
  printf 'Distfiles:  %sG    Ccache: %sG\n' "${distfiles_sz:-?}" "${ccache_sz:-?}"
  printf '\n'

  # ---- Realtime success / failure breakdown (matrix only) ----
  #
  # Single awk scan over results.tsv buckets every completed row by the
  # (pn_exit, em_exit) pair, plus a separate vdb-mismatch counter for
  # rows where both sides exited cleanly but installed a different number
  # of packages (typically a planner divergence we want flagged).
  #
  # Buckets:
  #   ok / ok       both engines built the target successfully
  #   ok / fail     PN-only win (PN succeeded where emerge failed)
  #   fail / ok     PN-only loss / regression (PN failed where emerge succeeded)
  #   fail / fail   both engines failed (usually environmental: no network,
  #                 missing system service, package legitimately broken)
  #   vdb mismatch  both ok but vdb_delta != "=" (planner picked a different
  #                 set of packages even though both runs completed)
  #
  # awk tolerates partial TSVs (header-only after start, growing rows under
  # mutex from the parallel matrix). Empty file is a no-op.
  if [[ -n "$run" && -f "$run/results.tsv" ]]; then
    printf '\033[1mResults so far\033[0m\n'
    awk -F'\t' '
      BEGIN {
        G="\033[32m"; R="\033[31m"; C="\033[36m"; Y="\033[33m"; D="\033[2m"; N="\033[0m"
      }
      NR == 1 { next }   # header
      {
        total++
        pn=$3; em=$4; vdb=$11
        is_ok_pn = (pn == "OK")
        is_ok_em = (em == "OK")
        if      (is_ok_pn && is_ok_em)  { okok++;     if (vdb != "=") vdb_mismatch++ }
        else if (is_ok_pn && !is_ok_em) { okfail++ }
        else if (!is_ok_pn && is_ok_em) { failok++ }
        else                            { failfail++ }
      }
      END {
        if (total == 0) {
          printf "  (no completions yet)\n"
          exit
        }
        # Rate denominators: OK/OK rate is over total; PN-only-win rate is
        # over (ok/ok + ok/fail) which is "everywhere PN succeeded";
        # regression rate is over (fail/ok + ok/ok) which is "everywhere
        # emerge succeeded". Match-rate is the headline.
        okok_pct      = (total > 0)               ? 100.0 * okok      / total : 0
        okfail_pct    = (total > 0)               ? 100.0 * okfail    / total : 0
        failok_pct    = (total > 0)               ? 100.0 * failok    / total : 0
        failfail_pct  = (total > 0)               ? 100.0 * failfail  / total : 0
        vdb_mm_pct    = (okok > 0)                ? 100.0 * vdb_mismatch / okok : 0
        printf "  Total:         %6d  packages compared\n", total
        printf "  %sok / ok%s        %6d  (%5.1f%%)   matched success\n",        G, N, okok,         okok_pct
        printf "  %sok / fail%s      %6d  (%5.1f%%)   PN-only wins (PN ok, emerge fail)\n", C, N, okfail,       okfail_pct
        printf "  %sfail / ok%s      %6d  (%5.1f%%)   regressions (PN fail, emerge ok)\n", R, N, failok,       failok_pct
        printf "  %sfail / fail%s    %6d  (%5.1f%%)   both failed (environmental)\n",      Y, N, failfail,     failfail_pct
        if (vdb_mismatch > 0) {
          printf "  %svdb mismatch%s   %6d  (%5.1f%% of ok/ok)   planner divergence\n", C, N, vdb_mismatch, vdb_mm_pct
        }
      }
    ' "$run/results.tsv"
    printf '\n'
  fi

  # ---- Active sessions ----
  #
  # State detection: each session mounts its overlay inside a *private*
  # mount + IPC namespace (`unshare --mount --ipc --propagation=private` in
  # mount_overlay_for), so from the host's mount namespace `mountpoint`
  # always reports "not mounted" — the old check rendered every session
  # as "idle". Instead, walk /proc once and find every process whose
  # /proc/<pid>/root resolves under $SESSIONS_DIR/<name>/, then derive a
  # single "what is this session doing right now" label by picking the
  # highest-priority task among its anchored processes:
  #
  #   compile (cc1/clang/rustc/ghc/gcc/g++)
  #   > build  (make/ninja/scons)
  #   > fetch  (curl/wget/aria2c)
  #   > phase  (ebuild.sh / portage helpers)
  #   > resolve (swipl)
  #   > plan    (emerge driver itself)
  #   > active  (any other anchored process)
  #   > idle    (no anchored processes — root setup or teardown)
  #
  # /proc/<pid>/root is only readable as the owning user (or root). This
  # tool's typical caller is root (chroot management), so the signal is
  # trustworthy in normal use.
  local n_sessions=0
  if [[ -d "$SESSIONS_DIR" ]]; then
    n_sessions=$(find "$SESSIONS_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
    n_sessions=$(( n_sessions + 0 ))
  fi

  declare -A sess_state sess_pcount sess_prio
  if (( n_sessions > 0 )); then
    local _sess_prefix="${SESSIONS_DIR%/}/"
    local _p _root _rest _sname _cmd _new _np _cp
    for _p in /proc/[0-9]*; do
      _root="$(readlink "$_p/root" 2>/dev/null)" || continue
      case "$_root" in
        "$_sess_prefix"*) ;;
        *) continue ;;
      esac
      _rest="${_root#$_sess_prefix}"
      _sname="${_rest%%/*}"
      sess_pcount[$_sname]=$(( ${sess_pcount[$_sname]:-0} + 1 ))
      # Suppress bash's own redirection-failure message (race: PID may exit
      # between the /proc/[0-9]* glob and this read). Wrap in a brace group
      # so `2>/dev/null` covers bash's stderr too, not just `tr`'s.
      _cmd="$({ tr '\0' ' ' <"$_p/cmdline" | head -c 200; } 2>/dev/null)"
      [[ -z "$_cmd" ]] && _cmd="$(cat "$_p/comm" 2>/dev/null)"
      # Patterns must accept both a path-prefixed binary (`/usr/bin/foo …`)
      # and the bare command name (e.g. swipl is exec'd by argv[0]="swipl"
      # under the portage-ng-dev wrapper). Trailing `\ *` requires a space
      # after the binary name so we never false-match substrings.
      case "$_cmd" in
        */cc1*|*/cc1plus*|*cc1\ *|*cc1plus\ *|*/rustc*|rustc\ *|*/ghc\ *|ghc\ *|*/gcc\ *|gcc\ *|*/g++\ *|g++\ *|*/clang\ *|clang\ *|*/clang++\ *|clang++\ *)
          _new="compile"; _np=7 ;;
        */make\ *|make\ *|*/gmake\ *|gmake\ *|*/ninja\ *|ninja\ *|*/scons\ *|scons\ *)
          _new="build"; _np=6 ;;
        */curl\ *|curl\ *|*/wget\ *|wget\ *|*/aria2c\ *|aria2c\ *)
          _new="fetch"; _np=5 ;;
        *ebuild.sh*|*ebuild-helpers*|*ebuild-ipc*)
          _new="phase"; _np=4 ;;
        */swipl\ *|swipl\ *|*portage-ng-dev*|*portage-ng.pl*)
          _new="resolve"; _np=3 ;;
        */emerge\ *|emerge\ *|*/emerge)
          _new="plan"; _np=2 ;;
        *)
          _new="active"; _np=1 ;;
      esac
      _cp="${sess_prio[$_sname]:-0}"
      if (( _np > _cp )); then
        sess_state[$_sname]="$_new"
        sess_prio[$_sname]="$_np"
      fi
    done
  fi

  # Split the count into "live" (has at least one anchored process) and
  # "done" (session dir exists but no anchored process). A done session
  # has three legitimate causes:
  #   - paired in compare-matrix: the faster engine finished and is
  #     waiting for its sibling (compare destroys both in lockstep)
  #   - kept by `compare --keep` for post-mortem investigation
  #   - mid-teardown: cleanup helpers are running but processes have
  #     already exited
  # In all three cases the chroot is no longer doing work, so it should
  # NOT count as "active". Without this split, a forgotten `--keep`
  # session zombies in the "Active" headline indefinitely (e.g. the
  # ghc-inv investigation sessions sat for 7+ hours after the build
  # failed, looking misleadingly like the matrix had stuck workers).
  local n_live=0 n_done=0
  if (( n_sessions > 0 )); then
    local _s _n
    while IFS= read -r _s; do
      _n="$(basename "$_s")"
      if (( ${sess_pcount[$_n]:-0} > 0 )); then
        n_live=$(( n_live + 1 ))
      else
        n_done=$(( n_done + 1 ))
      fi
    done < <(find "$SESSIONS_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)
  fi
  if (( n_done > 0 )); then
    printf '\033[1mActive sessions (%d live, %d done)\033[0m\n' "$n_live" "$n_done"
  else
    printf '\033[1mActive sessions (%d)\033[0m\n' "$n_live"
  fi
  if (( n_sessions > 0 )); then
    printf '  %-44s  %-10s  %-9s  %4s  %s\n' NAME ENGINE STATE PROC AGE
    local s name engine state pcount age_s age_str ctime
    while IFS= read -r s; do
      [[ -d "$s" ]] || continue
      name="$(basename "$s")"
      case "$name" in
        pkg-cmp-portage-ng-*) engine="portage-ng" ;;
        pkg-cmp-emerge-*)     engine="emerge"    ;;
        pkg-cmp-*)            engine="compare"   ;;
        selftest-*)           engine="selftest"  ;;
        *)                    engine="user"      ;;
      esac
      pcount="${sess_pcount[$name]:-0}"
      # 0-proc sessions are reported as `done` regardless of whether the
      # cause is paired-wait, --keep, or mid-teardown — the operator
      # only needs to know "this chroot is no longer doing work" and
      # the session column count already separates live vs done. Live
      # sessions get their work-class label from sess_state above.
      if (( pcount > 0 )); then
        state="${sess_state[$name]:-active}"
      else
        state="done"
      fi
      ctime="$(stat -c %Y "$s" 2>/dev/null || stat -f %m "$s" 2>/dev/null || echo "$now")"
      age_s=$(( now - ctime ))
      age_str="$(_progress_hms "$age_s")"
      printf '  %-44s  %-10s  %-9s  %4d  %s\n' \
        "${name:0:44}" "$engine" "$state" "$pcount" "$age_str"
    done < <(find "$SESSIONS_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)
  fi
  printf '\n'

  # ---- Recent completions (matrix only) ----
  # compare-matrix emits literal "OK" / "FAIL(N)" / "?" in the pn_exit/em_exit
  # columns (never numeric exit codes). Colour: green=ok, red=fail, dim=?.
  # Pad after the ANSI reset so visible width stays consistent regardless of
  # the (invisible) escape bytes injected.
  if [[ -n "$run" && -f "$run/results.tsv" ]]; then
    printf '\033[1mRecent completions (last 5)\033[0m\n'
    printf '  %-40s  %-7s  %-7s  %-6s  %s\n' TARGET PN EM VDB SECS
    tail -n 5 "$run/results.tsv" | awk -F'\t' '
      BEGIN { G="\033[32m"; R="\033[31m"; D="\033[2m"; N="\033[0m"; PAD="          " }
      function sym(s,    label,col,vis) {
        if      (s == "OK")            { label="ok";   col=G }
        else if (s ~ /^FAIL/)          { label="fail"; col=R }
        else if (s == "" || s == "?")  { label="?";    col=D }
        else                            { label=s;     col="" }
        vis = 7 - length(label); if (vis < 1) vis = 1
        return col label N substr(PAD, 1, vis)
      }
      {
        target=$1; pn_exit=$3; em_exit=$4
        vdb_delta=$11; secs=$12
        printf "  %-40s  %s  %s  %-6s  %ss\n", target, sym(pn_exit), sym(em_exit), vdb_delta, secs
      }'
  fi
  return 0
}

cmd_progress() {
  local run="" pinned_run="" interval="${TINDERBOX_PROGRESS_INTERVAL:-2}" once=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run)        pinned_run="$2"; shift 2 ;;
      --run=*)      pinned_run="${1#--run=}"; shift ;;
      --interval)   interval="$2"; shift 2 ;;
      --interval=*) interval="${1#--interval=}"; shift ;;
      --once|-1)    once=1; shift ;;
      -h|--help)
        cat <<'PROGRESS_HELP'
tinderbox-ng progress [--once] [--interval N] [--run DIR]

Continuously-updated dashboard. Auto-detects the most recent
compare-matrix run under $TINDERBOX_ROOT/reports/ (prefers unfinished).

Options:
  --once, -1            Print one frame and exit (for scripts / SSH dumps).
  --interval N          Refresh every N seconds (default 2; env:
                        TINDERBOX_PROGRESS_INTERVAL).
  --run DIR             Track this specific run directory instead of
                        autodetecting.
PROGRESS_HELP
        return 0 ;;
      *)            die "unknown progress flag: $1" ;;
    esac
  done

  [[ "$interval" =~ ^[0-9]+$ ]] || die "--interval must be a positive integer"
  (( interval >= 1 )) || interval=1
  export TINDERBOX_PROGRESS_INTERVAL="$interval"

  if [[ -n "$pinned_run" ]]; then
    run="$pinned_run"
  else
    run="$(_progress_pick_run "$REPORTS_DIR_DEFAULT")"
  fi

  # Single-shot mode: render and return. Used by scripts / non-tty clients.
  if (( once )) || ! [[ -t 1 ]]; then
    local cols="${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}"
    _progress_render_frame "$run" "$cols"
    return 0
  fi

  # Interactive loop. We use the alternate screen buffer so the operator's
  # scrollback survives, and clear+home each frame for a stable viewport.
  trap 'printf "\033[?25h\033[?1049l\n"; exit 0' INT TERM EXIT
  printf '\033[?1049h\033[?25l'

  # Flicker-free redraw strategy:
  #   1. Build the entire frame in memory (subshell capture).
  #   2. Move cursor home (\033[H), do NOT use \033[2J: a full clear blanks
  #      the whole screen between frames, which is the visible flicker.
  #   3. Insert \033[K (clear-to-end-of-line) before every newline so any
  #      leftover characters from a previous longer line are wiped on the
  #      same line they appear, atomically.
  #   4. Trail with \033[J (clear from cursor to end of screen) so old lines
  #      that no longer fit in the new frame disappear.
  # Result: the terminal sees one contiguous write per frame; the operator
  # sees content updating in place rather than the screen blanking + redrawing.
  while :; do
    local cols
    cols="$(tput cols 2>/dev/null || echo 100)"
    # Re-pick the run each tick so we follow new compare-matrix runs that
    # start mid-monitor (e.g. after `tinderbox-ng continue`). Skip the
    # re-pick if the user explicitly pinned a run with --run, otherwise
    # we'd stomp their choice.
    if [[ -z "$pinned_run" ]]; then
      local newpick
      newpick="$(_progress_pick_run "$REPORTS_DIR_DEFAULT")"
      if [[ -n "$newpick" && "$newpick" != "$run" ]]; then
        run="$newpick"
      fi
    fi
    [[ -n "$run" && ! -d "$run" ]] && run=""
    local frame
    frame="$(_progress_render_frame "$run" "$cols")"
    printf '\033[H%s\033[K\n\033[J' "${frame//$'\n'/$'\033[K\n'}"
    # Read with a timeout so the loop refreshes even when no key is pressed.
    # 'q' / 'Q' / Enter quit. Anything else triggers an immediate refresh.
    local key=""
    if read -r -t "$interval" -n 1 key; then
      case "$key" in q|Q|'') break ;; esac
    fi
  done
}

# =============================================================================
# Subcommand: analyze
# =============================================================================
#
# Run plan-correctness analysis on a matrix run (or any directory of
# compare-<label>-<stamp>/ logdirs). Wraps share/tinderbox-ng/compare-merge-
# emerge.py: feeds it a transient symlink tree where <label>.merge points at
# each pair's portage-ng.plan.log and <label>.emerge points at the emerge
# .plan.log, then captures the JSON + stdout summary into the source dir.
#
# Inputs (in priority order):
#   --run DIR     matrix run dir (default: most-recent compare-matrix-*
#                 under $REPORTS_DIR_DEFAULT). Per-pkg compare logdirs are
#                 discovered from each <label>.log wrapper file's "logs:"
#                 line.
#   --logdir DIR  treat DIR as a flat container of compare-*-<stamp>/
#                 subdirs and pair every one of them. Use this for ad-hoc
#                 sets, e.g. --logdir /srv/tinderbox-ng/logs to analyze
#                 every compare ever run.
#
# Output (default):
#   <source>/analysis.json   full JSON metrics dump
#   <source>/analysis.txt    captured stdout summary
#
# The analyzer is platform-agnostic Python 3 (stdlib only). It runs on
# the host outside any chroot — it just reads files.
#
# Pass-throughs to the analyzer:
#   --jobs N              parallel workers (default: nproc/2)
#   --md5-cache DIR       enable dep-aware metrics (DepConc%, Viol%)
#                         using a Portage md5-cache tree
#   --target-regex RE     restrict to pairs whose label matches
#   --full-lists          include full per-pair missing/extra lists in JSON

cmd_analyze() {
  require_dirs

  local pinned_run="" alt_logdir="" out_path="" jobs="" md5_cache="" target_regex="" full_lists=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run)            pinned_run="$2"; shift 2 ;;
      --run=*)          pinned_run="${1#--run=}"; shift ;;
      --logdir)         alt_logdir="$2"; shift 2 ;;
      --logdir=*)       alt_logdir="${1#--logdir=}"; shift ;;
      --out)            out_path="$2"; shift 2 ;;
      --out=*)          out_path="${1#--out=}"; shift ;;
      --jobs|-j)        jobs="$2"; shift 2 ;;
      --jobs=*)         jobs="${1#--jobs=}"; shift ;;
      --md5-cache)      md5_cache="$2"; shift 2 ;;
      --md5-cache=*)    md5_cache="${1#--md5-cache=}"; shift ;;
      --target-regex)   target_regex="$2"; shift 2 ;;
      --target-regex=*) target_regex="${1#--target-regex=}"; shift ;;
      --full-lists)     full_lists=1; shift ;;
      -h|--help)
        cat <<'ANALYZE_HELP'
tinderbox-ng analyze [--run DIR | --logdir DIR] [--out FILE]
                     [--jobs N] [--md5-cache DIR] [--target-regex RE]
                     [--full-lists]

Run plan-correctness analysis on the per-package portage-ng/emerge plan
logs produced by `tinderbox-ng compare`. Computes Jaccard set agreement
(CN / CN+V / CN+V+U), Kendall-tau and Spearman ordering metrics,
optional dependency-aware concordance + violation rate (with
--md5-cache), domain assumptions, blockers, cycle breaks, install-only
cycle breaks, download set agreement, and timing aggregates.

Sources (mutually exclusive):
  --run DIR        Matrix run dir (compare-matrix-<stamp>/). Default:
                   most-recent under $REPORTS_DIR_DEFAULT. Per-package
                   compare logdirs are followed from each <label>.log
                   wrapper file.
  --logdir DIR     Flat container of compare-<label>-<stamp>/ subdirs.
                   Pairs every subdir found.

Output (default <source>/analysis.{json,txt}):
  --out FILE       JSON output path. The stdout summary is teed next to
                   it as <basename>.txt.

Pass-throughs to share/tinderbox-ng/compare-merge-emerge.py:
  --jobs N
  --md5-cache DIR
  --target-regex RE
  --full-lists
ANALYZE_HELP
        return 0 ;;
      *) die "analyze: unknown flag $1" ;;
    esac
  done

  if [[ -n "$pinned_run" && -n "$alt_logdir" ]]; then
    die "analyze: --run and --logdir are mutually exclusive"
  fi

  # Resolve the analyzer script. LIBEXEC_DIR is the canonical install path
  # (libexec/tinderbox-ng/ relative to the install prefix);
  # TINDERBOX_COMPARE_ANALYZER overrides for development/forking.
  local analyzer="${TINDERBOX_COMPARE_ANALYZER:-$LIBEXEC_DIR/compare-merge-emerge.py}"
  [[ -f "$analyzer" ]] || die "analyzer script not found: $analyzer"
  command -v python3 >/dev/null 2>&1 || die "python3 not found in PATH"

  local source_dir="" source_kind=""
  if [[ -n "$alt_logdir" ]]; then
    [[ -d "$alt_logdir" ]] || die "logdir not found: $alt_logdir"
    source_dir="$alt_logdir"; source_kind="logdir"
  else
    local reports_dir="${REPORTS_DIR_DEFAULT:-$TINDERBOX_ROOT/reports}"
    local run="$pinned_run"
    if [[ -z "$run" ]]; then
      run="$(find "$reports_dir" -maxdepth 1 -mindepth 1 -type d \
                  -regextype posix-extended \
                  -regex ".*/compare-matrix-[0-9]{8}T[0-9]{6}" \
                  -printf '%T@\t%p\n' 2>/dev/null \
              | sort -rn | head -n1 | cut -f2-)"
      [[ -n "$run" ]] || die "no compare-matrix-<stamp> run found under $reports_dir; use --run or --logdir"
      log_info "auto-detected run: $(basename "$run")"
    fi
    [[ -d "$run" ]] || die "run dir not found: $run"
    source_dir="$run"; source_kind="run"
  fi

  out_path="${out_path:-$source_dir/analysis.json}"
  local out_txt="${out_path%.json}.txt"

  # Build the symlink tree the analyzer expects: pairs of <label>.merge
  # and <label>.emerge files in any directory layout. We pair by the
  # presence of {portage-ng,emerge}.plan.log inside each compare logdir.
  local work_dir
  work_dir="$(mktemp -d)" || die "mktemp failed"
  # shellcheck disable=SC2064
  trap "rm -rf '$work_dir'" RETURN

  local pair_count=0 skipped=0
  local enumerate_logdirs
  if [[ "$source_kind" == "run" ]]; then
    # In a matrix run the per-package wrapper log is <label>.log; its
    # second non-blank line contains "running both engines in parallel
    # (logs: <abs_path>)". That path is the per-package compare logdir.
    local wrapper
    while IFS= read -r -d '' wrapper; do
      local logdir
      logdir="$(grep -m1 -oE '/srv/tinderbox-ng/logs/compare-[^ )]+' "$wrapper" 2>/dev/null || true)"
      [[ -n "$logdir" && -d "$logdir" ]] || { skipped=$((skipped+1)); continue; }
      local label
      label="$(basename "$wrapper" .log)"
      _analyze_link_pair "$label" "$logdir" "$work_dir" \
        && pair_count=$((pair_count+1)) \
        || skipped=$((skipped+1))
    done < <(find "$source_dir" -maxdepth 1 -mindepth 1 -type f -name '*.log' \
                  ! -name 'all-packages-driver*.log' -print0 2>/dev/null)
  else
    # --logdir: walk for compare-*-<stamp>/ subdirs directly.
    local logdir
    while IFS= read -r -d '' logdir; do
      local label
      label="$(basename "$logdir")"
      label="${label#compare-}"
      label="${label%-[0-9]*T[0-9]*}"
      _analyze_link_pair "$label" "$logdir" "$work_dir" \
        && pair_count=$((pair_count+1)) \
        || skipped=$((skipped+1))
    done < <(find "$source_dir" -maxdepth 1 -mindepth 1 -type d -name 'compare-*' -print0 2>/dev/null)
  fi

  if (( pair_count == 0 )); then
    die "no .plan.log pairs found under $source_dir (skipped: $skipped)"
  fi
  log_info "analyzing $pair_count pair(s) (skipped: $skipped)"

  local args=("$analyzer" --root "$work_dir" --out "$out_path")
  [[ -n "$jobs"         ]] && args+=(--jobs "$jobs")
  [[ -n "$md5_cache"    ]] && args+=(--md5-cache "$md5_cache")
  [[ -n "$target_regex" ]] && args+=(--target-regex "$target_regex")
  (( full_lists ))         && args+=(--full-lists)

  log_info "→ python3 $(basename "$analyzer") --root <tmp> --out $out_path"
  install -d "$(dirname "$out_path")"

  # Capture stdout to <out_path>.txt for archival; mirror to terminal.
  if python3 "${args[@]}" 2>&1 | tee "$out_txt"; then
    local rc=${PIPESTATUS[0]}
    if (( rc == 0 )); then
      log_ok "analysis complete"
      log_info "  json: $out_path"
      log_info "  text: $out_txt"
      return 0
    fi
    return "$rc"
  fi
  return 1
}

# Internal: link a single compare logdir's plan logs into the analyzer
# work_dir as <label>.merge / <label>.emerge. Returns 1 if either plan
# log is missing.
_analyze_link_pair() {
  local label="$1" logdir="$2" work="$3"
  local pn="$logdir/portage-ng.plan.log"
  local em="$logdir/emerge.plan.log"
  [[ -f "$pn" && -f "$em" ]] || return 1
  ln -snf "$pn" "$work/${label}.merge"  || return 1
  ln -snf "$em" "$work/${label}.emerge" || return 1
  return 0
}

# =============================================================================
# tinderbox-ng phase-stats:
#   consolidate per-session phase_stats.pl files into a master forecasting file
# =============================================================================
#
# Each `tinderbox-ng compare --build` session has portage-ng emit
# Knowledge/phase_stats.pl with one phase_bytes/3 + phase_seconds/3 fact per
# (Entry, Phase). cmd_compare salvages it into the per-package compare logdir.
# Across a manifest (a matrix run, or any directory tree containing many such
# logdirs) we therefore have N independent observations of every (Entry,
# Phase) pair. This subcommand walks the source tree, aggregates those
# observations with a configurable function (default median), and writes a
# single master phase_stats.pl that can be dropped into a future portage-ng
# instance as Knowledge/phase_stats.pl to seed its forecasting tables (see
# ebuild_exec:load_phase_stats/0 and ebuild_exec:expected_phase_stats/4 in
# the portage-ng source).
#
# Inputs (mutually exclusive; default: most-recent compare-matrix-* run):
#   --run DIR     matrix run dir, e.g. compare-matrix-<stamp>/.
#   --logdir DIR  flat container of compare-<label>-<stamp>/ subdirs.
#   --src DIR     arbitrary directory tree to walk for phase_stats.pl files
#                 (escape hatch for ad-hoc consolidation).
#
# Output (default <source>/phase_stats.pl):
#   --out FILE    explicit master file path.
#
# Aggregation:
#   --aggregator NAME       median (default) | mean | max | p75 | p90.
#   --min-observations N    drop buckets with fewer than N samples.
#
# Pass-through:
#   --exclude-glob PATTERN  fnmatch pattern (matched against absolute path)
#                           to skip during the input scan. Repeatable.

cmd_phase_stats() {
  require_dirs

  local pinned_run="" alt_logdir="" alt_src="" out_path=""
  local aggregator="" min_obs=""
  local -a excludes=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run)              pinned_run="$2"; shift 2 ;;
      --run=*)            pinned_run="${1#--run=}"; shift ;;
      --logdir)           alt_logdir="$2"; shift 2 ;;
      --logdir=*)         alt_logdir="${1#--logdir=}"; shift ;;
      --src)              alt_src="$2"; shift 2 ;;
      --src=*)            alt_src="${1#--src=}"; shift ;;
      --out)              out_path="$2"; shift 2 ;;
      --out=*)            out_path="${1#--out=}"; shift ;;
      --aggregator)       aggregator="$2"; shift 2 ;;
      --aggregator=*)     aggregator="${1#--aggregator=}"; shift ;;
      --min-observations) min_obs="$2"; shift 2 ;;
      --min-observations=*) min_obs="${1#--min-observations=}"; shift ;;
      --exclude-glob)     excludes+=("$2"); shift 2 ;;
      --exclude-glob=*)   excludes+=("${1#--exclude-glob=}"); shift ;;
      -h|--help)
        cat <<'PHASE_STATS_HELP'
tinderbox-ng phase-stats [--run DIR | --logdir DIR | --src DIR] [--out FILE]
                         [--aggregator median|mean|max|p75|p90]
                         [--min-observations N]
                         [--exclude-glob PATTERN ...]

Consolidate the per-session phase_stats.pl files that `tinderbox-ng
compare --build` salvages into each compare session's log directory
(<logdir>/phase_stats.pl) into a single master forecasting file that
portage-ng can load as Knowledge/phase_stats.pl. Aggregates every
(Entry, Phase) observation across all sessions with a configurable
function (default: median).

Sources (mutually exclusive):
  --run DIR        Matrix run dir (compare-matrix-<stamp>/). Default:
                   most-recent under $REPORTS_DIR_DEFAULT. The wrapper
                   first looks under the run dir; when no
                   phase_stats.pl files are found there it falls back
                   to scanning $LOGS_DIR (where the per-session
                   compare logdirs actually live).
  --logdir DIR     Flat container of compare-<label>-<stamp>/ subdirs
                   (e.g. /srv/tinderbox-ng/logs).
  --src DIR        Arbitrary directory tree -- escape hatch for
                   ad-hoc consolidation across machines, archives,
                   etc. Walked recursively for files literally named
                   phase_stats.pl.

Output (default <source>/phase_stats.pl):
  --out FILE       Master file path. Drop in as the next portage-ng
                   instance's Knowledge/phase_stats.pl.

Aggregation:
  --aggregator     median (default; robust against cold-cache outliers)
                   | mean | max (worst-case envelope) | p75 | p90.
  --min-observations N
                   Drop (Entry, Phase) buckets with fewer than N
                   observations (default: 1, keep singletons).

Other:
  --exclude-glob PATTERN
                   fnmatch pattern matched against the absolute path of
                   each candidate input file. Repeatable.

The consolidator is platform-agnostic Python 3 (stdlib only).
PHASE_STATS_HELP
        return 0 ;;
      *) die "phase-stats: unknown flag $1" ;;
    esac
  done

  local set_count=0
  [[ -n "$pinned_run" ]] && set_count=$((set_count+1))
  [[ -n "$alt_logdir" ]] && set_count=$((set_count+1))
  [[ -n "$alt_src"    ]] && set_count=$((set_count+1))
  if (( set_count > 1 )); then
    die "phase-stats: --run, --logdir and --src are mutually exclusive"
  fi

  local consolidator="${TINDERBOX_PHASE_STATS_CONSOLIDATOR:-$LIBEXEC_DIR/consolidate-phase-stats.py}"
  [[ -f "$consolidator" ]] || die "consolidator script not found: $consolidator"
  command -v python3 >/dev/null 2>&1 || die "python3 not found in PATH"

  local source_dir=""
  if [[ -n "$alt_src" ]]; then
    [[ -d "$alt_src" ]] || die "src not found: $alt_src"
    source_dir="$alt_src"
  elif [[ -n "$alt_logdir" ]]; then
    [[ -d "$alt_logdir" ]] || die "logdir not found: $alt_logdir"
    source_dir="$alt_logdir"
  else
    local reports_dir="${REPORTS_DIR_DEFAULT:-$TINDERBOX_ROOT/reports}"
    local run="$pinned_run"
    if [[ -z "$run" ]]; then
      run="$(find "$reports_dir" -maxdepth 1 -mindepth 1 -type d \
                  -regextype posix-extended \
                  -regex ".*/compare-matrix-[0-9]{8}T[0-9]{6}" \
                  -printf '%T@\t%p\n' 2>/dev/null \
              | sort -rn | head -n1 | cut -f2-)"
      [[ -n "$run" ]] || die "no compare-matrix-<stamp> run found under $reports_dir; use --run, --logdir or --src"
      log_info "auto-detected run: $(basename "$run")"
    fi
    [[ -d "$run" ]] || die "run dir not found: $run"
    source_dir="$run"

    # For matrix runs the per-package phase_stats.pl files live under
    # /srv/tinderbox-ng/logs/compare-<label>-<stamp>/, NOT under the
    # report dir itself. Switch the walk root to the logs dir but keep
    # the report dir as the default output destination so the master
    # file ships with the run's analysis artefacts.
    if ! find "$source_dir" -maxdepth 4 -type f -name 'phase_stats.pl' \
           -print -quit 2>/dev/null | grep -q .; then
      local logs_dir="${LOGS_DIR:-$TINDERBOX_ROOT/logs}"
      if [[ -d "$logs_dir" ]]; then
        log_info "no phase_stats.pl under run dir; scanning $logs_dir instead"
        source_dir="$logs_dir"
      fi
    fi
  fi

  if [[ -z "$out_path" ]]; then
    if [[ -n "$pinned_run" || ( -z "$alt_logdir" && -z "$alt_src" ) ]]; then
      # Default for runs: place the master file alongside analysis.{json,txt}.
      local reports_dir="${REPORTS_DIR_DEFAULT:-$TINDERBOX_ROOT/reports}"
      local run="${pinned_run:-$(find "$reports_dir" -maxdepth 1 -mindepth 1 -type d \
                  -regextype posix-extended \
                  -regex ".*/compare-matrix-[0-9]{8}T[0-9]{6}" \
                  -printf '%T@\t%p\n' 2>/dev/null \
              | sort -rn | head -n1 | cut -f2-)}"
      out_path="$run/phase_stats.pl"
    else
      out_path="$source_dir/phase_stats.pl"
    fi
  fi

  local args=("$consolidator" --src "$source_dir" --out "$out_path")
  [[ -n "$aggregator" ]] && args+=(--aggregator "$aggregator")
  [[ -n "$min_obs"    ]] && args+=(--min-observations "$min_obs")
  local pat
  for pat in "${excludes[@]}"; do
    args+=(--exclude-glob "$pat")
  done

  log_info "→ python3 $(basename "$consolidator") --src $source_dir --out $out_path"
  install -d "$(dirname "$out_path")"

  if python3 "${args[@]}"; then
    log_ok "master phase_stats.pl written"
    log_info "  master: $out_path"
    return 0
  fi
  return 1
}

# =============================================================================
# tinderbox-ng extract-timing:
#   per-engine, per-phase wall-clock timing across one or many compare sessions
# =============================================================================
#
# `tinderbox-ng compare` writes a <log>.timing file alongside every
# <engine>.<phase>.log it produces (see _compare_run_pass) with
# started/ended/wall_time_ms/rc fields. This subcommand walks one or
# many compare session directories, reads those companion files (with
# a log mtime/ctime fallback for older sessions that predate
# _compare_run_pass), optionally merges in the session's phase_stats.pl,
# and writes a consolidated JSON report comparing portage-ng to emerge.
#
# Inputs (mutually exclusive; default: most-recent compare-matrix-* run):
#   --run DIR      matrix run dir, e.g. compare-matrix-<stamp>/. Each
#                  per-package wrapper log inside it embeds the absolute
#                  path of its compare session dir; we follow those.
#   --logdir DIR   flat container of compare-<label>-<stamp>/ subdirs
#                  (e.g. /srv/tinderbox-ng/logs).
#   --src DIR      same as --logdir; provided for API symmetry with
#                  `analyze` and `phase-stats`.
#   --session DIR  a single compare-<label>-<stamp>/ directory.
#
# Output (default <source>/timing.json):
#   --out FILE     explicit JSON output path. Sessions index by cpv when
#                  recoverable, else by label, else by session dirname.
#
# The extractor is platform-agnostic Python 3 (stdlib only).

cmd_extract_timing() {
  require_dirs

  local pinned_run="" alt_logdir="" alt_src="" alt_session="" out_path="" quiet=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run)         pinned_run="$2"; shift 2 ;;
      --run=*)       pinned_run="${1#--run=}"; shift ;;
      --logdir)      alt_logdir="$2"; shift 2 ;;
      --logdir=*)    alt_logdir="${1#--logdir=}"; shift ;;
      --src)         alt_src="$2"; shift 2 ;;
      --src=*)       alt_src="${1#--src=}"; shift ;;
      --session)     alt_session="$2"; shift 2 ;;
      --session=*)   alt_session="${1#--session=}"; shift ;;
      --out)         out_path="$2"; shift 2 ;;
      --out=*)       out_path="${1#--out=}"; shift ;;
      --quiet)       quiet=1; shift ;;
      -h|--help)
        cat <<'EXTRACT_TIMING_HELP'
tinderbox-ng extract-timing [--run DIR | --logdir DIR | --src DIR | --session DIR]
                            [--out FILE] [--quiet]

Extract per-engine, per-phase wall-clock timing from `tinderbox-ng compare`
session log directories and emit a consolidated JSON report comparing
portage-ng to emerge across one or many sessions. Used to track
portage-ng's resolver and build performance against the emerge baseline.

Sources (mutually exclusive):
  --run DIR        Matrix run dir (compare-matrix-<stamp>/). Default:
                   most-recent under $REPORTS_DIR_DEFAULT. Per-package
                   compare logdirs are followed from each <label>.log
                   wrapper file.
  --logdir DIR     Flat container of compare-<label>-<stamp>/ subdirs.
  --src DIR        Same as --logdir (symmetry with `analyze` /
                   `phase-stats`).
  --session DIR    A single compare session directory.

Output (default <source>/timing.json):
  --out FILE       JSON output path.

Each session entry contains: started/ended/wall_time_ms/rc per pass
(portage_ng_plan, portage_ng_build, emerge_plan, emerge_build), pn/em
ratios, recovered cpv (when available), and per-phase totals from
phase_stats.pl when present. Summary block aggregates avg/p50/p95/max
per pass plus head-to-head wins.

Older sessions (before per-pass .timing files were written) reconstruct
wall time from each log file's ctime/mtime delta and are flagged with
"mtime_estimated": true.

The extractor is platform-agnostic Python 3 (stdlib only).
EXTRACT_TIMING_HELP
        return 0 ;;
      *) die "extract-timing: unknown flag $1" ;;
    esac
  done

  local set_count=0
  [[ -n "$pinned_run"  ]] && set_count=$((set_count+1))
  [[ -n "$alt_logdir"  ]] && set_count=$((set_count+1))
  [[ -n "$alt_src"     ]] && set_count=$((set_count+1))
  [[ -n "$alt_session" ]] && set_count=$((set_count+1))
  if (( set_count > 1 )); then
    die "extract-timing: --run, --logdir, --src and --session are mutually exclusive"
  fi

  local extractor="${TINDERBOX_TIMING_EXTRACTOR:-$LIBEXEC_DIR/extract-timing.py}"
  [[ -f "$extractor" ]] || die "timing extractor not found: $extractor"
  command -v python3 >/dev/null 2>&1 || die "python3 not found in PATH"

  # Resolve source + default output path. The auto-detected default
  # mirrors phase-stats: report files ride alongside each matrix run's
  # analysis artefacts (analysis.json, phase_stats.pl).
  local source_kind="" source_arg=""
  if [[ -n "$alt_session" ]]; then
    [[ -d "$alt_session" ]] || die "session dir not found: $alt_session"
    source_kind="--session"
    source_arg="$alt_session"
  elif [[ -n "$alt_src" ]]; then
    [[ -d "$alt_src" ]] || die "src not found: $alt_src"
    source_kind="--src"
    source_arg="$alt_src"
  elif [[ -n "$alt_logdir" ]]; then
    [[ -d "$alt_logdir" ]] || die "logdir not found: $alt_logdir"
    source_kind="--logdir"
    source_arg="$alt_logdir"
  else
    local reports_dir="${REPORTS_DIR_DEFAULT:-$TINDERBOX_ROOT/reports}"
    local run="$pinned_run"
    if [[ -z "$run" ]]; then
      run="$(find "$reports_dir" -maxdepth 1 -mindepth 1 -type d \
                  -regextype posix-extended \
                  -regex ".*/compare-matrix-[0-9]{8}T[0-9]{6}" \
                  -printf '%T@\t%p\n' 2>/dev/null \
              | sort -rn | head -n1 | cut -f2-)"
      [[ -n "$run" ]] || die "no compare-matrix-<stamp> run found under $reports_dir; use --run, --logdir, --src or --session"
      log_info "auto-detected run: $(basename "$run")"
    fi
    [[ -d "$run" ]] || die "run dir not found: $run"
    source_kind="--run"
    source_arg="$run"
  fi

  if [[ -z "$out_path" ]]; then
    case "$source_kind" in
      --run)     out_path="$source_arg/timing.json" ;;
      --session) out_path="$source_arg/timing.json" ;;
      *)         out_path="$source_arg/timing.json" ;;
    esac
  fi

  local args=("$extractor" "$source_kind" "$source_arg" --out "$out_path")
  (( quiet )) && args+=(--quiet)

  log_info "→ python3 $(basename "$extractor") $source_kind $source_arg --out $out_path"
  install -d "$(dirname "$out_path")"

  if python3 "${args[@]}"; then
    log_ok "timing report written"
    log_info "  json: $out_path"
    return 0
  fi
  return 1
}

# =============================================================================
# Internal: chroot the baseline directly (bootstrap-time only)
# =============================================================================
#
# Used during bootstrap and refresh-kb. Re-execs through the __ns-helper so
# all mounts live in a private mount namespace and disappear automatically on
# exit. With --tree-rw, binds the tree rw (sync needs to write to .git);
# otherwise binds it ro to match session semantics.

in_baseline_chroot() {
  local tree_mode=ro
  if [[ "${1:-}" == "--tree-rw" ]]; then
    tree_mode=rw
    shift
  fi
  local ns_mode="baseline-${tree_mode}"
  _unshare_ns "$0" __ns-helper "$ns_mode" "$@"
}

# Mount the bare minimum onto the baseline. Must run inside an unshared
# mount namespace (called via __ns-helper).
_ns_baseline_mount() {
  local mode="$1"   # ro | rw
  local M="$BASELINE_DIR"

  install -d "$M/dev" "$M/proc" "$M/sys" "$M/run" \
             "$M$CHROOT_TREE_PATH" "$M$CHROOT_DISTFILES_PATH"

  mount --make-rprivate / 2>/dev/null || true

  # Fresh /dev in this namespace - no link to host /dev
  _mount_quiet -t devtmpfs -o mode=0755,size=10M devtmpfs "$M/dev"
  install -d "$M/dev/pts" "$M/dev/shm"
  _mount_quiet -t devpts -o newinstance,ptmxmode=0620,gid=5 devpts "$M/dev/pts"
  _mount_quiet -t tmpfs  -o mode=1777 tmpfs "$M/dev/shm"

  _ns_blackhole_dev_log "$M"

  _mount_quiet -t proc  proc  "$M/proc"
  _mount_quiet -t sysfs sysfs "$M/sys"
  _mount_quiet -t tmpfs -o nosuid,nodev,mode=755,size=128M tmpfs "$M/run"

  _mount_quiet --bind "$TREE_DIR" "$M$CHROOT_TREE_PATH"
  if [[ "$mode" == "ro" ]]; then
    mount -o remount,bind,ro "$M$CHROOT_TREE_PATH"
  fi

  _mount_quiet --bind "$DISTFILES_DIR" "$M$CHROOT_DISTFILES_PATH"

  # Bind the shared binpkgs cache so portage-ng's `--sync` (run via refresh-kb
  # and bootstrap_install_kb_qlf) can read the on-disk Packages index when it
  # builds kb.qlf. Without this bind, refresh-kb logs
  #   No Packages index at /var/cache/binpkgs/Packages -- registering empty
  #   binpkg repository.
  # and the resulting kb.qlf has zero binpkg variants, which makes the
  # planner blind to pre-existing binpkgs every time the kb is regenerated.
  # Mirrors _ns_session_mount's binpkgs bind so the in-chroot path is the
  # same canonical /var/cache/binpkgs in both contexts.
  if [[ -d "$BINPKGS_DIR" ]]; then
    install -d "$M$CHROOT_BINPKGS_PATH"
    _mount_quiet --bind "$BINPKGS_DIR" "$M$CHROOT_BINPKGS_PATH"
  fi

  # DNS bind - same caveat as session: don't truncate, just create if missing.
  if [[ ! -e "$M/etc/resolv.conf" ]]; then
    install -m 0644 /dev/null "$M/etc/resolv.conf" 2>/dev/null || true
  fi
  if [[ -e "$M/etc/resolv.conf" ]]; then
    _mount_quiet --bind /etc/resolv.conf "$M/etc/resolv.conf"
  fi
}

# =============================================================================
# Internal: __ns-helper (re-entered inside unshare -m)
# =============================================================================
#
# Performs the mounts then exec-chroots. Never returns. Stdin/stdout/stderr
# are inherited from the outer process (so heredocs to in_baseline_chroot
# and interactive bash sessions both work).

_ns_helper_main() {
  local mode="${1:-}"
  shift || true
  case "$mode" in
    session)
      local name="${1:-}"
      shift || true
      [[ -n "$name" ]] || die "__ns-helper session: missing name"
      _ns_session_mount "$name"
      exec chroot "$(session_merged "$name")" "$@"
      ;;
    baseline-rw)
      _ns_baseline_mount rw
      exec chroot "$BASELINE_DIR" "$@"
      ;;
    baseline-ro)
      _ns_baseline_mount ro
      exec chroot "$BASELINE_DIR" "$@"
      ;;
    *)
      die "__ns-helper: unknown mode '$mode'"
      ;;
  esac
}

# =============================================================================
# Helpers
# =============================================================================

cp_template() {
  local name="$1" dest="$2"
  [[ -f "$SHARE_DIR/$name" ]] || die "missing template $SHARE_DIR/$name"
  local nproc_val="${NPROC:-$(nproc 2>/dev/null || echo 4)}"
  case "$nproc_val" in
    ''|*[!0-9]*) die "refusing to substitute non-numeric NPROC='$nproc_val' into $name" ;;
  esac
  sed -e "s|@NPROC@|$nproc_val|g" \
      -e "s|@GENTOO_PROFILE@|$GENTOO_PROFILE|g" \
      "$SHARE_DIR/$name" >"$dest"
  chmod 0644 "$dest"
}

# =============================================================================
# Usage / dispatch
# =============================================================================

usage() {
  cat <<'USAGE'
tinderbox-ng - Gentoo build-testing rig with overlayfs sessions

Subcommands:
  doctor                   Preflight: check host has every required tool +
                           kernel feature + template + disk space before
                           bootstrap. Reports all problems in one pass.
                           Run by `bootstrap` automatically (skip with
                           TINDERBOX_SKIP_DOCTOR=1).
  bootstrap                Build the immutable baseline (stage3 + swi-prolog
                           + ccache + portage-ng + kb.qlf). Long-running.
                           Set TINDERBOX_BOOTSTRAP_SELFTEST=1 to also run
                           `selftest` on completion.
  selftest                 Smoke-test a freshly-bootstrapped baseline:
                           `compare --pretend sys-apps/portage` in a fresh
                           session. Override target via TINDERBOX_SELFTEST_TARGET.
  refresh-tree [<commit>]  Re-pin shared/portage-tree to <commit> (default: master).
                           Existing sessions keep the old tree until reset.
  refresh-kb               Regenerate kb.qlf inside baseline against the pinned
                           tree (requires baseline to be unfrozen briefly).
  refresh-portage-ng       Re-deploy the portage-ng source tree into the
                           baseline from PORTAGE_NG_LOCAL (or PORTAGE_NG_URL).
                           Does NOT regenerate kb.qlf.
  install-ccache           Retrofit dev-util/ccache + /etc/ccache.conf into an
                           existing baseline (or bump max_size). Idempotent.
  install-kernel-sources   Retrofit sys-kernel/gentoo-sources (or
                           \$TINDERBOX_KERNEL_PACKAGE) into an existing baseline
                           and set /usr/src/linux via `eselect kernel set 1`.
                           Needed for ebuilds that probe kernel headers
                           during src_configure/src_compile. Idempotent.
  baseline-thaw            One-shot migration for legacy baselines bootstrapped
                           by an older tinderbox-ng that called bootstrap_freeze
                           (chmod a-w on files and/or dirs). Restores owner-write
                           on every file and dir in the baseline. Idempotent and
                           cheap (~1s for a 70k-file stage3). `tinderbox-ng
                           doctor` warns when this is needed.
  refresh-baseline-config  Re-apply share/tinderbox-ng portage templates
                           (make.conf, repos.conf, package.use) into an existing
                           baseline. Picks up template fixes (e.g. LDFLAGS pin)
                           without TINDERBOX_REBOOTSTRAP=1. Idempotent.

  new <name>               Create an empty session.
  enter <name>             Mount overlay + binds and chroot in (interactive).
  exec <name> -- <cmd...>  Mount, run <cmd> non-interactively, capture log,
                           unmount. Exits with the command's exit code.
  exit <name>              Tear down all mounts for <name> (idempotent).
  reset <name>             Discard the upper layer (revert to baseline).
  destroy <name>           Remove the session directory entirely.

  portage-ng <name> [--pretend|--build] <args...>
                           Run portage-ng-dev inside session. Default: --build.
  emerge <name> [--pretend] <args...>
                           Run /usr/bin/emerge inside session (--oneshot).
  compare [--pretend|--build] [--keep] [--label NAME] <pkg>
                           Spin two fresh sessions, run portage-ng AND emerge
                           on the same target in parallel, print a side-by-side
                           summary (exit codes, plan size, completed steps,
                           VDB delta, first error). Default: --pretend.
  continue [--run DIR] [--jobs N] [--background]
                           Resume a compare-matrix run that was interrupted
                           (host crash, reboot, SIGINT). Auto-mounts tmpfs,
                           auto-detects the most recent run, recovers
                           mode/manifest/jobs from meta.txt, and dispatches
                           compare-matrix on every target not yet in
                           results.tsv. Appends to the original run's TSV +
                           meta.txt (no sibling stamp dir). Alias: `resume`.

  list                     Show sessions, mount status, upper size, age.
  diff <name>              Print files modified in the session's upper layer.
  status                   Show tinderbox-ng global state (paths, pin, sizes).
  progress [--once]        Live dashboard: progress bar + ETA + load avg
           [--interval N]  + RAM + tmpfs + active sessions, refreshed every
           [--run DIR]     N seconds (default 2). Auto-detects the latest
                           compare-matrix run; --once for a one-shot dump
                           (also the default when stdout is not a tty).

  analyze [--run DIR |     Plan-correctness analysis over a matrix run (or
           --logdir DIR]   any dir of compare-<label>-<stamp>/ subdirs).
          [--out FILE]     Pairs portage-ng.plan.log and emerge.plan.log
          [--jobs N]       per package and feeds them through
          [--md5-cache D]  share/tinderbox-ng/compare-merge-emerge.py to
          [--target-regex] compute Jaccard set agreement, Kendall+Spearman
                           ordering metrics, dep-aware concordance and
                           violation rate (with --md5-cache), domain
                           assumptions, blockers, cycle breaks, download
                           agreement, and timing. Writes <source>/
                           analysis.{json,txt}. Alias: `analyse`.

  phase-stats [--run DIR | Consolidate per-session phase_stats.pl files
               --logdir D| (salvaged into each compare logdir by
               --src DIR]  `compare`) into a single master phase_stats.pl
              [--out FILE] suitable as the next portage-ng instance's
              [--aggregator NAME]
                           Knowledge/phase_stats.pl seed for build-time
              [--min-observations N]
                           forecasting. Aggregator is one of
              [--exclude-glob PAT ...]
                           median (default) | mean | max | p75 | p90.
                           Default output: <run>/phase_stats.pl. Aliases:
                           `phase_stats`, `consolidate-phase-stats`.

  extract-timing [--run DIR | --logdir DIR | --src DIR | --session DIR]
                 [--out FILE] [--quiet]
                           Extract per-engine wall-clock timing from
                           compare session logs into a JSON report
                           (started/ended/wall_time_ms/rc per pass plus
                           pn-vs-emerge ratios and aggregate stats).
                           Reads the <log>.timing files cmd_compare
                           writes; falls back to log mtime/ctime for
                           older sessions. Default output:
                           <source>/timing.json. Aliases: `timing`,
                           `extract_timing`.

  tmpfs-up                 Mount the shared sessions tmpfs (idempotent).
                           Auto-runs on `new`/`compare`/`continue`; this
                           is for explicit pre-allocation before a long
                           batch (or to remount after a host reboot).
  tmpfs-down               Unmount the shared sessions tmpfs (only if
                           no sessions remain; destroys their contents).

Environment:
  TINDERBOX_ROOT                  Root for everything (default /srv/tinderbox-ng).
  TINDERBOX_SESSIONS_TMPFS_SIZE   tmpfs size cap for $TINDERBOX_ROOT/sessions
                                  (default auto: sized from RAM and compare
                                  --jobs; 0 or empty disables; nested mount
                                  is skipped when $TINDERBOX_ROOT is tmpfs).
  TINDERBOX_MATRIX_JOBS           Hint for auto sessions-tmpfs sizing when
                                  set by compare-matrix (usually leave unset).
  TINDERBOX_CCACHE_MAX_SIZE       Cap for the shared ccache (default 100G).
                                  Read by bootstrap_install_ccache and the
                                  `install-ccache` retrofit subcommand.
  TINDERBOX_KERNEL_PACKAGE        Kernel-source package emerged into the
                                  baseline (default sys-kernel/gentoo-sources).
                                  Read by bootstrap_install_kernel_sources and
                                  the `install-kernel-sources` retrofit. The
                                  installed tree is also `make defconfig`'d,
                                  `modules_prepare`'d, and `make modules`'d so
                                  linux-mod ebuilds see Module.symvers.
                                  Kernel-mod matrix targets:
                                  share/tinderbox-ng/manifest-kernel-modules.txt
  TINDERBOX_PLAN_TIMEOUT          Per-package planning timeout in seconds
                                  (default 1800). Used by `compare`'s
                                  --pretend pass for both engines. Capped
                                  at TINDERBOX_BUILD_TIMEOUT.
  TINDERBOX_BUILD_TIMEOUT         Per-package build timeout in seconds
                                  (default 43200 = 12h). Used by `compare`'s
                                  --build pass for both engines, and by
                                  `pn`/`em` standalone runs.
  TINDERBOX_LIBEXEC_DIR           Override location of executable helpers
                                  (default $SCRIPT_DIR/../libexec/tinderbox-ng).
  TINDERBOX_SHARE_DIR             Override location of data templates
                                  (default $SCRIPT_DIR/../share/tinderbox-ng).
  TINDERBOX_LIB_DIR               Legacy single-bucket override that maps to
                                  both LIBEXEC_DIR and SHARE_DIR (pre-reorg
                                  installs that flattened everything).
  TINDERBOX_COMPARE_ANALYZER      Override path to compare-merge-emerge.py
                                  (default $LIBEXEC_DIR/compare-merge-emerge.py).
                                  Read by `tinderbox-ng analyze`.
  TINDERBOX_PHASE_STATS_CONSOLIDATOR
                                  Override path to consolidate-phase-stats.py
                                  (default $LIBEXEC_DIR/consolidate-phase-stats.py).
                                  Read by `tinderbox-ng phase-stats`.
  TINDERBOX_TIMING_EXTRACTOR      Override path to extract-timing.py
                                  (default $LIBEXEC_DIR/extract-timing.py).
                                  Read by `tinderbox-ng extract-timing`.
  STAGE3_VARIANT                  e.g. amd64-openrc (default).
  PORTAGE_TREE_URL                Default https://github.com/gentoo-mirror/gentoo.git
  PORTAGE_TREE_PIN                Optional commit to pin during bootstrap.
  PORTAGE_NG_URL                  If set: git clone. Otherwise rsync PORTAGE_NG_LOCAL.
  PORTAGE_NG_LOCAL                Local portage-ng checkout to seed (e.g. /opt/portage-ng).
  TINDERBOX_REBOOTSTRAP=1         Allow `bootstrap` to overwrite an existing baseline.

See README.md in this repository for deployment notes.
USAGE
}

main() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then usage; exit 2; fi
  shift

  case "$sub" in
    # User-facing subcommands
    doctor)       cmd_doctor       "$@" ;;
    selftest)     cmd_selftest     "$@" ;;
    bootstrap)    cmd_bootstrap    "$@" ;;
    refresh-tree) cmd_refresh_tree "$@" ;;
    refresh-kb)   cmd_refresh_kb   "$@" ;;
    refresh-portage-ng) cmd_refresh_portage_ng "$@" ;;
    refresh_portage_ng) cmd_refresh_portage_ng "$@" ;;
    install-ccache) cmd_install_ccache "$@" ;;
    install_ccache) cmd_install_ccache "$@" ;;
    install-kernel-sources) cmd_install_kernel_sources "$@" ;;
    install_kernel_sources) cmd_install_kernel_sources "$@" ;;
    baseline-thaw)         cmd_baseline_thaw "$@" ;;
    baseline_thaw)         cmd_baseline_thaw "$@" ;;
    refresh-baseline-config) cmd_refresh_baseline_config "$@" ;;
    refresh_baseline_config) cmd_refresh_baseline_config "$@" ;;
    new)          cmd_new          "$@" ;;
    enter)        cmd_enter        "$@" ;;
    exec)         cmd_exec         "$@" ;;
    exit)         cmd_exit         "$@" ;;
    reset)        cmd_reset        "$@" ;;
    destroy)      cmd_destroy      "$@" ;;
    portage-ng)   cmd_portage_ng   "$@" ;;
    portage_ng)   cmd_portage_ng   "$@" ;;
    pn)           cmd_portage_ng   "$@" ;;
    emerge)       cmd_emerge       "$@" ;;
    em)           cmd_emerge       "$@" ;;
    compare)      cmd_compare      "$@" ;;
    cmp)          cmd_compare      "$@" ;;
    continue)     cmd_continue     "$@" ;;
    resume)       cmd_continue     "$@" ;;
    list)         cmd_list         "$@" ;;
    diff)         cmd_diff         "$@" ;;
    status)       cmd_status       "$@" ;;
    progress)     cmd_progress     "$@" ;;
    monitor)      cmd_progress     "$@" ;;
    analyze)      cmd_analyze      "$@" ;;
    analyse)      cmd_analyze      "$@" ;;
    phase-stats)  cmd_phase_stats  "$@" ;;
    phase_stats)  cmd_phase_stats  "$@" ;;
    consolidate-phase-stats) cmd_phase_stats "$@" ;;
    extract-timing) cmd_extract_timing "$@" ;;
    extract_timing) cmd_extract_timing "$@" ;;
    timing)         cmd_extract_timing "$@" ;;
    tmpfs-up)     cmd_tmpfs_up     "$@" ;;
    tmpfs_up)     cmd_tmpfs_up     "$@" ;;
    tmpfs-down)   cmd_tmpfs_down   "$@" ;;
    tmpfs_down)   cmd_tmpfs_down   "$@" ;;
    -h|--help|help) usage; exit 0 ;;

    # Internal: re-entered inside `unshare --mount --ipc --propagation=private`
    # by cmd_enter / cmd_exec / in_baseline_chroot. Not for user use.
    __ns-helper) _ns_helper_main   "$@" ;;

    *)            usage; die "unknown subcommand: $sub" ;;
  esac
}

main "$@"
